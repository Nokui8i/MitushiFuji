{% comment %}
  Shared Mitushi product carousel styles (homepage, product, cart, recommendations).
{% endcomment %}
<style>
  .mitushi-product-carousel {
    background-color: var(--ink);
    padding-top: 72px;
    padding-bottom: 72px;
  }

  .mitushi-carousel-container {
    margin: 0 auto;
    max-width: 1320px;
    padding: 0 24px;
  }

  .mitushi-carousel-header {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 20px;
    margin-bottom: 32px;
  }

  .mitushi-carousel-title-group > div:first-child {
    font-size: 10px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.5em;
    color: #cc132a;
    margin-bottom: 10px;
  }

  .mitushi-carousel-title-group > h2 {
    font-family: var(--font-display);
    letter-spacing: 0.02em;
    font-size: 28px;
    font-weight: 700;
    color: #f7f7f8;
    margin: 0;
  }

  @media (min-width: 768px) {
    .mitushi-carousel-title-group > h2 {
      font-size: 48px;
    }
  }

  .mitushi-carousel-controls {
    display: flex;
    gap: 8px;
    flex-shrink: 0;
  }

  .mitushi-carousel-btn {
    display: grid;
    place-items: center;
    width: 36px;
    height: 36px;
    border: 1px solid rgba(255, 255, 255, 0.2);
    background: transparent;
    color: #f7f7f8;
    cursor: pointer;
    transition: all 0.3s;
  }

  .mitushi-carousel-btn:hover {
    border-color: #cc132a;
    color: #cc132a;
  }

  .mitushi-carousel-track {
    display: flex;
    gap: 12px;
    overflow-x: auto;
    padding-bottom: 12px;
    scroll-snap-type: x mandatory;
    scroll-behavior: smooth;
    -ms-overflow-style: none;
    scrollbar-width: none;
  }

  .mitushi-carousel-track::-webkit-scrollbar {
    display: none;
  }

  .mitushi-product-card {
    position: relative;
    flex-shrink: 0;
    width: 56vw;
    max-width: 260px;
    scroll-snap-align: start;
  }

  @media (min-width: 640px) {
    .mitushi-product-card {
      width: 300px;
      max-width: none;
    }
  }

  @media (min-width: 1200px) {
    .mitushi-product-card {
      width: 320px;
    }
  }

  .mitushi-product-image-wrapper {
    position: relative;
    aspect-ratio: 4 / 5.15;
    overflow: hidden;
    background-color: rgba(255, 255, 255, 0.05);
  }

  .mitushi-product-front,
  .mitushi-product-back {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: opacity 500ms;
  }

  .mitushi-product-back {
    opacity: 0;
  }

  .mitushi-product-card:hover .mitushi-product-back {
    opacity: 1;
  }

  .mitushi-product-card:hover .mitushi-product-front {
    opacity: 0;
  }

  .mitushi-product-badge {
    position: absolute;
    left: 10px;
    top: 10px;
    background-color: #cc132a;
    padding: 3px 8px;
    font-size: 9px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.28em;
    color: #f7f7f8;
    z-index: 10;
  }

  .mitushi-product-add-btn {
    position: absolute;
    right: 10px;
    top: 10px;
    display: grid;
    place-items: center;
    width: 34px;
    height: 34px;
    background-color: rgba(247, 247, 248, 0.95);
    color: #28282B;
    border: none;
    cursor: pointer;
    opacity: 0;
    transition: all 0.3s;
    z-index: 10;
  }

  .mitushi-product-card:hover .mitushi-product-add-btn {
    opacity: 1;
  }

  .mitushi-product-add-btn:hover {
    background-color: #cc132a;
    color: #f7f7f8;
  }

  .mitushi-product-cta {
    position: absolute;
    inset-inline: 0;
    bottom: 0;
    background-color: rgba(40, 40, 43, 0.95);
    padding: 10px 12px;
    backdrop-filter: blur(4px);
    transform: translateY(100%);
    transition: transform 500ms cubic-bezier(0.16, 1, 0.3, 1);
  }

  .mitushi-product-card:hover .mitushi-product-cta {
    transform: translateY(0);
  }

  .mitushi-product-cta-content {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 8px;
  }

  .mitushi-product-cta-info {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .mitushi-product-cta-label {
    font-size: 8px;
    text-transform: uppercase;
    letter-spacing: 0.22em;
    color: rgba(255, 255, 255, 0.6);
    line-height: 1;
  }

  .mitushi-product-price {
    font-family: var(--font-display);
    letter-spacing: 0.02em;
    font-size: 15px;
    font-weight: 700;
    line-height: 1.1;
    color: #f7f7f8;
  }

  .mitushi-product-cart-btn {
    background-color: #cc132a;
    padding: 6px 10px;
    font-size: 9px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    color: #f7f7f8;
    border: none;
    cursor: pointer;
    transition: all 0.3s;
    white-space: nowrap;
    flex-shrink: 0;
  }

  .mitushi-product-cart-btn:hover {
    background-color: #ff1a3a;
  }

  .mitushi-product-info {
    margin-top: 12px;
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 12px;
  }

  .mitushi-product-details {
    flex: 1;
    min-width: 0;
  }

  .mitushi-product-name {
    font-family: var(--font-display);
    letter-spacing: 0.02em;
    font-size: clamp(0.9375rem, 3.4vw, 1.0625rem);
    font-weight: 700;
    line-height: 1.2;
    color: #f7f7f8;
    margin: 0;
  }

  .mitushi-product-tag {
    margin-top: 3px;
    font-size: clamp(0.625rem, 2.2vw, 0.6875rem);
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.16em;
    color: rgba(255, 255, 255, 0.45);
    margin-bottom: 0;
  }

  .mitushi-product-info-price {
    font-family: var(--font-display);
    letter-spacing: 0.02em;
    font-size: 16px;
    font-weight: 700;
    line-height: 1;
    color: #f7f7f8;
    flex-shrink: 0;
  }

  @media (min-width: 768px) {
    .mitushi-product-name {
      font-size: 1.125rem;
      line-height: 1.25;
    }

    .mitushi-product-tag {
      font-size: 0.6875rem;
    }

    .mitushi-product-info-price {
      font-size: 20px;
    }
  }

  @media (max-width: 767px) {
    .mitushi-product-carousel {
      padding-top: 56px;
      padding-bottom: 56px;
    }

    .mitushi-carousel-container {
      padding-inline: 1rem;
    }

    .mitushi-carousel-header {
      margin-bottom: 24px;
    }

    .mitushi-carousel-title-group > h2 {
      font-size: clamp(1.35rem, 7vw, 1.75rem);
    }
  }
</style>
