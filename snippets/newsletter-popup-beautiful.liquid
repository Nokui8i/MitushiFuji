{% comment %}
  Mitushi inner-circle newsletter popup (from mitushi-stellar-showcase).
{% endcomment %}

{%- liquid
  assign form_id = 'beautifulNewsletterForm' | append: section.id
  assign eyebrow = section.settings.headline_main
  assign title_before = section.settings.headline_sub
  assign title_highlight = section.settings.logo_text
  assign title_after = section.settings.title_after
  assign description_text = section.settings.description_text
  assign email_label = section.settings.email_label
  assign button_text = section.settings.button_text
  assign legal_text = section.settings.description_legal
  assign dismiss_text = section.settings.dismiss_text
  assign success_title = section.settings.success_title
  assign success_message = section.settings.success_message
  assign visual_jp = section.settings.visual_jp
  assign visual_mark = section.settings.visual_mark
  assign visual_tag = section.settings.visual_tag

  assign popup_logo_height = section.settings.logo_size | default: 56
  assign eyebrow_size = section.settings.headline_main_size | default: 10
  assign title_size = section.settings.headline_sub_size | default: 36
  assign desc_size = section.settings.description_size | default: 14
  assign email_label_size = section.settings.email_label_size | default: 10
  assign email_input_size = section.settings.email_input_size | default: 14
  assign email_input_padding = section.settings.email_input_padding | default: 12
  assign button_font_size = section.settings.button_font_size | default: 11
  assign button_padding = section.settings.button_padding | default: 14
  assign popup_width_pct = section.settings.popup_width | default: 70
  assign popup_height_pct = section.settings.popup_height | default: 85

  if section.settings.logo_image != blank
    assign popup_logo_url = section.settings.logo_image | image_url: width: 440
    assign popup_logo_alt = section.settings.logo_image.alt | default: shop.name
  else
    assign popup_logo_url = 'mitushi-logo.png' | asset_url
    assign popup_logo_alt = shop.name
  endif
-%}

<style>
  #shopify-section-{{ section.id }} .mitushi-nl-popup {
    --nl-popup-width: {{ popup_width_pct }}vw;
    --nl-popup-max-height: {{ popup_height_pct }}vh;
    --nl-logo-height: {{ popup_logo_height }}px;
    --nl-eyebrow-size: {{ eyebrow_size }}px;
    --nl-title-size: {{ title_size }}px;
    --nl-desc-size: {{ desc_size }}px;
    --nl-email-label-size: {{ email_label_size }}px;
    --nl-input-size: {{ email_input_size }}px;
    --nl-input-padding: {{ email_input_padding }}px;
    --nl-button-size: {{ button_font_size }}px;
    --nl-button-padding: {{ button_padding }}px;
  }

  .mitushi-nl-popup {
    position: relative;
    width: min(940px, var(--nl-popup-width, 95vw), 95vw);
    max-height: min(var(--nl-popup-max-height, 92vh), 92vh);
    overflow-x: hidden;
    overflow-y: auto;
    border: 1px solid rgba(255, 255, 255, 0.12);
    background: #28282b;
    color: #f7f7f8;
    box-shadow: 0 24px 64px rgba(0, 0, 0, 0.55);
    animation: mitushi-nl-popup-in 0.45s cubic-bezier(0.16, 1, 0.3, 1);
  }

  @media (max-width: 767px) {
    .mitushi-nl-popup {
      width: 100vw;
      max-width: 100vw;
      max-height: 96vh;
      border-inline: none;
    }
  }

  @keyframes mitushi-nl-popup-in {
    from {
      opacity: 0;
      transform: translateY(24px) scale(0.98);
    }
    to {
      opacity: 1;
      transform: translateY(0) scale(1);
    }
  }

  @media (min-width: 640px) {
    @keyframes mitushi-nl-popup-in {
      from {
        opacity: 0;
        transform: scale(0.96);
      }
      to {
        opacity: 1;
        transform: scale(1);
      }
    }
  }

  .mitushi-nl-popup__close {
    position: absolute;
    top: 12px;
    right: 12px;
    z-index: 20;
    display: grid;
    place-items: center;
    width: 36px;
    height: 36px;
    border: 1px solid rgba(255, 255, 255, 0.2);
    background: rgba(40, 40, 43, 0.85);
    color: rgba(247, 247, 248, 0.75);
    backdrop-filter: blur(8px);
    cursor: pointer;
    transition: border-color 0.2s ease, background 0.2s ease, color 0.2s ease;
  }

  .mitushi-nl-popup__close:hover {
    border-color: #cc132a;
    background: #cc132a;
    color: #f7f7f8;
  }

  .mitushi-nl-popup__grid {
    display: grid;
    grid-template-columns: 1fr;
  }

  @media (min-width: 768px) {
    .mitushi-nl-popup__grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  .mitushi-nl-popup__visual {
    display: none;
    position: relative;
    min-height: 460px;
    overflow: hidden;
    background: linear-gradient(135deg, #1a1a1c 0%, #28282b 50%, #0f0f10 100%);
    flex-shrink: 0;
  }

  @media (min-width: 768px) {
    .mitushi-nl-popup__visual {
      display: block;
    }
  }

  .mitushi-nl-popup__visual-glow {
    position: absolute;
    left: 50%;
    top: 50%;
    width: min(280px, 85vw);
    height: min(280px, 85vw);
    transform: translate(-50%, -50%);
    border-radius: 50%;
    background: rgba(204, 19, 42, 0.8);
    filter: blur(48px);
    opacity: 0.6;
    pointer-events: none;
  }

  @media (min-width: 768px) {
    .mitushi-nl-popup__visual-glow {
      left: -64px;
      top: 50%;
      width: 420px;
      height: 420px;
      transform: translateY(-50%);
      filter: blur(64px);
    }
  }

  .mitushi-nl-popup__visual-ring {
    position: absolute;
    left: 50%;
    top: 50%;
    width: 140px;
    height: 140px;
    transform: translate(-50%, -50%);
    border-radius: 50%;
    border: 2px solid rgba(204, 19, 42, 0.8);
    background: rgba(204, 19, 42, 0.3);
    pointer-events: none;
  }

  @media (min-width: 768px) {
    .mitushi-nl-popup__visual-ring {
      left: 40px;
      width: 224px;
      height: 224px;
      transform: translateY(-50%);
    }
  }

  .mitushi-nl-popup__visual-grid {
    position: absolute;
    inset: 0;
    opacity: 0.08;
    background-image:
      linear-gradient(to right, #f4f4f4 1px, transparent 1px),
      linear-gradient(to bottom, #f4f4f4 1px, transparent 1px);
    background-size: 40px 40px;
    pointer-events: none;
  }

  .mitushi-nl-popup__visual-jp {
    position: absolute;
    left: 16px;
    top: 16px;
    font-size: 9px;
    letter-spacing: 0.4em;
    color: rgba(247, 247, 248, 0.6);
    writing-mode: vertical-rl;
  }

  @media (min-width: 768px) {
    .mitushi-nl-popup__visual-jp {
      left: 24px;
      top: 24px;
      font-size: 11px;
      letter-spacing: 0.5em;
    }
  }

  .mitushi-nl-popup__visual-center {
    position: absolute;
    inset: 0;
    display: grid;
    place-items: center;
    text-align: center;
    pointer-events: none;
  }

  .mitushi-nl-popup__visual-mark {
    font-family: var(--font-display, inherit);
    font-size: clamp(2.75rem, 14vw, 4rem);
    line-height: 0.95;
    letter-spacing: 0.02em;
    color: transparent;
    -webkit-text-stroke: 1px rgba(247, 247, 248, 0.85);
    text-stroke: 1px rgba(247, 247, 248, 0.85);
  }

  @media (min-width: 768px) {
    .mitushi-nl-popup__visual-mark {
      font-size: clamp(4rem, 9vw, 7rem);
    }
  }

  .mitushi-nl-popup__visual-tag {
    margin-top: 8px;
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.5em;
    text-transform: uppercase;
    color: #cc132a;
  }

  .mitushi-nl-popup__panel {
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 24px 20px 28px;
  }

  @media (min-width: 768px) {
    .mitushi-nl-popup__panel {
      padding: 40px;
    }
  }

  .mitushi-nl-popup__brand {
    display: flex;
    justify-content: center;
    margin-bottom: 20px;
    position: relative;
  }

  @media (min-width: 768px) {
    .mitushi-nl-popup__brand {
      display: none;
    }
  }

  .mitushi-nl-popup__brand-glow {
    position: absolute;
    inset: -8px -20%;
    border-radius: 999px;
    background: radial-gradient(ellipse at center, rgba(204, 19, 42, 0.35) 0%, transparent 70%);
    pointer-events: none;
  }

  .mitushi-nl-popup__brand-logo {
    position: relative;
    z-index: 1;
    display: block;
    height: var(--nl-logo-height, 56px);
    width: auto;
    max-width: min(220px, 72vw);
    object-fit: contain;
    filter: brightness(2.2) contrast(1.25);
  }

  .mitushi-nl-popup__eyebrow {
    font-size: var(--nl-eyebrow-size, 10px);
    font-weight: 700;
    letter-spacing: 0.5em;
    text-transform: uppercase;
    color: #cc132a;
  }

  .mitushi-nl-popup__title {
    margin: 12px 0 0;
    font-family: var(--font-display, inherit);
    font-size: clamp(var(--nl-title-size, 1.75rem), 5vw, var(--nl-title-size, 2.25rem));
    line-height: 1.05;
    letter-spacing: 0.02em;
    color: #f7f7f8;
    font-weight: 700;
  }

  .mitushi-nl-popup__title span {
    color: #cc132a;
  }

  .mitushi-nl-popup__desc {
    margin: 16px 0 0;
    max-width: 22rem;
    font-size: var(--nl-desc-size, 14px);
    line-height: 1.65;
    color: rgba(247, 247, 248, 0.7);
  }

  .mitushi-nl-popup__form {
    margin-top: 28px;
  }

  .mitushi-nl-popup__label {
    display: block;
    margin-bottom: 8px;
    font-size: var(--nl-email-label-size, 10px);
    font-weight: 700;
    letter-spacing: 0.4em;
    text-transform: uppercase;
    color: rgba(247, 247, 248, 0.8);
  }

  .mitushi-nl-popup__input {
    width: 100%;
    padding: var(--nl-input-padding, 12px) 16px;
    border: 1px solid rgba(255, 255, 255, 0.14);
    background: #1d1d1f;
    color: #f7f7f8;
    font-size: var(--nl-input-size, 14px);
    outline: none;
    transition: border-color 0.2s ease;
    box-sizing: border-box;
  }

  .mitushi-nl-popup__input:focus {
    border-color: #cc132a;
  }

  .mitushi-nl-popup__submit {
    display: flex;
    width: 100%;
    align-items: center;
    justify-content: center;
    gap: 8px;
    margin-top: 12px;
    padding: var(--nl-button-padding, 14px) 16px;
    border: none;
    background: #cc132a;
    color: #f7f7f8;
    font-size: var(--nl-button-size, 11px);
    font-weight: 700;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    cursor: pointer;
    transition: background 0.2s ease;
  }

  .mitushi-nl-popup__submit:hover {
    background: #ff1a3a;
  }

  .mitushi-nl-popup__submit svg {
    width: 16px;
    height: 16px;
    transition: transform 0.2s ease;
  }

  .mitushi-nl-popup__submit:hover svg {
    transform: translateX(4px);
  }

  .mitushi-nl-popup__dismiss {
    display: block;
    margin-top: 20px;
    padding: 0;
    border: none;
    background: transparent;
    font-size: 10px;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: rgba(247, 247, 248, 0.4);
    cursor: pointer;
    transition: color 0.2s ease;
  }

  .mitushi-nl-popup__dismiss:hover {
    color: rgba(247, 247, 248, 0.7);
  }

  .mitushi-nl-popup__legal {
    margin: 24px 0 0;
    font-size: 10px;
    line-height: 1.6;
    color: rgba(247, 247, 248, 0.4);
  }

  .mitushi-nl-popup__success {
    padding: 40px 0;
    text-align: center;
  }

  .mitushi-nl-popup__success-icon {
    display: grid;
    place-items: center;
    width: 56px;
    height: 56px;
    margin: 0 auto;
    border-radius: 50%;
    background: #cc132a;
    color: #f7f7f8;
  }

  .mitushi-nl-popup__success-title {
    margin: 20px 0 0;
    font-family: var(--font-display, inherit);
    font-size: 1.75rem;
    letter-spacing: 0.02em;
    color: #f7f7f8;
  }

  .mitushi-nl-popup__success-msg {
    margin: 8px 0 0;
    font-size: 14px;
    color: rgba(247, 247, 248, 0.7);
  }

  .mitushi-nl-popup__error {
    margin-top: 12px;
    padding: 10px 12px;
    border: 1px solid rgba(204, 19, 42, 0.5);
    background: rgba(204, 19, 42, 0.12);
    color: #f7f7f8;
    font-size: 13px;
    text-align: start;
  }

  .mitushi-nl-popup__bar {
    height: 4px;
    background: linear-gradient(to right, transparent, #cc132a, transparent);
  }

  .mitushi-nl-popup.is-success .mitushi-nl-popup__form-view {
    display: none;
  }

  .mitushi-nl-popup:not(.is-success) .mitushi-nl-popup__success-view {
    display: none;
  }
</style>

<div class="mitushi-nl-popup{% if form.posted_successfully? %} is-success{% endif %}" data-mitushi-nl-popup>
  <button class="mitushi-nl-popup__close js-popup-close-btn" type="button" data-dismiss="modal" aria-label="{{ 'accessibility.close_popup' | t }}">
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
      <path d="M18 6L6 18M6 6l12 12"/>
    </svg>
  </button>

  <div class="mitushi-nl-popup__grid">
    <div class="mitushi-nl-popup__visual" aria-hidden="true">
      <div class="mitushi-nl-popup__visual-glow"></div>
      <div class="mitushi-nl-popup__visual-ring"></div>
      <div class="mitushi-nl-popup__visual-grid"></div>
      <div class="mitushi-nl-popup__visual-jp">{{ visual_jp }}</div>
      <div class="mitushi-nl-popup__visual-center">
        <div>
          <div class="mitushi-nl-popup__visual-mark">{{ visual_mark }}</div>
          <div class="mitushi-nl-popup__visual-tag">{{ visual_tag }}</div>
        </div>
      </div>
    </div>

    <div class="mitushi-nl-popup__panel">
      <div class="mitushi-nl-popup__brand">
        <span class="mitushi-nl-popup__brand-glow" aria-hidden="true"></span>
        <img
          src="{{ popup_logo_url }}"
          alt="{{ popup_logo_alt | escape }}"
          class="mitushi-nl-popup__brand-logo"
          width="220"
          height="44"
          loading="eager"
        >
      </div>

      <div class="mitushi-nl-popup__form-view">
        {%- if eyebrow != blank -%}
          <div class="mitushi-nl-popup__eyebrow">{{ eyebrow }}</div>
        {%- endif -%}
        {%- if title_before != blank or title_highlight != blank or title_after != blank -%}
          <h2 id="mitushi-newsletter-title-{{ section.id }}" class="mitushi-nl-popup__title">
            {{- title_before -}}
            {%- if title_highlight != blank -%}
              <span>{{ title_highlight }}</span>
            {%- endif -%}
            {{- title_after -}}
          </h2>
        {%- endif -%}
        {%- if description_text != blank -%}
          <p class="mitushi-nl-popup__desc">{{ description_text | newline_to_br }}</p>
        {%- endif -%}

        {%- form 'customer', id: form_id, class: 'mitushi-nl-popup__form' -%}
          <input type="hidden" name="contact[tags]" value="newsletter">

          <label for="email-{{ form_id }}" class="mitushi-nl-popup__label">{{ email_label }}</label>
          <input
            id="email-{{ form_id }}"
            type="email"
            name="contact[email]"
            class="mitushi-nl-popup__input"
            value="{{ form.email }}"
            aria-required="true"
            autocorrect="off"
            autocapitalize="off"
            autocomplete="email"
            {% if form.errors %}
              autofocus
              aria-invalid="true"
              aria-describedby="{{ form_id }}-error"
            {% endif %}
            required
          >

          <button type="submit" class="mitushi-nl-popup__submit">
            {{ button_text }}
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path d="M5 12h14M13 6l6 6-6 6"/>
            </svg>
          </button>

          {%- if form.errors -%}
            <div id="{{ form_id }}-error" class="mitushi-nl-popup__error" role="alert">
              {{ form.errors.translated_fields.email | capitalize }} {{ form.errors.messages.email }}
            </div>
          {%- endif -%}
        {%- endform -%}

        {%- if dismiss_text != blank -%}
          <button type="button" class="mitushi-nl-popup__dismiss js-popup-close-btn" data-dismiss="modal">
            {{ dismiss_text }}
          </button>
        {%- endif -%}

        {%- if legal_text != blank -%}
          <p class="mitushi-nl-popup__legal">{{ legal_text }}</p>
        {%- endif -%}
      </div>

      <div class="mitushi-nl-popup__success-view">
        <div class="mitushi-nl-popup__success">
          <div class="mitushi-nl-popup__success-icon" aria-hidden="true">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M5 12l5 5L19 7"/>
            </svg>
          </div>
          <h2 class="mitushi-nl-popup__success-title">{{ success_title }}</h2>
          <p class="mitushi-nl-popup__success-msg">{{ success_message }}</p>
        </div>
      </div>
    </div>
  </div>

  <div class="mitushi-nl-popup__bar" aria-hidden="true"></div>
</div>

<script>
  (function () {
    var popup = document.querySelector('[data-mitushi-nl-popup].is-success');
    if (!popup) return;
    window.setTimeout(function () {
      var close = popup.querySelector('.js-popup-close-btn');
      if (close) close.click();
    }, 1800);
  })();
</script>
