<sht-cart-noti id="cartNotificationPanel" class="js-cartNotificationPanel cart-notification no-focus-visible" tabindex="-1" hidden="true">
    <style>
      #cartNotificationPanel.cart-notification {
        display: block !important;
        visibility: visible !important;
        opacity: 1 !important;
        pointer-events: auto !important;
        
        position: absolute !important;
        top: 100% !important;
        right: 2rem !important;
        width: 380px !important;
        max-width: calc(100vw - 4rem) !important;
        margin-top: 12px !important;
        padding: 1.5rem !important;
        
        background: rgba(28, 28, 30, 0.96) !important;
        backdrop-filter: blur(20px) saturate(160%) !important;
        -webkit-backdrop-filter: blur(20px) saturate(160%) !important;
        border: 1px solid rgba(255, 255, 255, 0.12) !important;
        border-radius: 12px !important;
        box-shadow: 0 24px 48px rgba(0, 0, 0, 0.6) !important;
        z-index: 9999 !important;
        
        transition: opacity 0.3s cubic-bezier(0.4, 0, 0.2, 1), transform 0.3s cubic-bezier(0.4, 0, 0.2, 1) !important;
        transform: translateY(0) !important;
      }

      #cartNotificationPanel.cart-notification[hidden] {
        opacity: 0 !important;
        visibility: hidden !important;
        transform: translateY(-12px) !important;
        pointer-events: none !important;
      }

      /* Styles for contents to look premium and aligned with Mitushi brand */
      #cartNotificationPanel .cart-notification__links a.btn,
      #cartNotificationPanel .cart-notification__links button.btn {
        font-family: var(--font-display) !important;
        font-size: 14px !important;
        letter-spacing: 0.1em !important;
        text-transform: uppercase !important;
        border-radius: 6px !important;
        padding: 12px 18px !important;
        display: inline-flex !important;
        align-items: center !important;
        justify-content: center !important;
        transition: all 0.2s ease !important;
      }

      #cartNotificationPanel .btn-secondary--animate {
        background: transparent !important;
        border: 1px solid rgba(255, 255, 255, 0.2) !important;
        color: #f7f7f8 !important;
      }
      #cartNotificationPanel .btn-secondary--animate:hover {
        border-color: #cc132a !important;
        color: #cc132a !important;
        background: rgba(204, 19, 42, 0.08) !important;
      }

      #cartNotificationPanel .btn-primary--animate {
        background: #cc132a !important;
        border: 1px solid #cc132a !important;
        color: #fff !important;
      }
      #cartNotificationPanel .btn-primary--animate:hover {
        background: #e61934 !important;
        border-color: #e61934 !important;
        box-shadow: 0 0 12px rgba(204, 19, 42, 0.4) !important;
      }

      #cartNotificationPanel .cart-notification-panel-content .cart-item {
        border-bottom: 1px solid rgba(255, 255, 255, 0.08) !important;
        padding-bottom: 1rem !important;
        margin-bottom: 1rem !important;
      }
    </style>
    <div data-type="cart-notification-panel-wrapper" class="js-cart-notification-panel-wrapper p-relative" >
      <div class="focus-inset js-cart-notification-panel-container" aria-modal="true" aria-label="{{ 'general.cart.item_added' | t }}" role="dialog" tabindex="-1">
        <div class="d-flex middle-xs between-xs mb-24">
          <p class="m-zero d-flex middle-xs ">
            <span class="icon icon--small btn-icon bs-none color-accent-2 fs-0 mr-8">
              {%- render 'icon-check-mark', size: 16 -%}
            </span>
            {{ "general.cart.success_message" | t }}
          </p>
          <button type="button" class="btn btn-icon btn-small btn-secondary--animate js-cart-notification-panel-close-btn" aria-label="{{ 'accessibility.close' | t }}" >
            {% render 'icon-close' %}
          </button>
        </div>
        {% if settings.cart_show_free_shipping_notification and settings.cart_minimum_order_price_for_free_shipping != blank %}
          <div class="cart-notification-free-shipping js-cart-notification-free-shipping top-xs pb-8 pt-8"></div>
        {% endif %}
        <div class="js-cart-notification-panel-content cart-notification-panel-content d-grid top-xs mt-16 mb-24 gap-16 "></div>
        <div class="cart-notification__links">
          <a href="{{ routes.cart_url }}" {% if settings.cart_type == 'drawer' %} role="button" onclick="event.preventDefault();try { window.cartNotificationPanel.close(); window.shtCartDrawer.openDrawer(SHTHelper.qs('.js-header-cart-status-btn')); } catch(err) { window.location.assign('{{ routes.cart_url }}');}" {% endif %} aria-haspopup="true" aria-expanded="false" aria-controls="shtCartDrawer" class="btn btn-large btn-secondary--animate w-100 mb-16">
            <span class="d-block o-hidden p-relative">
              <span class="btn-secondary__content">
                {{ "general.cart.view" | t }} (<span class="js-cart-notification-panel-item-count-content"></span>)
              </span>
            </span>
          </a>
          <form action="{{ routes.cart_url }}" method="post" id="cart-notification-form">
            <button class="btn btn-large btn-primary--animate w-100 js-cart-notification-panel-btn mb-16" name="checkout">
              <span class="d-block o-hidden p-relative">
                <span class="btn-primary__content">
                  {{ "sections.cart.checkout" | t }}
                </span>
              </span>
            </button>
          </form>
        </div>
      </div>
    </div>
  </sht-cart-noti>