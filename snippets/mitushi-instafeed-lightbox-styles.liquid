{% comment %}
  Mintt Instafeed — compact lightbox (ANIQI-style popup sizing).
  The app injects .lightbox-instagram on <body>; theme cannot change popup type in Liquid.
{% endcomment %}
<style>
  /* Backdrop + centering */
  body:has(.lightbox-instagram) {
    overflow: hidden !important;
  }

  body > div:has(> .lightbox-instagram),
  body > div:has(.lightbox-instagram) {
    display: flex !important;
    align-items: center !important;
    justify-content: center !important;
    padding: clamp(16px, 3vw, 32px) !important;
    box-sizing: border-box !important;
  }

  .lightbox-instagram {
    position: relative !important;
    top: auto !important;
    left: auto !important;
    right: auto !important;
    bottom: auto !important;
    transform: none !important;
    margin: 0 auto !important;
    width: min(900px, 94vw) !important;
    max-width: min(900px, 94vw) !important;
    height: auto !important;
    max-height: min(640px, 82vh) !important;
    display: flex !important;
    flex-direction: row !important;
    align-items: stretch !important;
    border-radius: 14px !important;
    overflow: hidden !important;
    box-shadow: 0 28px 90px rgba(0, 0, 0, 0.55) !important;
    background: #ffffff !important;
  }

  .lightbox-instagram .instafeed-post-image,
  .lightbox-instagram .box-picture,
  .lightbox-instagram .box-image,
  .lightbox-instagram > div:first-child:not(.box-content) {
    flex: 1 1 58% !important;
    min-width: 0 !important;
    max-width: 58% !important;
    display: flex !important;
    align-items: center !important;
    justify-content: center !important;
    background: #0f0f10 !important;
    overflow: hidden !important;
  }

  .lightbox-instagram .instafeed-post-image img,
  .lightbox-instagram .instafeed-post-image video,
  .lightbox-instagram .box-picture img,
  .lightbox-instagram .box-picture video,
  .lightbox-instagram img:not(.instafeed-profile-image) {
    width: 100% !important;
    height: 100% !important;
    max-height: min(640px, 82vh) !important;
    object-fit: contain !important;
    object-position: center !important;
  }

  .lightbox-instagram .box-content {
    flex: 0 0 42% !important;
    width: 42% !important;
    max-width: 42% !important;
    min-width: 240px !important;
    max-height: min(640px, 82vh) !important;
    padding: 20px 22px !important;
    overflow-y: auto !important;
    overflow-x: hidden !important;
    background: #ffffff !important;
    color: #121212 !important;
    box-sizing: border-box !important;
  }

  .lightbox-instagram .box-content .instafeed-caption,
  .lightbox-instagram .box-content .caption,
  .lightbox-instagram .box-content p {
    font-size: 13px !important;
    line-height: 1.55 !important;
    color: #333 !important;
  }

  /* Nav arrows — keep inside viewport, not edge-to-edge */
  body > .instafeed-arrow,
  body > [class*="instafeed"][class*="arrow"],
  body > [class*="lightbox"][class*="arrow"],
  body > [class*="lightbox"][class*="prev"],
  body > [class*="lightbox"][class*="next"] {
    opacity: 0.85 !important;
  }

  @media (max-width: 767px) {
    .lightbox-instagram {
      flex-direction: column !important;
      width: min(420px, 94vw) !important;
      max-width: min(420px, 94vw) !important;
      max-height: 88vh !important;
    }

    .lightbox-instagram .instafeed-post-image,
    .lightbox-instagram .box-picture,
    .lightbox-instagram .box-image,
    .lightbox-instagram > div:first-child:not(.box-content),
    .lightbox-instagram .box-content {
      flex: none !important;
      width: 100% !important;
      max-width: 100% !important;
      min-width: 0 !important;
    }

    .lightbox-instagram .instafeed-post-image,
    .lightbox-instagram .box-picture,
    .lightbox-instagram .box-image,
    .lightbox-instagram > div:first-child:not(.box-content) {
      max-height: 52vh !important;
    }

    .lightbox-instagram .box-content {
      max-height: 36vh !important;
      padding: 16px !important;
    }
  }
</style>
