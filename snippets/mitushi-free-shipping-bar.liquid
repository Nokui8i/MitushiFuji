{% comment %}
  Free shipping progress — Mitushi cart (no sht-free-shipping-bar; theme JS overwrote copy & broke animation).
{% endcomment %}
{%- liquid
  assign fs_minimum = settings.cart_minimum_order_price_for_free_shipping | default: '199'
  if fs_minimum == blank
    assign fs_minimum = '199'
  endif
  assign free_shipping_threshold = fs_minimum | times: 100
  assign remaining = free_shipping_threshold | minus: cart.total_price
  if remaining < 0
    assign remaining = 0
  endif
  assign progress = cart.total_price | times: 100.0 | divided_by: free_shipping_threshold | at_most: 100
  assign qualified = false
  if cart.total_price >= free_shipping_threshold
    assign qualified = true
  endif
-%}

<div
  class="mitushi-freeship js-free-shipping-notification-message"
  data-freeship-threshold="{{ free_shipping_threshold }}"
>
  <div class="js-free-shipping-notification-value">
    <div
      class="mitushi-freeship__widget"
      data-total-price="{{ cart.total_price }}"
      data-free-shipping-price="{{ free_shipping_threshold }}"
    >
      <div class="mitushi-freeship__message-wrap mb-2 js-free-shipping-message">
        {%- if qualified -%}
          <span class="text-crimson">★ You unlocked free shipping</span>
        {%- else -%}
          Add <span class="text-crimson mitushi-freeship__remaining">{{ remaining | money }}</span> for free shipping
        {%- endif -%}
      </div>
      <div class="mitushi-freeship__track" aria-hidden="true">
        <div
          class="mitushi-freeship__fill js-free-shipping-progress-visual{% if qualified %} is-complete{% endif %}"
          style="width: {{ progress }}%;"
        ></div>
      </div>
      <progress
        class="mitushi-freeship__progress-native js-free-shipping-progress"
        value="{{ cart.total_price }}"
        max="{{ free_shipping_threshold }}"
        aria-label="Free shipping progress"
      ></progress>
    </div>
  </div>
</div>
