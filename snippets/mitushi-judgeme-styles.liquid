<style>

  /* Judge.me — Mitushi reviews page (grid + fallback) */

  .mitushi-reviews-page,

  .mitushi-judgeme-all-reviews-wrap {

    --jdgm-star-color: #cc132a;

    --jdgm-text: rgba(255, 255, 255, 0.92);

    --jdgm-muted: rgba(255, 255, 255, 0.55);

    --jdgm-border: rgba(255, 255, 255, 0.1);

    --jdgm-surface: rgba(255, 255, 255, 0.04);

    --jdgm-accent: #cc132a;

  }



  .mitushi-reviews-page .shopify-app-block,

  .mitushi-judgeme-all-reviews-wrap,

  .mitushi-judgeme-all-reviews,

  .mitushi-judgeme-all-reviews .jdgm-widget {

    color: var(--jdgm-text);

    font-family: var(--font-sans), system-ui, sans-serif;

    width: 100%;

    max-width: 100%;

  }



  /* No write-review on public page — reviews come from post-purchase emails */

  .mitushi-reviews-page .jdgm-write-rev-link,

  .mitushi-reviews-page .jdgm-rev-widg__write-review-link {

    display: none !important;

  }



  /* Judge.me star icon font */

  .mitushi-reviews-page .jdgm-star,

  .mitushi-reviews-page .jdgm-star:before,

  .mitushi-reviews-page .jdgm-star.jdgm--on:before,

  .mitushi-reviews-page .jdgm-star.jdgm--off:before,

  .mitushi-reviews-page .jdgm-star.jdgm--half:before,

  .mitushi-judgeme-all-reviews .jdgm-star,

  .mitushi-judgeme-all-reviews .jdgm-star:before {

    font-family: 'JudgemeStar' !important;

    color: var(--jdgm-star-color) !important;

    opacity: 1 !important;

    visibility: visible !important;

    text-transform: none !important;

    letter-spacing: 0 !important;

  }



  /* Reviews Grid / app block — Mitushi dark gallery */

  .mitushi-reviews-page .shopify-app-block,

  .mitushi-reviews-page .shopify-app-block .jdgm-widget,

  .mitushi-reviews-page .shopify-app-block [class*="jdgm"] {

    background: transparent !important;

    border: none !important;

    box-shadow: none !important;

    padding: 0 !important;

    margin: 0 !important;

    color: var(--jdgm-text) !important;

  }



  /* Hide Judge.me default title + empty shop rating (we use Mitushi heading) */

  .mitushi-reviews-page .shopify-app-block .jdgm-rev-widg__header,

  .mitushi-reviews-page .shopify-app-block .jdgm-rev-widg__title,

  .mitushi-reviews-page .shopify-app-block .jdgm-rev-widg__summary,

  .mitushi-reviews-page .shopify-app-block .jdgm-rev-widg__summary-text,

  .mitushi-reviews-page .shopify-app-block .jdgm-all-reviews-page__header,

  .mitushi-reviews-page .shopify-app-block > div > h2,

  .mitushi-reviews-page .shopify-app-block > div > h3,

  .mitushi-reviews-page .shopify-app-block [class*="grid-header"],

  .mitushi-reviews-page .shopify-app-block [class*="reviews-grid"] > h2,

  .mitushi-reviews-page .shopify-app-block [class*="reviews-grid"] > h3 {

    display: none !important;

  }



  .mitushi-reviews-page .shopify-app-block [class*="grid"],

  .mitushi-reviews-page .shopify-app-block [class*="gallery"] {

    gap: 14px !important;

  }



  .mitushi-reviews-page .shopify-app-block [class*="grid"] > *,

  .mitushi-reviews-page .shopify-app-block [class*="gallery"] > *,

  .mitushi-reviews-page .shopify-app-block [class*="card"],

  .mitushi-reviews-page .shopify-app-block [class*="tile"] {

    border-radius: 8px !important;

    overflow: hidden !important;

    border: 1px solid rgba(255, 255, 255, 0.08) !important;

    background: rgba(255, 255, 255, 0.03) !important;

    transition: border-color 0.25s ease, transform 0.25s ease !important;

  }



  .mitushi-reviews-page .shopify-app-block [class*="grid"] > *:hover,

  .mitushi-reviews-page .shopify-app-block [class*="gallery"] > *:hover,

  .mitushi-reviews-page .shopify-app-block [class*="card"]:hover {

    border-color: rgba(204, 19, 42, 0.45) !important;

    transform: translateY(-2px) !important;

  }



  .mitushi-reviews-page .shopify-app-block [class*="overlay"],

  .mitushi-reviews-page .shopify-app-block [class*="caption"],

  .mitushi-reviews-page .shopify-app-block [class*="footer"] {

    background: linear-gradient(180deg, transparent 0%, rgba(20, 20, 22, 0.92) 72%) !important;

  }



  .mitushi-reviews-page .shopify-app-block button,

  .mitushi-reviews-page .shopify-app-block [class*="show-more"],

  .mitushi-reviews-page .shopify-app-block [class*="load-more"],

  .mitushi-reviews-page .shopify-app-block a[class*="more"] {

    color: #fff !important;

    background: transparent !important;

    border: 1px solid rgba(255, 255, 255, 0.18) !important;

    border-radius: 999px !important;

    padding: 10px 22px !important;

    font-size: 11px !important;

    letter-spacing: 0.14em !important;

    text-transform: uppercase !important;

    margin-top: 28px !important;

    transition: border-color 0.2s ease, color 0.2s ease !important;

  }



  .mitushi-reviews-page .shopify-app-block button:hover,

  .mitushi-reviews-page .shopify-app-block [class*="show-more"]:hover,

  .mitushi-reviews-page .shopify-app-block a[class*="more"]:hover {

    border-color: var(--jdgm-accent) !important;

    color: var(--jdgm-accent) !important;

  }



  .mitushi-reviews-page .shopify-app-block img {

    border-radius: 4px;

  }



  .mitushi-reviews-page .shopify-app-block [class*="jdgm-rev"],

  .mitushi-reviews-page .shopify-app-block [class*="jdgm-grid"] {

    color: var(--jdgm-text);

  }



  .mitushi-reviews-page .shopify-app-block [class*="verified"],

  .mitushi-reviews-page .shopify-app-block .jdgm-rev__buyer-badge {

    color: var(--jdgm-muted) !important;

    font-size: 11px !important;

    letter-spacing: 0.04em !important;

  }



  .mitushi-reviews-page .shopify-app-block .jdgm-rev__author,

  .mitushi-reviews-page .shopify-app-block [class*="reviewer"] {

    color: #fff !important;

    font-weight: 600 !important;

    font-size: 13px !important;

  }



  .mitushi-reviews-page .shopify-app-block .jdgm-rev__body,

  .mitushi-reviews-page .shopify-app-block .jdgm-rev__content,

  .mitushi-reviews-page .shopify-app-block [class*="review-text"],

  .mitushi-reviews-page .shopify-app-block [class*="review-body"] {

    color: var(--jdgm-muted) !important;

    line-height: 1.65 !important;

    font-size: 13px !important;

  }



  .mitushi-reviews-page .shopify-app-block .jdgm-rev__timestamp,

  .mitushi-reviews-page .shopify-app-block [class*="date"] {

    color: rgba(255, 255, 255, 0.35) !important;

    font-size: 11px !important;

  }



  .mitushi-reviews-page .shopify-app-block .jdgm-rev__prod-link,

  .mitushi-reviews-page .shopify-app-block a[href*="/products/"] {

    color: var(--jdgm-accent) !important;

    font-size: 11px !important;

    letter-spacing: 0.06em !important;

    text-transform: uppercase !important;

    text-decoration: none !important;

  }



  .mitushi-reviews-page .shopify-app-block .jdgm-rev__prod-link:hover,

  .mitushi-reviews-page .shopify-app-block a[href*="/products/"]:hover {

    text-decoration: underline !important;

  }



  /* Fallback: All Reviews Page (histogram) */

  .mitushi-judgeme-all-reviews .jdgm-widget {

    color: var(--jdgm-text) !important;

    background: transparent !important;

    border: none !important;

    box-shadow: none !important;

    padding: 0 !important;

  }



  .mitushi-judgeme-all-reviews .jdgm-rev-widg__header,

  .mitushi-judgeme-all-reviews .jdgm-all-reviews-page__header {

    display: flex !important;

    flex-wrap: wrap !important;

    align-items: center !important;

    justify-content: space-between !important;

    gap: 24px !important;

    margin-bottom: 28px !important;

    padding-bottom: 24px !important;

    border-bottom: 1px solid var(--jdgm-border) !important;

  }



  .mitushi-judgeme-all-reviews .jdgm-rev-widg__summary-average {

    font-size: 42px !important;

    font-weight: 800 !important;

    color: #fff !important;

    font-family: var(--font-display), inherit !important;

  }



  .mitushi-judgeme-all-reviews .jdgm-histogram {

    display: flex !important;

    flex-direction: column !important;

    gap: 8px !important;

    min-width: 240px !important;

    flex: 1 1 240px !important;

    margin: 0 !important;

    padding: 0 !important;

    list-style: none !important;

  }



  .mitushi-judgeme-all-reviews .jdgm-histogram__row {

    display: flex !important;

    align-items: center !important;

    gap: 10px !important;

    width: 100% !important;

  }



  .mitushi-judgeme-all-reviews .jdgm-histogram__bar {

    flex: 1 1 auto !important;

    height: 8px !important;

    border-radius: 999px !important;

    background: rgba(255, 255, 255, 0.1) !important;

    overflow: hidden !important;

    min-width: 80px !important;

  }



  .mitushi-judgeme-all-reviews .jdgm-histogram__bar-content {

    display: block !important;

    height: 100% !important;

    border-radius: 999px !important;

    background: linear-gradient(90deg, #cc132a, #ffb82d) !important;

  }



  .mitushi-judgeme-all-reviews .jdgm-histogram__percentage,

  .mitushi-judgeme-all-reviews .jdgm-histogram__frequency,

  .mitushi-judgeme-all-reviews .jdgm-histogram__star {

    color: var(--jdgm-muted) !important;

    font-size: 12px !important;

    white-space: nowrap !important;

  }



  .mitushi-judgeme-all-reviews .jdgm-rev {

    background: var(--jdgm-surface) !important;

    border: 1px solid var(--jdgm-border) !important;

    border-radius: 10px !important;

    padding: 20px 24px !important;

    margin-bottom: 16px !important;

  }



  .mitushi-judgeme-all-reviews .jdgm-rev__author {

    color: #fff !important;

    font-weight: 700 !important;

    font-size: 13px !important;

    letter-spacing: 0.06em !important;

    text-transform: uppercase !important;

  }



  .mitushi-judgeme-all-reviews .jdgm-rev__body,

  .mitushi-judgeme-all-reviews .jdgm-rev__content {

    color: var(--jdgm-muted) !important;

    line-height: 1.75 !important;

    font-size: 14px !important;

  }



  .mitushi-judgeme-all-reviews .jdgm-btn {

    background: var(--jdgm-accent) !important;

    border: none !important;

    border-radius: 6px !important;

    color: #fff !important;

  }



  .mitushi-product-rating .jdgm-preview-badge {

    display: inline-flex !important;

    align-items: center !important;

    gap: 8px !important;

  }



  @media (max-width: 768px) {

    .mitushi-judgeme-all-reviews .jdgm-rev-widg__header,

    .mitushi-judgeme-all-reviews .jdgm-all-reviews-page__header {

      flex-direction: column !important;

      align-items: flex-start !important;

    }



    .mitushi-judgeme-all-reviews .jdgm-histogram {

      width: 100% !important;

    }

  }

</style>

