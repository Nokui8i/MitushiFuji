{% comment %}
  ANIQI-style demo reviews grid — preview until real Judge.me reviews arrive.
{% endcomment %}

{%- liquid
  assign demo_products = collections.all.products
  assign demo_count = section.settings.demo_review_count | default: 8
-%}

<style>
  .mitushi-reviews-demo {
    width: 100%;
  }

  .mitushi-reviews-demo__toolbar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    margin-bottom: 20px;
    padding-bottom: 16px;
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
  }

  .mitushi-reviews-demo__summary {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 10px 14px;
    font-size: 14px;
    color: rgba(255, 255, 255, 0.88);
  }

  .mitushi-reviews-demo__stars {
    color: #cc132a;
    letter-spacing: 2px;
    font-size: 15px;
    line-height: 1;
  }

  .mitushi-reviews-demo__count {
    font-weight: 600;
    letter-spacing: 0.02em;
  }

  .mitushi-reviews-demo__badge {
    display: inline-flex;
    align-items: center;
    padding: 4px 10px;
    border-radius: 999px;
    background: rgba(204, 19, 42, 0.18);
    border: 1px solid rgba(204, 19, 42, 0.45);
    color: #ff8a9a;
    font-size: 9px;
    font-weight: 700;
    letter-spacing: 0.22em;
    text-transform: uppercase;
  }

  .mitushi-reviews-demo__filter {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    border-radius: 8px;
    border: 1px solid rgba(255, 255, 255, 0.1);
    background: rgba(255, 255, 255, 0.03);
    color: rgba(255, 255, 255, 0.55);
    cursor: default;
    pointer-events: none;
  }

  .mitushi-reviews-demo__grid {
    column-count: 4;
    column-gap: 12px;
  }

  .mitushi-reviews-demo__card {
    break-inside: avoid;
    margin-bottom: 12px;
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.07);
    border-radius: 6px;
    overflow: hidden;
    transition: border-color 0.25s ease, transform 0.25s ease;
  }

  .mitushi-reviews-demo__card:hover {
    border-color: rgba(204, 19, 42, 0.35);
    transform: translateY(-2px);
  }

  .mitushi-reviews-demo__media {
    position: relative;
    display: block;
    width: 100%;
    overflow: hidden;
    background: #1a1a1c;
  }

  .mitushi-reviews-demo__media--tall { aspect-ratio: 3 / 4; }
  .mitushi-reviews-demo__media--wide { aspect-ratio: 4 / 3; }
  .mitushi-reviews-demo__media--square { aspect-ratio: 1 / 1; }

  .mitushi-reviews-demo__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .mitushi-reviews-demo__media-placeholder {
    width: 100%;
    height: 100%;
    background: linear-gradient(145deg, #3a3a3f 0%, #222225 55%, #cc132a22 100%);
  }

  .mitushi-reviews-demo__multi {
    position: absolute;
    top: 10px;
    right: 10px;
    padding: 4px 8px;
    border-radius: 6px;
    background: rgba(0, 0, 0, 0.55);
    color: #fff;
    font-size: 11px;
    font-weight: 600;
    backdrop-filter: blur(8px);
  }

  .mitushi-reviews-demo__body {
    padding: 14px 14px 12px;
  }

  .mitushi-reviews-demo__meta {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 6px 10px;
    margin-bottom: 8px;
  }

  .mitushi-reviews-demo__author {
    font-size: 13px;
    font-weight: 600;
    color: #fff;
  }

  .mitushi-reviews-demo__verified {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    font-size: 10px;
    color: rgba(255, 255, 255, 0.45);
    letter-spacing: 0.04em;
  }

  .mitushi-reviews-demo__verified svg {
    width: 12px;
    height: 12px;
    color: #cc132a;
  }

  .mitushi-reviews-demo__date {
    width: 100%;
    font-size: 11px;
    color: rgba(255, 255, 255, 0.32);
  }

  .mitushi-reviews-demo__rating {
    color: #cc132a;
    font-size: 12px;
    letter-spacing: 1px;
    margin-bottom: 8px;
  }

  .mitushi-reviews-demo__text {
    margin: 0;
    font-size: 13px;
    line-height: 1.65;
    color: rgba(255, 255, 255, 0.62);
  }

  .mitushi-reviews-demo__product {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-top: 14px;
    padding-top: 12px;
    border-top: 1px solid rgba(255, 255, 255, 0.06);
    text-decoration: none;
    color: inherit;
  }

  .mitushi-reviews-demo__product:hover .mitushi-reviews-demo__product-title {
    color: #cc132a;
  }

  .mitushi-reviews-demo__product-thumb {
    flex: 0 0 40px;
    width: 40px;
    height: 40px;
    border-radius: 4px;
    overflow: hidden;
    background: #1a1a1c;
    border: 1px solid rgba(255, 255, 255, 0.08);
  }

  .mitushi-reviews-demo__product-thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .mitushi-reviews-demo__product-title {
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.78);
    line-height: 1.4;
    transition: color 0.2s ease;
  }

  .mitushi-reviews-demo__note {
    margin: 20px 0 0;
    text-align: center;
    font-size: 11px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.35);
  }

  @media (max-width: 1100px) {
    .mitushi-reviews-demo__grid { column-count: 3; }
  }

  @media (max-width: 768px) {
    .mitushi-reviews-demo__grid { column-count: 2; column-gap: 10px; }
    .mitushi-reviews-demo__toolbar { margin-bottom: 16px; }
  }

  @media (max-width: 480px) {
    .mitushi-reviews-demo__grid { column-count: 1; }
  }
</style>

{%- assign demo_reviews = 'Sarah M.|Quality is insane. The print is sharp and the fabric feels premium.|tall|+2|12.02.2026,Jake R.|Best anime streetwear hoodie I have ever owned. Fits true to size.|wide||28.01.2026,Maya K.|Shipping was fast and the details are crazy good in person.|square||15.01.2026,Daniel T.|Wore it to a con and got so many compliments. 10/10.|tall||03.01.2026,Emily L.|Heavyweight feel without being stiff. Exactly what I wanted.|wide|+1|22.12.2025,Noah P.|Colors pop even better than the photos on the site.|square||10.12.2025,Ava S.|Customer service was great and the piece feels luxury.|tall||28.11.2025,Leo M.|The cut is perfect and the material feels expensive.|square|+3|14.11.2025' | split: ',' -%}

<div class="mitushi-reviews-demo" aria-label="Demo reviews preview">
  <div class="mitushi-reviews-demo__toolbar">
    <div class="mitushi-reviews-demo__summary">
      <span class="mitushi-reviews-demo__stars" aria-hidden="true">★★★★★</span>
      <span class="mitushi-reviews-demo__count">{{ demo_count }} Reviews</span>
      <span class="mitushi-reviews-demo__badge">Demo preview</span>
    </div>
    <span class="mitushi-reviews-demo__filter" aria-hidden="true">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M4 6h16M7 12h10M10 18h4"/>
      </svg>
    </span>
  </div>

  <div class="mitushi-reviews-demo__grid">
    {%- for demo_entry in demo_reviews limit: demo_count -%}
      {%- assign parts = demo_entry | split: '|' -%}
      {%- assign author = parts[0] -%}
      {%- assign body = parts[1] -%}
      {%- assign ratio = parts[2] | default: 'square' -%}
      {%- assign multi = parts[3] -%}
      {%- assign review_date = parts[4] | default: '01.01.2026' -%}
      {%- assign product = demo_products[forloop.index0] -%}
      {%- assign product_url = product.url | default: routes.all_products_collection_url -%}
      {%- assign product_title = product.title | default: 'Mitushi Streetwear' -%}

      <article class="mitushi-reviews-demo__card">
        <div class="mitushi-reviews-demo__media mitushi-reviews-demo__media--{{ ratio }}">
          {%- if product.featured_image != blank -%}
            {{
              product.featured_image
              | image_url: width: 800
              | image_tag:
                loading: 'lazy',
                alt: product_title,
                widths: '400,600,800',
                sizes: '(min-width: 1100px) 25vw, (min-width: 768px) 33vw, 50vw'
            }}
          {%- else -%}
            <div class="mitushi-reviews-demo__media-placeholder" role="img" aria-label="Product preview"></div>
          {%- endif -%}
          {%- if multi != blank -%}
            <span class="mitushi-reviews-demo__multi">{{ multi }}</span>
          {%- endif -%}
        </div>

        <div class="mitushi-reviews-demo__body">
          <div class="mitushi-reviews-demo__meta">
            <span class="mitushi-reviews-demo__author">{{ author }}</span>
            <span class="mitushi-reviews-demo__verified">
              <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M9 12.75 11.25 15 15 9.75M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z"/>
              </svg>
              Verified
            </span>
            <span class="mitushi-reviews-demo__date">{{ review_date }}</span>
          </div>
          <div class="mitushi-reviews-demo__rating" aria-label="5 out of 5 stars">★★★★★</div>
          <p class="mitushi-reviews-demo__text">{{ body }}</p>

          <a class="mitushi-reviews-demo__product" href="{{ product_url }}">
            <span class="mitushi-reviews-demo__product-thumb">
              {%- if product.featured_image != blank -%}
                {{ product.featured_image | image_url: width: 80 | image_tag: loading: 'lazy', alt: product_title }}
              {%- endif -%}
            </span>
            <span class="mitushi-reviews-demo__product-title">{{ product_title }}</span>
          </a>
        </div>
      </article>
    {%- endfor -%}
  </div>

  <p class="mitushi-reviews-demo__note">
    Demo only — real reviews appear here after customers respond to Judge.me emails
  </p>
</div>
