{% comment %}
  Mitushi Instagram / Apps section — hero-style backdrop + header only.
  Instafeed controls tile layout; we do not override app markup.
{% endcomment %}
<style>
  #shopify-section-{{ section.id }} .mitushi-apps-section {
    position: relative;
    overflow: hidden;
    background-color: var(--ink, #0f0f10);
    border-top: 1px solid rgba(255, 255, 255, 0.08);
    padding-top: {{ section.settings.padding_top | default: 80 }}px;
    padding-bottom: {{ section.settings.padding_bottom | default: 80 }}px;
    color: var(--bone, #f7f7f8);
  }

  #shopify-section-{{ section.id }} .mitushi-apps-backdrop {
    position: absolute;
    inset: 0;
    background: radial-gradient(55% 70% at 75% 35%, rgba(204, 19, 42, 0.2) 0%, transparent 68%);
    pointer-events: none;
  }

  #shopify-section-{{ section.id }} .mitushi-apps-grid {
    position: absolute;
    inset: 0;
    opacity: 0.07;
    background-image:
      linear-gradient(var(--bone, #f4f4f4) 1px, transparent 1px),
      linear-gradient(90deg, var(--bone, #f4f4f4) 1px, transparent 1px);
    background-size: 80px 80px;
    mask-image: radial-gradient(ellipse 90% 80% at 50% 40%, black 25%, transparent 78%);
    -webkit-mask-image: radial-gradient(ellipse 90% 80% at 50% 40%, black 25%, transparent 78%);
    pointer-events: none;
  }

  #shopify-section-{{ section.id }} .mitushi-apps-ghost {
    pointer-events: none;
    position: absolute;
    left: 50%;
    top: 42%;
    transform: translate(-50%, -50%);
    z-index: 0;
    font-family: var(--font-display, inherit);
    font-size: clamp(6rem, 18vw, 14rem);
    line-height: 1;
    color: transparent;
    -webkit-text-stroke: 1px rgba(244, 244, 244, 0.12);
    opacity: 0.35;
    user-select: none;
    white-space: nowrap;
  }

  #shopify-section-{{ section.id }} .mitushi-apps-vertical-jp {
    pointer-events: none;
    position: absolute;
    left: 20px;
    top: 50%;
    transform: translateY(-50%);
    z-index: 1;
    font-family: var(--font-jp, inherit);
    font-size: 10px;
    letter-spacing: 0.85em;
    color: rgba(244, 244, 244, 0.35);
    writing-mode: vertical-rl;
    text-orientation: mixed;
    display: none;
  }

  @media (min-width: 1024px) {
    #shopify-section-{{ section.id }} .mitushi-apps-vertical-jp {
      display: block;
    }
  }

  #shopify-section-{{ section.id }} .mitushi-apps-container {
    position: relative;
    z-index: 2;
    margin: 0 auto;
    max-width: 1360px;
    padding: 0 24px;
  }

  @media (min-width: 1024px) {
    #shopify-section-{{ section.id }} .mitushi-apps-container {
      padding-left: 48px;
      padding-right: 48px;
    }
  }

  #shopify-section-{{ section.id }} .mitushi-apps-header {
    display: flex;
    flex-wrap: wrap;
    align-items: flex-end;
    justify-content: space-between;
    gap: 24px 20px;
    margin-bottom: 40px;
    padding-bottom: 28px;
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
  }

  #shopify-section-{{ section.id }} .mitushi-apps-eyebrow {
    margin: 0 0 14px;
    font-size: 10px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.5em;
    color: #cc132a;
  }

  #shopify-section-{{ section.id }} .mitushi-apps-heading {
    margin: 0;
    font-family: var(--font-display, inherit);
    font-size: clamp(2rem, 6vw, 3.5rem);
    font-weight: 700;
    letter-spacing: 0.04em;
    line-height: 0.95;
    text-transform: uppercase;
    color: #f7f7f8;
  }

  /* Primary CTA — matches hero "Shop the Drop" */
  #shopify-section-{{ section.id }} .mitushi-apps-instagram-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 12px;
    flex-shrink: 0;
    min-height: 48px;
    padding: 16px 28px;
    font-size: 11px;
    font-weight: 700;
    line-height: 1;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    text-decoration: none;
    color: var(--bone, #f7f7f8);
    background-color: var(--crimson, #cc132a);
    border: 1px solid var(--crimson, #cc132a);
    box-shadow: 0 4px 24px rgba(204, 19, 42, 0.35);
    transition: background-color 0.3s ease, border-color 0.3s ease, box-shadow 0.3s ease, transform 0.3s ease;
  }

  #shopify-section-{{ section.id }} .mitushi-apps-instagram-link__arrow {
    display: inline-block;
    font-size: 14px;
    line-height: 1;
    letter-spacing: 0;
    transition: transform 0.3s ease;
  }

  #shopify-section-{{ section.id }} .mitushi-apps-instagram-link:hover {
    background-color: #e0152f;
    border-color: #e0152f;
    box-shadow: 0 0 32px rgba(204, 19, 42, 0.65);
    transform: translateY(-1px);
  }

  #shopify-section-{{ section.id }} .mitushi-apps-instagram-link:hover .mitushi-apps-instagram-link__arrow {
    transform: translateX(4px);
  }

  #shopify-section-{{ section.id }} .mitushi-apps-instagram-link:active {
    transform: translateY(0);
    box-shadow: 0 2px 16px rgba(204, 19, 42, 0.45);
  }

  #shopify-section-{{ section.id }} .mitushi-apps-instagram-link--outline {
    color: #f7f7f8;
    background: rgba(15, 15, 16, 0.65);
    border-color: rgba(255, 255, 255, 0.28);
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.35);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
  }

  #shopify-section-{{ section.id }} .mitushi-apps-instagram-link--outline:hover {
    background: rgba(204, 19, 42, 0.15);
    border-color: #cc132a;
    box-shadow: 0 0 28px rgba(204, 19, 42, 0.4);
  }

  #shopify-section-{{ section.id }} .mitushi-apps-feed-wrap {
    position: relative;
    z-index: 2;
    padding-top: 8px;
  }

  #shopify-section-{{ section.id }} .mitushi-apps-feed {
    width: 100%;
  }

  #shopify-section-{{ section.id }} .mitushi-apps-feed > * {
    max-width: 100%;
  }

  #shopify-section-{{ section.id }} .mitushi-apps-feed .page-width,
  #shopify-section-{{ section.id }} .mitushi-apps-feed [class*='page-width'] {
    max-width: 100%;
    padding-left: 0;
    padding-right: 0;
  }

  #shopify-section-{{ section.id }} .instafeed-new-layout-container > h2:empty,
  #shopify-section-{{ section.id }} #insta-feed > h2:empty {
    display: none;
  }
</style>
