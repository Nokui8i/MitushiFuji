{% comment %}
  Mitushi Apps section — header + section chrome only.
  Instafeed tile shape, grid, and images are controlled by the Instafeed app.
{% endcomment %}
<style>
  #shopify-section-{{ section.id }} .mitushi-apps-section {
    background-color: var(--ink, #0f0f10);
    border-top: 1px solid rgba(255, 255, 255, 0.1);
    padding-top: {{ section.settings.padding_top | default: 72 }}px;
    padding-bottom: {{ section.settings.padding_bottom | default: 72 }}px;
  }

  #shopify-section-{{ section.id }} .mitushi-apps-container {
    margin: 0 auto;
    max-width: 1360px;
    padding: 0 24px;
  }

  #shopify-section-{{ section.id }} .mitushi-apps-header {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 20px;
    margin-bottom: 36px;
  }

  #shopify-section-{{ section.id }} .mitushi-apps-eyebrow {
    font-size: 10px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.5em;
    color: #cc132a;
    margin-bottom: 12px;
  }

  #shopify-section-{{ section.id }} .mitushi-apps-heading {
    margin: 0;
    font-family: var(--font-display, inherit);
    font-size: 32px;
    font-weight: 700;
    letter-spacing: 0.02em;
    line-height: 1.05;
    color: #f7f7f8;
  }

  @media (min-width: 768px) {
    #shopify-section-{{ section.id }} .mitushi-apps-heading {
      font-size: 48px;
    }
  }

  #shopify-section-{{ section.id }} .mitushi-apps-instagram-link {
    flex-shrink: 0;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.35em;
    text-transform: uppercase;
    text-decoration: none;
    color: rgba(247, 247, 248, 0.65);
    border: 1px solid rgba(255, 255, 255, 0.2);
    padding: 12px 18px;
    transition: border-color 0.2s ease, color 0.2s ease;
  }

  #shopify-section-{{ section.id }} .mitushi-apps-instagram-link:hover {
    border-color: #cc132a;
    color: #cc132a;
  }

  #shopify-section-{{ section.id }} .mitushi-apps-feed {
    width: 100%;
  }

  /* Align feed to section width — do not override Instafeed tiles */
  #shopify-section-{{ section.id }} .mitushi-apps-feed > * {
    max-width: 100%;
  }

  #shopify-section-{{ section.id }} .mitushi-apps-feed .page-width,
  #shopify-section-{{ section.id }} .mitushi-apps-feed [class*='page-width'] {
    max-width: 100%;
    padding-left: 0;
    padding-right: 0;
  }

  #shopify-section-{{ section.id }} .instafeed-new-layout-container > h2:empty,
  #shopify-section-{{ section.id }} #insta-feed > h2:empty {
    display: none;
  }
</style>
