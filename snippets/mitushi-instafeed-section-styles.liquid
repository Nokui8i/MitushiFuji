{% comment %}
  Mitushi Instagram / Apps section — hero-style backdrop + header only.
  Instafeed controls tile layout; we do not override app markup.
{% endcomment %}
<style>
  #shopify-section-{{ section.id }} .mitushi-apps-section {
    position: relative;
    overflow: hidden;
    background-color: var(--ink, #0f0f10);
    border-top: none;
    padding-top: {{ section.settings.padding_top | default: 80 }}px;
    padding-bottom: {{ section.settings.padding_bottom | default: 80 }}px;
    color: var(--bone, #f7f7f8);
  }

  #shopify-section-{{ section.id }} .mitushi-apps-section--instafeed {
    overflow: visible;
  }

  #shopify-section-{{ section.id }} .mitushi-apps-backdrop {
    position: absolute;
    inset: 0;
    background: radial-gradient(55% 70% at 75% 35%, rgba(204, 19, 42, 0.2) 0%, transparent 68%);
    pointer-events: none;
  }

  #shopify-section-{{ section.id }} .mitushi-apps-grid {
    position: absolute;
    inset: 0;
    opacity: 0.07;
    background-image:
      linear-gradient(var(--bone, #f4f4f4) 1px, transparent 1px),
      linear-gradient(90deg, var(--bone, #f4f4f4) 1px, transparent 1px);
    background-size: 80px 80px;
    mask-image: radial-gradient(ellipse 90% 80% at 50% 40%, black 25%, transparent 78%);
    -webkit-mask-image: radial-gradient(ellipse 90% 80% at 50% 40%, black 25%, transparent 78%);
    pointer-events: none;
  }

  #shopify-section-{{ section.id }} .mitushi-apps-ghost {
    pointer-events: none;
    position: absolute;
    left: 50%;
    top: 42%;
    transform: translate(-50%, -50%);
    z-index: 0;
    font-family: var(--font-display, inherit);
    font-size: clamp(6rem, 18vw, 14rem);
    line-height: 1;
    color: transparent;
    -webkit-text-stroke: 1px rgba(244, 244, 244, 0.12);
    opacity: 0.35;
    user-select: none;
    white-space: nowrap;
  }

  #shopify-section-{{ section.id }} .mitushi-apps-vertical-jp {
    pointer-events: none;
    position: absolute;
    left: 20px;
    top: 50%;
    transform: translateY(-50%);
    z-index: 1;
    font-family: var(--font-jp, inherit);
    font-size: 10px;
    letter-spacing: 0.85em;
    color: rgba(244, 244, 244, 0.35);
    writing-mode: vertical-rl;
    text-orientation: mixed;
    display: none;
  }

  @media (min-width: 1024px) {
    #shopify-section-{{ section.id }} .mitushi-apps-vertical-jp {
      display: block;
    }
  }

  #shopify-section-{{ section.id }} .mitushi-apps-container {
    position: relative;
    z-index: 2;
    margin: 0 auto;
    max-width: 1360px;
    padding: 0 24px;
  }

  @media (min-width: 1024px) {
    #shopify-section-{{ section.id }} .mitushi-apps-container {
      padding-left: 48px;
      padding-right: 48px;
    }
  }

  #shopify-section-{{ section.id }} .mitushi-apps-header {
    margin-bottom: 40px;
    padding-bottom: 0;
    border-bottom: none;
  }

  #shopify-section-{{ section.id }} .mitushi-apps-header-row {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 16px 12px;
  }

  #shopify-section-{{ section.id }} .mitushi-apps-eyebrow {
    margin: 0 0 12px;
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: none;
    color: rgba(247, 247, 248, 0.55);
  }

  #shopify-section-{{ section.id }} .mitushi-apps-eyebrow::first-letter {
    text-transform: uppercase;
  }

  #shopify-section-{{ section.id }} .mitushi-apps-header--instafeed {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 20px;
    text-align: start;
  }

  #shopify-section-{{ section.id }} .mitushi-apps-title-group {
    flex: 1;
    min-width: 0;
    text-align: start;
  }

  #shopify-section-{{ section.id }} .mitushi-apps-eyebrow--crimson {
    margin: 0 0 10px;
    font-size: 10px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.5em;
    color: #cc132a !important;
  }

  #shopify-section-{{ section.id }} .mitushi-apps-header--instafeed .mitushi-apps-eyebrow--crimson {
    color: #cc132a !important;
  }

  #shopify-section-{{ section.id }} .mitushi-apps-header--instafeed .mitushi-apps-heading {
    flex: none;
    text-align: start;
  }

  #shopify-section-{{ section.id }} .mitushi-apps-header--instafeed .mitushi-ig-cta {
    position: relative;
    z-index: 3;
    visibility: visible;
    opacity: 1;
  }

  #shopify-section-{{ section.id }} .mitushi-apps-heading {
    margin: 0;
    flex: 1;
    min-width: 0;
    font-family: var(--font-display, inherit);
    font-size: clamp(2rem, 6vw, 3.5rem);
    font-weight: 700;
    letter-spacing: 0.04em;
    line-height: 0.95;
    text-transform: uppercase;
    color: #f7f7f8;
  }

  #shopify-section-{{ section.id }} .mitushi-ig-cta__label-mobile {
    display: none;
  }

  @media (max-width: 767px) {
    #shopify-section-{{ section.id }} .mitushi-apps-section {
      padding-top: 56px;
      padding-bottom: 56px;
    }

    #shopify-section-{{ section.id }} .mitushi-apps-container {
      padding-left: 20px;
      padding-right: 20px;
    }

    #shopify-section-{{ section.id }} .mitushi-apps-header {
      margin-bottom: 28px;
      padding-bottom: 0;
    }

    #shopify-section-{{ section.id }} .mitushi-apps-header--instafeed {
      flex-wrap: wrap;
      align-items: flex-end;
      gap: 16px 12px;
    }

    #shopify-section-{{ section.id }} .mitushi-apps-header--instafeed .mitushi-ig-cta {
      margin-inline-start: auto;
    }

    #shopify-section-{{ section.id }} .mitushi-apps-eyebrow {
      margin-bottom: 8px;
      font-size: 10px;
      letter-spacing: 0.08em;
    }

    #shopify-section-{{ section.id }} .mitushi-apps-header-row {
      align-items: center;
      gap: 10px;
    }

    #shopify-section-{{ section.id }} .mitushi-apps-heading {
      font-size: clamp(1.35rem, 7vw, 1.75rem);
      letter-spacing: 0.03em;
    }

    #shopify-section-{{ section.id }} .mitushi-ig-cta__label-desktop {
      display: none;
    }

    #shopify-section-{{ section.id }} .mitushi-ig-cta__label-mobile {
      display: inline;
    }

    #shopify-section-{{ section.id }} .mitushi-ig-cta--split {
      min-height: 30px;
      height: 30px;
      box-shadow: 0 4px 14px rgba(0, 0, 0, 0.22);
    }

    #shopify-section-{{ section.id }} .mitushi-ig-cta--split .mitushi-ig-cta__label {
      padding: 0 10px;
      font-size: 8px;
      letter-spacing: 0.18em;
    }

    #shopify-section-{{ section.id }} .mitushi-ig-cta--split .mitushi-ig-cta__icon {
      width: 30px;
      border: none;
    }

    #shopify-section-{{ section.id }} .mitushi-ig-cta--split .mitushi-ig-cta__ig {
      width: 14px;
      height: 14px;
    }

    #shopify-section-{{ section.id }} .mitushi-ig-cta--solid {
      min-height: 40px;
      padding: 12px 14px;
      font-size: 9px;
      letter-spacing: 0.2em;
      gap: 8px;
    }

    #shopify-section-{{ section.id }} .mitushi-ig-cta--minimal {
      font-size: 9px;
      letter-spacing: 0.22em;
      padding: 4px 0;
      white-space: nowrap;
    }

    #shopify-section-{{ section.id }} .mitushi-apps-ghost {
      font-size: clamp(4rem, 22vw, 7rem);
      top: 38%;
    }
  }

  /* Instagram CTA — split / solid / minimal */
  #shopify-section-{{ section.id }} .mitushi-ig-cta {
    flex-shrink: 0;
    text-decoration: none;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  /* Split panel: glass label + crimson icon block */
  #shopify-section-{{ section.id }} .mitushi-ig-cta--split {
    display: inline-flex;
    align-items: stretch;
    min-height: 44px;
    height: 44px;
    overflow: hidden;
    border: none;
    box-shadow: 0 10px 32px rgba(0, 0, 0, 0.32);
  }

  #shopify-section-{{ section.id }} .mitushi-ig-cta--split .mitushi-ig-cta__label {
    display: inline-flex;
    align-items: center;
    padding: 0 18px;
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.34em;
    text-transform: uppercase;
    color: rgba(247, 247, 248, 0.92);
    background: rgba(12, 12, 13, 0.75);
    border: none;
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    transition: background 0.3s ease, color 0.3s ease;
  }

  #shopify-section-{{ section.id }} .mitushi-ig-cta--split .mitushi-ig-cta__icon {
    display: grid;
    place-items: center;
    width: 44px;
    flex-shrink: 0;
    background: linear-gradient(145deg, #d91630 0%, #a80f24 100%);
    border: none;
    color: #f7f7f8;
    transition: background 0.3s ease, box-shadow 0.3s ease;
  }

  #shopify-section-{{ section.id }} .mitushi-ig-cta--split:hover {
    transform: translateY(-2px);
    box-shadow: 0 16px 48px rgba(0, 0, 0, 0.45);
  }

  #shopify-section-{{ section.id }} .mitushi-ig-cta--split:hover .mitushi-ig-cta__label {
    background: rgba(204, 19, 42, 0.12);
    color: #f7f7f8;
  }

  #shopify-section-{{ section.id }} .mitushi-ig-cta--split:hover .mitushi-ig-cta__icon {
    background: linear-gradient(145deg, #ff1a3a 0%, #cc132a 100%);
    box-shadow: inset 0 0 24px rgba(255, 255, 255, 0.12);
  }

  #shopify-section-{{ section.id }} .mitushi-ig-cta--split .mitushi-ig-cta__ig {
    display: block;
  }

  /* Solid — hero-style block */
  #shopify-section-{{ section.id }} .mitushi-ig-cta--solid {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    min-height: 48px;
    padding: 16px 28px;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: #f7f7f8;
    background: #cc132a;
    border: 1px solid #cc132a;
    box-shadow: 0 4px 24px rgba(204, 19, 42, 0.35);
  }

  #shopify-section-{{ section.id }} .mitushi-ig-cta--solid .mitushi-ig-cta__label {
    letter-spacing: inherit;
  }

  #shopify-section-{{ section.id }} .mitushi-ig-cta--solid .mitushi-ig-cta__icon {
    display: inline-flex;
  }

  #shopify-section-{{ section.id }} .mitushi-ig-cta--solid .mitushi-ig-cta__arrow {
    font-size: 14px;
    letter-spacing: 0;
    transition: transform 0.3s ease;
  }

  #shopify-section-{{ section.id }} .mitushi-ig-cta--solid:hover {
    box-shadow: 0 0 32px rgba(204, 19, 42, 0.65);
    transform: translateY(-1px);
  }

  #shopify-section-{{ section.id }} .mitushi-ig-cta--solid:hover .mitushi-ig-cta__arrow {
    transform: translateX(4px);
  }

  /* Minimal editorial link */
  #shopify-section-{{ section.id }} .mitushi-ig-cta--minimal {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 8px 0;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: rgba(247, 247, 248, 0.85);
    border-bottom: 2px solid rgba(204, 19, 42, 0.85);
  }

  #shopify-section-{{ section.id }} .mitushi-ig-cta--minimal .mitushi-ig-cta__icon {
    display: inline-flex;
    color: #cc132a;
  }

  #shopify-section-{{ section.id }} .mitushi-ig-cta--minimal .mitushi-ig-cta__arrow {
    font-size: 16px;
    transition: transform 0.3s ease;
  }

  #shopify-section-{{ section.id }} .mitushi-ig-cta--minimal:hover {
    color: #f7f7f8;
    border-bottom-color: #ff1a3a;
  }

  #shopify-section-{{ section.id }} .mitushi-ig-cta--minimal:hover .mitushi-ig-cta__arrow {
    transform: translate(4px, -2px);
  }

  #shopify-section-{{ section.id }} .mitushi-apps-section-wrap,
  #shopify-section-{{ section.id }} .mitushi-apps-section-wrap.section {
    border-top: none !important;
    border-bottom: none !important;
  }

  #shopify-section-{{ section.id }} .mitushi-apps-section--instafeed {
    overflow: visible;
  }

  #shopify-section-{{ section.id }} .mitushi-apps-feed-wrap {
    position: relative;
    z-index: 2;
    padding-top: 0;
    overflow: visible;
  }

  #shopify-section-{{ section.id }} .mitushi-apps-feed {
    width: 100%;
    overflow: visible;
    min-height: 1px;
  }

  #shopify-section-{{ section.id }} #insta-feed,
  #shopify-section-{{ section.id }} .instafeed-new-layout-container,
  #shopify-section-{{ section.id }} [id^="feed-"] {
    width: 100%;
    position: relative;
    z-index: 2;
  }

  #shopify-section-{{ section.id }} .mitushi-apps-feed > * {
    max-width: 100%;
  }

  #shopify-section-{{ section.id }} .mitushi-apps-feed .page-width,
  #shopify-section-{{ section.id }} .mitushi-apps-feed [class*='page-width'] {
    max-width: 100%;
    padding-left: 0;
    padding-right: 0;
  }

  #shopify-section-{{ section.id }} .instafeed-new-layout-container > h2:empty,
  #shopify-section-{{ section.id }} #insta-feed > h2:empty {
    display: none;
  }

  /* Centered header — reviews and other non-Instafeed app sections */
  #shopify-section-{{ section.id }} .mitushi-apps-header--centered {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }

  #shopify-section-{{ section.id }} .mitushi-apps-header--centered .mitushi-apps-eyebrow {
    text-align: center;
    width: 100%;
  }

  #shopify-section-{{ section.id }} .mitushi-apps-header--centered .mitushi-apps-header-row {
    justify-content: center !important;
    align-items: center !important;
    width: 100%;
  }

  #shopify-section-{{ section.id }} .mitushi-apps-header--centered .mitushi-apps-heading {
    flex: none !important;
    width: 100%;
    text-align: center !important;
    margin-inline: auto;
  }

  /* Centered layout must not apply to Instafeed */
  #shopify-section-{{ section.id }} .mitushi-apps-header--instafeed.mitushi-apps-header--centered,
  #shopify-section-{{ section.id }} .mitushi-apps-header--instafeed {
    display: flex !important;
    flex-direction: row !important;
    align-items: flex-end !important;
    text-align: start !important;
  }

  #shopify-section-{{ section.id }} .mitushi-apps-header--instafeed.mitushi-apps-header--centered .mitushi-apps-eyebrow,
  #shopify-section-{{ section.id }} .mitushi-apps-header--instafeed .mitushi-apps-eyebrow--crimson {
    text-align: start !important;
    color: #cc132a !important;
  }
</style>
