{% comment %}
  Mitushi styling for Apps sections (Instafeed) — scoped to section.id.
{% endcomment %}
<style>
  #shopify-section-{{ section.id }} .mitushi-apps-section {
    background-color: var(--ink, #0f0f10);
    border-top: 1px solid rgba(255, 255, 255, 0.1);
    padding-top: {{ section.settings.padding_top | default: 72 }}px;
    padding-bottom: {{ section.settings.padding_bottom | default: 72 }}px;
  }

  #shopify-section-{{ section.id }} .mitushi-apps-container {
    margin: 0 auto;
    max-width: 1360px;
    padding: 0 24px;
  }

  #shopify-section-{{ section.id }} .mitushi-apps-header {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 20px;
    margin-bottom: 36px;
  }

  #shopify-section-{{ section.id }} .mitushi-apps-eyebrow {
    font-size: 10px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.5em;
    color: #cc132a;
    margin-bottom: 12px;
  }

  #shopify-section-{{ section.id }} .mitushi-apps-heading {
    margin: 0;
    font-family: var(--font-display, inherit);
    font-size: 32px;
    font-weight: 700;
    letter-spacing: 0.02em;
    line-height: 1.05;
    color: #f7f7f8;
  }

  @media (min-width: 768px) {
    #shopify-section-{{ section.id }} .mitushi-apps-heading {
      font-size: 48px;
    }
  }

  #shopify-section-{{ section.id }} .mitushi-apps-instagram-link {
    flex-shrink: 0;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.35em;
    text-transform: uppercase;
    text-decoration: none;
    color: rgba(247, 247, 248, 0.65);
    border: 1px solid rgba(255, 255, 255, 0.2);
    padding: 12px 18px;
    transition: border-color 0.2s ease, color 0.2s ease;
  }

  #shopify-section-{{ section.id }} .mitushi-apps-instagram-link:hover {
    border-color: #cc132a;
    color: #cc132a;
  }

  #shopify-section-{{ section.id }} .mitushi-apps-feed {
    width: 100%;
  }

  /* Instafeed app layout */
  #shopify-section-{{ section.id }} #insta-feed,
  #shopify-section-{{ section.id }} .instafeed-shopify {
    width: 100% !important;
    max-width: 100% !important;
    margin: 0 !important;
    padding: 0 !important;
  }

  #shopify-section-{{ section.id }} .instafeed-new-layout-container,
  #shopify-section-{{ section.id }} .instafeed-new-layout-wrapper {
    width: 100% !important;
    max-width: 100% !important;
    margin: 0 !important;
    padding: 0 !important;
  }

  #shopify-section-{{ section.id }} .instafeed-new-layout-wrapper {
    display: grid !important;
    gap: {{ section.settings.grid_gap | default: 12 }}px !important;
    grid-template-columns: repeat({{ section.settings.columns_mobile | default: 2 }}, minmax(0, 1fr)) !important;
  }

  @media (min-width: 768px) {
    #shopify-section-{{ section.id }} .instafeed-new-layout-wrapper {
      grid-template-columns: repeat({{ section.settings.columns_desktop | default: 3 }}, minmax(0, 1fr)) !important;
    }
  }

  #shopify-section-{{ section.id }} .instafeed-new-layout-item {
    width: 100% !important;
    margin: 0 !important;
    overflow: hidden;
    border-radius: {{ section.settings.image_radius | default: 4 }}px;
    background: #1a1a1c;
  }

  #shopify-section-{{ section.id }} .instafeed-new-layout-item img,
  #shopify-section-{{ section.id }} #insta-feed img {
    display: block;
    width: 100% !important;
    height: 100% !important;
    object-fit: cover !important;
    aspect-ratio: 1 / 1;
  }

  /* Hide empty Instafeed title when theme header is used */
  #shopify-section-{{ section.id }} .instafeed-new-layout-container > h2:empty,
  #shopify-section-{{ section.id }} #insta-feed > h2:empty {
    display: none !important;
  }

  #shopify-section-{{ section.id }} .page-width:has(#insta-feed),
  #shopify-section-{{ section.id }} [class*="page-width"]:has(#insta-feed) {
    max-width: 100% !important;
    padding: 0 !important;
  }
</style>
