{% render 'mitushi-carousel-styles' %}

{%- liquid
  assign source_collection = section.settings.collection
  if source_collection == blank
    assign source_collection = collections.all
  endif

  assign has_product_blocks = false
  for block in section.blocks
    if block.settings.product_handle != blank
      assign has_product_blocks = true
      break
    endif
  endfor
-%}

<section class="mitushi-product-carousel" id="products">
  <div class="mitushi-carousel-container">
    <div class="mitushi-carousel-header">
      <div class="mitushi-carousel-title-group">
        <div>{{ section.settings.subheading | default: '/ 02 — Latest drop' }}</div>
        <h2>{{ section.settings.heading | default: 'Featured pieces' }}</h2>
      </div>
      <div class="mitushi-carousel-controls">
        <button type="button" class="mitushi-carousel-btn" aria-label="Previous" onclick="scrollCarousel(-1)">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16">
            <path d="M15 19l-7-7 7-7"></path>
          </svg>
        </button>
        <button type="button" class="mitushi-carousel-btn" aria-label="Next" onclick="scrollCarousel(1)">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16">
            <path d="M9 5l7 7-7 7"></path>
          </svg>
        </button>
      </div>
    </div>
    <div class="mitushi-carousel-track" id="carouselTrack">
      {%- if has_product_blocks -%}
        {%- for block in section.blocks -%}
          {%- assign prod_obj = block.settings.product_handle -%}
          {%- if prod_obj == blank -%}
            {%- continue -%}
          {%- endif -%}
          {%- render 'mitushi-carousel-product-card',
            prod_obj: prod_obj,
            block: block,
            index_mod: forloop.index
          -%}
        {%- endfor -%}
      {%- else -%}
        {%- for prod_obj in source_collection.products limit: section.settings.products_to_show -%}
          {%- render 'mitushi-carousel-product-card',
            prod_obj: prod_obj,
            block: nil,
            index_mod: forloop.index
          -%}
        {%- endfor -%}
      {%- endif -%}
    </div>
  </div>
</section>

<script>
  function scrollCarousel(direction) {
    const track = document.getElementById('carouselTrack');
    if (!track) return;
    const card = track.querySelector('.mitushi-product-card');
    const gap = 12;
    const amount = card ? card.offsetWidth + gap : 300;
    track.scrollBy({ left: direction * amount, behavior: 'smooth' });
  }
</script>

{% schema %}
{
  "name": "Product Carousel",
  "settings": [
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "/ 02 — Latest drop"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Featured pieces"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection (Shopify)",
      "info": "Products are loaded from this collection. Leave empty to use all products."
    },
    {
      "type": "range",
      "id": "products_to_show",
      "label": "Products to show",
      "min": 2,
      "max": 12,
      "step": 1,
      "default": 8
    }
  ],
  "blocks": [
    {
      "type": "product",
      "name": "Product (manual override)",
      "settings": [
        {
          "type": "product",
          "id": "product_handle",
          "label": "Select Product"
        },
        {
          "type": "text",
          "id": "badge",
          "label": "Badge (e.g., New, Hot, Drop 03)"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Product Carousel"
    }
  ]
}
{% endschema %}
