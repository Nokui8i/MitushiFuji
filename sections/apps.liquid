{%- assign has_instafeed_block = false -%}
{%- assign has_reviews_block = false -%}
{%- for block in section.blocks -%}
  {%- assign block_type = block.type | downcase -%}
  {%- assign block_id = block.id | downcase -%}
  {%- if block_type contains 'instafeed' or block_id contains 'instafeed' -%}
    {%- assign has_instafeed_block = true -%}
  {%- endif -%}
  {%- if block_type contains 'loox' or block_type contains 'judge' or block_type contains 'reviews' or block_type contains 'yotpo' or block_type contains 'stamped' or block_id contains 'loox' or block_id contains 'judge' or block_id contains 'reviews' -%}
    {%- assign has_reviews_block = true -%}
  {%- endif -%}
{%- endfor -%}
{%- if has_instafeed_block == false and section.settings.ghost_text == 'FEED' and section.settings.show_instagram_link -%}
  {%- assign has_instafeed_block = true -%}
{%- endif -%}
{%- assign reviews_only = false -%}
{%- if has_reviews_block and has_instafeed_block == false -%}
  {%- assign reviews_only = true -%}
{%- endif -%}

{%- assign use_mitushi_layout = section.settings.enable_mitushi_layout | default: true -%}
{%- assign show_header = section.settings.show_section_header | default: true -%}
{%- assign instagram_url = section.settings.instagram_url | default: settings.social_instagram_link -%}
{%- assign display_subheading = section.settings.subheading -%}
{%- assign display_heading = section.settings.heading -%}
{%- assign display_ghost = section.settings.ghost_text -%}
{%- assign display_vertical_jp = section.settings.vertical_jp -%}
{%- assign show_ig_link = section.settings.show_instagram_link -%}

{%- if reviews_only -%}
  {%- assign show_ig_link = false -%}
  {%- if display_subheading == 'From Instagram' or display_subheading == blank -%}
    {%- assign display_subheading = 'Customer Reviews' -%}
  {%- endif -%}
  {%- if display_heading == 'From Instagram' -%}
    {%- assign display_heading = 'Reviews' -%}
  {%- endif -%}
  {%- if display_ghost == 'FEED' -%}
    {%- assign display_ghost = 'REVIEWS' -%}
  {%- endif -%}
  {%- if display_vertical_jp == 'ミツシ・フィード' -%}
    {%- assign display_vertical_jp = 'レビュー' -%}
  {%- endif -%}
{%- elsif has_instafeed_block == false -%}
  {%- assign show_ig_link = false -%}
{%- endif -%}

{%- if has_instafeed_block -%}
  {%- assign show_ig_link = true -%}
  {%- if instagram_url == blank -%}
    {%- assign instagram_url = settings.social_instagram_link -%}
  {%- endif -%}
  {%- if display_subheading == blank -%}
    {%- assign display_subheading = '/ 03 — インスタグラム' -%}
  {%- endif -%}
  {%- if display_heading == blank -%}
    {%- assign display_heading = 'From Instagram' -%}
  {%- endif -%}
{%- endif -%}

{%- assign center_header = false -%}
{%- unless has_instafeed_block -%}
  {%- assign center_header = true -%}
{%- endunless -%}

{%- if use_mitushi_layout -%}
  {%- render 'mitushi-instafeed-section-styles', section: section -%}
{%- endif -%}

<div
  class="{% unless has_instafeed_block %}o-hidden {% endunless %}section mitushi-apps-section-wrap {{ section.settings.remove_padding_top | replace: 'true', 'section-top-zero' | replace: section.settings.remove_padding_top, '' }} {{ section.settings.remove_padding_bottom | replace: 'true', 'section-bottom-zero' | replace: section.settings.remove_padding_bottom, '' }} color-{{- section.settings.color_scheme -}}"
  data-ui-component="Apps Section"
>
  {%- if use_mitushi_layout -%}
    <div class="mitushi-apps-section w-100{% if has_instafeed_block %} mitushi-apps-section--instafeed{% endif %}{% if reviews_only %} mitushi-apps-section--reviews{% endif %}">
      {%- if section.settings.show_hero_background -%}
        <div class="mitushi-apps-backdrop" aria-hidden="true"></div>
        <div class="mitushi-apps-grid" aria-hidden="true"></div>
        {%- if display_ghost != blank -%}
          <div class="mitushi-apps-ghost" aria-hidden="true">{{ display_ghost }}</div>
        {%- endif -%}
        {%- if display_vertical_jp != blank -%}
          <div class="mitushi-apps-vertical-jp" aria-hidden="true">{{ display_vertical_jp }}</div>
        {%- endif -%}
      {%- endif -%}

      <div class="mitushi-apps-container">
        {%- if show_header -%}
          {%- if display_subheading != blank or display_heading != blank -%}
            <header class="mitushi-apps-header{% if center_header %} mitushi-apps-header--centered{% endif %}{% if has_instafeed_block %} mitushi-apps-header--instafeed{% endif %}">
              {%- if has_instafeed_block -%}
                <div class="mitushi-apps-title-group">
                  {%- if display_subheading != blank -%}
                    <p class="mitushi-apps-eyebrow mitushi-apps-eyebrow--crimson">{{ display_subheading }}</p>
                  {%- endif -%}
                  {%- if display_heading != blank -%}
                    <h2 class="mitushi-apps-heading">{{ display_heading }}</h2>
                  {%- endif -%}
                </div>
                {%- if show_ig_link and instagram_url != blank -%}
                  {%- assign cta_style = section.settings.cta_style | default: 'split' -%}
                  <a
                    class="mitushi-ig-cta mitushi-ig-cta--{{ cta_style }}"
                    href="{{ instagram_url }}"
                    target="_blank"
                    rel="noopener noreferrer"
                  >
                    <span class="mitushi-ig-cta__label" data-label-full="{{ section.settings.instagram_link_label | default: 'Follow on Instagram' | escape }}">
                      <span class="mitushi-ig-cta__label-desktop">{{ section.settings.instagram_link_label | default: 'Follow on Instagram' }}</span>
                      <span class="mitushi-ig-cta__label-mobile">{{ section.settings.instagram_link_label_short | default: 'Follow' }}</span>
                    </span>
                    <span class="mitushi-ig-cta__icon" aria-hidden="true">
                      {%- if cta_style == 'split' -%}
                        <svg class="mitushi-ig-cta__ig" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75">
                          <rect x="3" y="3" width="18" height="18" rx="5"/>
                          <circle cx="12" cy="12" r="4"/>
                          <circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none"/>
                        </svg>
                      {%- else -%}
                        <span class="mitushi-ig-cta__arrow">→</span>
                      {%- endif -%}
                    </span>
                  </a>
                {%- endif -%}
              {%- else -%}
                {%- if display_subheading != blank -%}
                  <p class="mitushi-apps-eyebrow">{{ display_subheading }}</p>
                {%- endif -%}
                <div class="mitushi-apps-header-row">
                  {%- if display_heading != blank -%}
                    <h2 class="mitushi-apps-heading">{{ display_heading }}</h2>
                  {%- endif -%}
                </div>
              {%- endif -%}
            </header>
          {%- endif -%}
        {%- endif -%}

        <div class="mitushi-apps-feed-wrap">
          <div class="mitushi-apps-feed">
            {%- for block in section.blocks -%}
              {% render block %}
            {%- endfor -%}
          </div>
        </div>
      </div>
    </div>
  {%- else -%}
    <div class="{{ section.settings.enable_content_fullwidth | default: 'ctnr' | replace: 'true', '' }} w-100">
      {%- for block in section.blocks -%}
        {% render block %}
      {%- endfor -%}
    </div>
  {%- endif -%}
</div>

{% schema %}
{
  "name": "t:general.apps",
  "settings": [
    {
      "type": "header",
      "content": "t:general.general"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:general.color_scheme",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "Mitushi layout"
    },
    {
      "type": "checkbox",
      "id": "enable_mitushi_layout",
      "label": "Use Mitushi section styling",
      "default": true,
      "info": "Adds headline, spacing, and grid gaps for app blocks. Instagram header and CTA appear only when an Instafeed block is present; reviews apps use Reviews styling automatically."
    },
    {
      "type": "checkbox",
      "id": "show_section_header",
      "label": "Show section header",
      "default": true
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Eyebrow",
      "default": "/ 03 — インスタグラム"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "From Instagram",
      "info": "Main title below the red eyebrow line."
    },
    {
      "type": "checkbox",
      "id": "show_instagram_link",
      "label": "Show Instagram link",
      "default": true
    },
    {
      "type": "url",
      "id": "instagram_url",
      "label": "Instagram profile URL"
    },
    {
      "type": "text",
      "id": "instagram_link_label",
      "label": "Instagram link text (desktop)",
      "default": "Follow on Instagram"
    },
    {
      "type": "text",
      "id": "instagram_link_label_short",
      "label": "Instagram link text (mobile)",
      "default": "Follow"
    },
    {
      "type": "select",
      "id": "cta_style",
      "label": "Button style",
      "options": [
        { "value": "split", "label": "Split panel + IG icon" },
        { "value": "solid", "label": "Solid block (like hero)" },
        { "value": "minimal", "label": "Minimal underline" }
      ],
      "default": "split"
    },
    {
      "type": "header",
      "content": "Hero-style background"
    },
    {
      "type": "checkbox",
      "id": "show_hero_background",
      "label": "Show grid and crimson glow (like hero)",
      "default": true
    },
    {
      "type": "text",
      "id": "ghost_text",
      "label": "Background ghost text",
      "default": "FEED",
      "info": "Large outlined text behind the section. Leave empty to hide."
    },
    {
      "type": "text",
      "id": "vertical_jp",
      "label": "Vertical side text (desktop)",
      "default": "ミツシ・フィード"
    },
    {
      "type": "paragraph",
      "content": "Post layout and tile shape are controlled in the Instafeed app block — not here."
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 72
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 72
    },
    {
      "type": "header",
      "content": "t:general.layout"
    },
    {
      "type": "checkbox",
      "id": "enable_content_fullwidth",
      "label": "t:general.enable_layout_fullwidth",
      "info": "t:general.layout_fullwidth_info",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "remove_padding_top",
      "default": false,
      "label": "t:general.remove_padding_top"
    },
    {
      "type": "checkbox",
      "id": "remove_padding_bottom",
      "default": false,
      "label": "t:general.remove_padding_bottom"
    }
  ],
  "blocks": [
    {
      "type": "@app"
    }
  ],
  "presets": [
    {
      "name": "t:general.apps"
    }
  ]
}
{% endschema %}
