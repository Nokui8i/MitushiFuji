{% comment %}
  Mitushi Reviews Page — Judge.me Reviews Grid app block only.
{% endcomment %}

{% render 'mitushi-judgeme-styles' %}

<style>
  .mitushi-reviews-page {
    background: var(--ink, #28282b);
    color: #f7f7f8;
    padding: 32px 0 72px;
    min-height: 60vh;
  }

  .mitushi-reviews-page__inner {
    max-width: 1360px;
    margin: 0 auto;
    padding: 0 20px;
  }

  .mitushi-reviews-page__hero {
    text-align: center;
    margin-bottom: 28px;
  }

  .mitushi-reviews-page__title {
    font-family: var(--font-display), inherit;
    font-size: clamp(28px, 3.5vw, 36px);
    font-weight: 800;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #ffffff;
    margin: 0;
    line-height: 1.1;
  }

  .mitushi-reviews-page__widget {
    width: 100%;
  }

  .mitushi-reviews-page__widget--framed {
    background: rgba(255, 255, 255, 0.02);
    border: 1px solid rgba(255, 255, 255, 0.06);
    border-radius: 12px;
    padding: 24px 20px;
  }

  .mitushi-reviews-page__embed-hint {
    margin: 0 0 20px;
    padding: 14px 16px;
    border-radius: 8px;
    border: 1px solid rgba(204, 19, 42, 0.35);
    background: rgba(204, 19, 42, 0.08);
    color: rgba(255, 255, 255, 0.82);
    font-size: 13px;
    line-height: 1.6;
  }

  .mitushi-reviews-page__embed-hint strong {
    color: #fff;
  }

  @media (max-width: 768px) {
    .mitushi-reviews-page {
      padding: 24px 0 56px;
    }

    .mitushi-reviews-page__inner {
      padding: 0 16px;
    }

    .mitushi-reviews-page__widget--framed {
      padding: 16px 12px;
    }
  }
</style>

<section class="mitushi-reviews-page" data-ui-component="Mitushi Reviews Section">
  <div class="mitushi-reviews-page__inner">
    {%- if section.settings.show_heading -%}
      <header class="mitushi-reviews-page__hero">
        <h1 class="mitushi-reviews-page__title">{{ section.settings.heading | default: 'Reviews' | escape }}</h1>
      </header>
    {%- endif -%}

    <div class="mitushi-reviews-page__widget mitushi-judgeme-all-reviews-wrap{% unless section.blocks.size > 0 %} mitushi-reviews-page__widget--framed{% endunless %}">
      {%- if request.design_mode -%}
        <p class="mitushi-reviews-page__embed-hint">
          <strong>Judge.me not showing?</strong>
          Add the <strong>Reviews Grid</strong> app block to this section, then open
          <strong>Theme settings → App embeds</strong> (puzzle icon) and turn <strong>Judge.me</strong> ON.
        </p>
      {%- endif -%}

      {%- if section.blocks.size > 0 -%}
        {%- for block in section.blocks -%}
          <div {{ block.shopify_attributes }}>
            {% render block %}
          </div>
        {%- endfor -%}
      {%- else -%}
        {% render 'mitushi-judgeme-all-reviews' %}
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Mitushi Reviews",
  "tag": "section",
  "class": "mitushi-reviews-section",
  "blocks": [
    {
      "type": "@app"
    }
  ],
  "settings": [
    {
      "type": "checkbox",
      "id": "show_heading",
      "label": "Show page heading",
      "default": false
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Reviews"
    }
  ],
  "presets": [
    {
      "name": "Mitushi Reviews"
    }
  ]
}
{% endschema %}
