{% comment %}
  Mitushi Reviews Page — Judge.me All Reviews (like ANIQI /pages/reviews)
{% endcomment %}

{% render 'mitushi-judgeme-styles' %}

<style>
  .mitushi-reviews-page {
    background: var(--ink, #28282b);
    color: #f7f7f8;
    padding: 48px 0 80px;
    min-height: 60vh;
  }

  .mitushi-reviews-page__inner {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 24px;
  }

  .mitushi-reviews-page__hero {
    text-align: center;
    margin-bottom: 40px;
  }

  .mitushi-reviews-page__title {
    font-family: var(--font-display), inherit;
    font-size: clamp(32px, 4.5vw, 44px);
    font-weight: 800;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #ffffff;
    margin: 0;
    line-height: 1.1;
  }

  .mitushi-reviews-page__widget {
    background: rgba(255, 255, 255, 0.02);
    border: 1px solid rgba(255, 255, 255, 0.06);
    border-radius: 12px;
    padding: 32px 28px;
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    box-shadow: 0 24px 48px rgba(0, 0, 0, 0.4);
  }

  .mitushi-reviews-page__empty {
    text-align: center;
    padding: 48px 24px;
    color: rgba(255, 255, 255, 0.5);
    font-size: 14px;
    letter-spacing: 0.05em;
  }

  @media (max-width: 768px) {
    .mitushi-reviews-page {
      padding: 32px 0 56px;
    }

    .mitushi-reviews-page__widget {
      padding: 20px 16px;
      border-radius: 8px;
    }

    .mitushi-reviews-page__hero {
      margin-bottom: 32px;
    }
  }
</style>

<section class="mitushi-reviews-page" data-ui-component="Mitushi Reviews Section">
  <div class="mitushi-reviews-page__inner">
    <header class="mitushi-reviews-page__hero">
      <h1 class="mitushi-reviews-page__title">
        {{ section.settings.heading | default: 'Reviews' | escape }}
      </h1>
    </header>

    <div class="mitushi-reviews-page__widget mitushi-judgeme-all-reviews-wrap">
      {%- if section.blocks.size > 0 -%}
        {%- for block in section.blocks -%}
          {% render block %}
        {%- endfor -%}
      {%- else -%}
        {% render 'mitushi-judgeme-all-reviews' %}
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Mitushi Reviews",
  "tag": "section",
  "class": "mitushi-reviews-section",
  "blocks": [
    {
      "type": "@app"
    }
  ],
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Reviews"
    }
  ],
  "presets": [
    {
      "name": "Mitushi Reviews"
    }
  ]
}
{% endschema %}
