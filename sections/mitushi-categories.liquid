<style>
  .mitushi-categories {
    position: relative;
    border-top: 1px solid rgba(255, 255, 255, 0.1);
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
    background-color: var(--ink);
    padding-top: 72px;
    padding-bottom: 72px;
  }

  .mitushi-categories-container {
    margin: 0 auto;
    max-width: 1360px;
    padding: 0 24px;
  }

  .mitushi-categories-header {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    margin-bottom: 36px;
  }

  .mitushi-categories-title-group > div:first-child {
    font-size: 10px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.5em;
    color: #cc132a;
    margin-bottom: 12px;
  }

  .mitushi-categories-title-group > h2 {
    font-family: var(--font-display);
    letter-spacing: 0.02em;
    font-size: 32px;
    font-weight: 700;
    color: #f7f7f8;
  }

  @media (min-width: 768px) {
    .mitushi-categories-title-group > h2 {
      font-size: 52px;
    }
  }

  @media (min-width: 1200px) {
    .mitushi-categories-title-group > h2 {
      font-size: 56px;
    }
  }

  .mitushi-categories-view-all {
    display: none;
    font-size: 12px;
    text-transform: uppercase;
    letter-spacing: 0.3em;
    color: rgba(255, 255, 255, 0.7);
    text-decoration: none;
    transition: color 0.3s;
  }

  .mitushi-categories-view-all:hover {
    color: #cc132a;
  }

  @media (min-width: 768px) {
    .mitushi-categories-view-all {
      display: block;
    }
  }

  /* Dynamic grid: first collection featured, rest stack in column 2 */
  .mitushi-categories-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 8px;
  }

  .mitushi-category-card {
    position: relative;
    display: block;
    overflow: hidden;
    background-color: rgba(255, 255, 255, 0.05);
    text-decoration: none;
    color: inherit;
    border: 1px solid rgba(255, 255, 255, 0.1);
    transition: border-color 0.3s;
    min-height: 160px;
  }

  .mitushi-category-card:hover {
    border-color: rgba(204, 19, 42, 0.6);
  }

  .mitushi-category-card.big {
    grid-column: 1 / -1;
    min-height: min(68vw, 420px);
  }

  .mitushi-category-card:not(.big) {
    min-height: min(44vw, 200px);
    aspect-ratio: 1 / 1;
  }

  @media (min-width: 768px) {
    .mitushi-categories-grid {
      grid-template-columns: minmax(0, 2fr) minmax(0, 1fr);
      grid-template-rows: repeat(var(--mitushi-cat-stack, 2), minmax(160px, 1fr));
      gap: 12px;
      min-height: 536px;
    }

    .mitushi-categories-grid--single {
      grid-template-columns: 1fr;
      min-height: 420px;
    }

    .mitushi-category-card {
      min-height: 0;
      height: 100%;
      aspect-ratio: auto;
    }

    .mitushi-category-card.big {
      grid-column: 1;
      grid-row: 1 / span var(--mitushi-cat-span, var(--mitushi-cat-stack, 2));
      min-height: 280px;
    }

    .mitushi-categories-grid--single .mitushi-category-card.big {
      grid-column: 1;
      grid-row: 1;
    }

    .mitushi-category-card:not(.big) {
      grid-column: 2;
      grid-row: var(--mitushi-cat-row, auto);
      min-height: 160px;
    }
  }

  @media (min-width: 1200px) {
    .mitushi-categories-grid {
      min-height: 584px;
    }
  }

  .mitushi-category-image--placeholder {
    background:
      radial-gradient(ellipse 80% 60% at 70% 30%, rgba(204, 19, 42, 0.18) 0%, transparent 70%),
      linear-gradient(145deg, rgba(255, 255, 255, 0.06) 0%, rgba(255, 255, 255, 0.02) 100%);
  }

  .mitushi-category-image-wrapper {
    position: absolute;
    inset: 0;
    overflow: hidden;
  }

  .mitushi-category-image {
    height: 100%;
    width: 100%;
    object-fit: cover;
    filter: grayscale(20%);
    transition: all 1.2s cubic-bezier(0.4, 0.0, 0.2, 1);
  }

  .mitushi-category-card:hover .mitushi-category-image {
    transform: scale(1.05);
    filter: grayscale(0%);
  }

  .mitushi-category-overlay {
    position: absolute;
    inset: 0;
    z-index: 1;
    background: linear-gradient(to top, #28282B, rgba(40, 40, 43, 0.2), transparent);
    opacity: 0.9;
    pointer-events: none;
  }

  .mitushi-category-content {
    position: absolute;
    inset: 0;
    z-index: 2;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    padding: 10px;
  }

  @media (min-width: 768px) {
    .mitushi-category-content {
      padding: 24px;
    }
  }

  @media (min-width: 1200px) {
    .mitushi-category-content {
      padding: 28px;
    }
  }

  .mitushi-category-top {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
  }

  .mitushi-category-jp {
    font-family: var(--font-jp);
    font-size: clamp(9px, 2.5vw, 12px);
    color: rgba(255, 255, 255, 0.7);
    line-height: 1.2;
  }

  .mitushi-category-bottom {
    display: flex;
    flex-direction: column;
  }

  .mitushi-category-bottom-row {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
  }

  .mitushi-category-name {
    font-family: var(--font-display);
    letter-spacing: 0.02em;
    font-size: clamp(1.25rem, 5.5vw, 1.75rem);
    font-weight: 700;
    line-height: 0.95;
    color: #f7f7f8;
  }

  @media (min-width: 768px) {
    .mitushi-category-name {
      font-size: 48px;
    }
  }

  @media (min-width: 1200px) {
    .mitushi-category-name {
      font-size: 52px;
    }
  }

  .mitushi-category-arrow {
    width: clamp(18px, 5vw, 28px);
    height: clamp(18px, 5vw, 28px);
    color: #cc132a;
    opacity: 0;
    transform: translateX(8px);
    transition: all 500ms cubic-bezier(0.16, 1, 0.3, 1);
  }

  .mitushi-category-card:hover .mitushi-category-arrow {
    opacity: 1;
    transform: translateX(0);
  }

  .mitushi-category-ring {
    position: absolute;
    inset: 0;
    z-index: 3;
    border: 1px solid transparent;
    transition: border-color 0.3s;
    pointer-events: none;
  }

  .mitushi-category-card:hover .mitushi-category-ring {
    border-color: rgba(204, 19, 42, 0.6);
  }

  @media (max-width: 767px) {
    .mitushi-categories {
      padding-top: 56px;
      padding-bottom: 56px;
    }

    .mitushi-categories-container {
      padding-inline: 1rem;
    }

    .mitushi-categories-header {
      justify-content: center;
      margin-bottom: 24px;
    }

    .mitushi-categories-title-group {
      width: 100%;
      text-align: center;
    }

    .mitushi-categories-title-group > h2 {
      font-size: clamp(1.5rem, 8vw, 2rem);
    }

    .mitushi-categories-title-group > div:first-child {
      font-size: 8px;
      letter-spacing: 0.35em;
      margin-bottom: 8px;
    }

    .mitushi-category-content {
      padding: 14px;
    }

    .mitushi-category-card.big .mitushi-category-content {
      padding: 18px;
    }

    .mitushi-category-name {
      font-size: clamp(1.35rem, 6vw, 1.65rem);
    }

    .mitushi-category-card.big .mitushi-category-name {
      font-size: clamp(2rem, 11vw, 2.5rem);
    }

    .mitushi-category-jp {
      font-size: 11px;
    }

  }
</style>

<section class="mitushi-categories" id="products">
  <div class="mitushi-categories-container">
    <div class="mitushi-categories-header">
      <div class="mitushi-categories-title-group">
        <div>{{ section.settings.subheading | default: '/ 01 — Collections' }}</div>
        <h2>{{ section.settings.heading | default: 'Shop by category' }}</h2>
      </div>
    </div>

    {%- liquid
      assign use_auto_collections = section.settings.use_shopify_collections
      assign category_count = 0

      if use_auto_collections
        if section.settings.featured_collections != blank and section.settings.featured_collections.size > 0
          assign category_count = section.settings.featured_collections.size
        else
          for collection in collections
            unless collection.handle == 'all' or collection.handle == 'frontpage'
              assign category_count = category_count | plus: 1
            endunless
          endfor
        endif
      else
        assign category_count = section.blocks.size
      endif

      assign stack_rows = category_count | minus: 1
      if stack_rows < 1
        assign stack_rows = 1
      endif
    -%}

    {%- if category_count > 0 -%}
      <div
        class="mitushi-categories-grid{% if category_count == 1 %} mitushi-categories-grid--single{% endif %}"
        style="--mitushi-cat-stack: {{ stack_rows }};"
      >
        {%- if use_auto_collections -%}
          {%- if section.settings.featured_collections != blank and section.settings.featured_collections.size > 0 -%}
            {%- for col_obj in section.settings.featured_collections -%}
              {%- render 'mitushi-category-card',
                col_obj: col_obj,
                is_big: forloop.first,
                stack_span: stack_rows,
                grid_row: forloop.index0,
                japanese_label: '',
                image_override: blank
              -%}
            {%- endfor -%}
          {%- else -%}
            {%- assign auto_index = 0 -%}
            {%- for col_obj in collections -%}
              {%- unless col_obj.handle == 'all' or col_obj.handle == 'frontpage' -%}
                {%- render 'mitushi-category-card',
                  col_obj: col_obj,
                  is_big: auto_index == 0,
                  stack_span: stack_rows,
                  grid_row: auto_index,
                  japanese_label: '',
                  image_override: blank
                -%}
                {%- assign auto_index = auto_index | plus: 1 -%}
              {%- endunless -%}
            {%- endfor -%}
          {%- endif -%}
        {%- else -%}
          {%- for block in section.blocks -%}
            {%- liquid
              assign col_obj = blank
              assign col_jp = block.settings.japanese
              assign image_override = block.settings.image

              if block.settings.collection != blank
                assign col_obj = block.settings.collection
              endif
            -%}
            {%- if col_obj != blank -%}
              {%- render 'mitushi-category-card',
                col_obj: col_obj,
                is_big: forloop.first,
                stack_span: stack_rows,
                grid_row: forloop.index0,
                japanese_label: col_jp,
                image_override: image_override,
                block: block
              -%}
            {%- endif -%}
          {%- endfor -%}
        {%- endif -%}
      </div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Categories Section",
  "settings": [
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "/ 01 — Collections"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Shop by category"
    },
    {
      "type": "checkbox",
      "id": "use_shopify_collections",
      "label": "Use Shopify collections",
      "default": true,
      "info": "Shows your store collections with images from Shopify. New collections appear automatically."
    },
    {
      "type": "collection_list",
      "id": "featured_collections",
      "label": "Collections to show",
      "info": "Optional. Pick and drag to reorder. Leave empty to show all collections."
    }
  ],
  "blocks": [
    {
      "type": "category",
      "name": "Category (manual mode)",
      "settings": [
        {
          "type": "collection",
          "id": "collection",
          "label": "Collection"
        },
        {
          "type": "text",
          "id": "japanese",
          "label": "Japanese label (optional)"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image override (optional)"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Categories Section"
    }
  ]
}
{% endschema %}
