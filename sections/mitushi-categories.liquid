<style>
  .mitushi-categories {
    position: relative;
    border-top: 1px solid rgba(255, 255, 255, 0.1);
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
    background-color: var(--ink);
    padding-top: 72px;
    padding-bottom: 72px;
  }

  .mitushi-categories-container {
    margin: 0 auto;
    max-width: 1360px;
    padding: 0 24px;
  }

  .mitushi-categories-header {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    margin-bottom: 36px;
  }

  .mitushi-categories-title-group > div:first-child {
    font-size: 10px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.5em;
    color: #cc132a;
    margin-bottom: 12px;
  }

  .mitushi-categories-title-group > h2 {
    font-family: var(--font-display);
    letter-spacing: 0.02em;
    font-size: 32px;
    font-weight: 700;
    color: #f7f7f8;
  }

  @media (min-width: 768px) {
    .mitushi-categories-title-group > h2 {
      font-size: 52px;
    }
  }

  @media (min-width: 1200px) {
    .mitushi-categories-title-group > h2 {
      font-size: 56px;
    }
  }

  .mitushi-categories-view-all {
    display: none;
    font-size: 12px;
    text-transform: uppercase;
    letter-spacing: 0.3em;
    color: rgba(255, 255, 255, 0.7);
    text-decoration: none;
    transition: color 0.3s;
  }

  .mitushi-categories-view-all:hover {
    color: #cc132a;
  }

  @media (min-width: 768px) {
    .mitushi-categories-view-all {
      display: block;
    }
  }

  /* Flat grid: 1 big + up to 3 small cards */
  .mitushi-categories-layout {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 8px;
  }

  .mitushi-category-card {
    position: relative;
    display: block;
    overflow: hidden;
    background-color: rgba(255, 255, 255, 0.05);
    text-decoration: none;
    color: inherit;
    border: 1px solid rgba(255, 255, 255, 0.1);
    transition: border-color 0.3s;
    isolation: isolate;
  }

  .mitushi-category-card:hover {
    border-color: rgba(204, 19, 42, 0.6);
  }

  .mitushi-category-card.big {
    grid-column: 1 / -1;
    min-height: min(68vw, 420px);
  }

  .mitushi-category-card:not(.big) {
    aspect-ratio: 1 / 1;
    min-height: 0;
  }

  /* Mobile: only 2 small cards below the big one */
  .mitushi-categories-layout > .mitushi-category-card:nth-child(n+4) {
    display: none;
  }

  @media (min-width: 768px) {
    .mitushi-categories-layout {
      grid-template-columns: minmax(0, 2fr) minmax(0, 1fr);
      grid-template-rows: repeat(3, minmax(160px, 1fr));
      gap: 12px;
      min-height: 536px;
    }

    .mitushi-categories-layout--single {
      grid-template-columns: 1fr;
      grid-template-rows: minmax(420px, 1fr);
      min-height: 420px;
    }

    .mitushi-categories-layout > .mitushi-category-card:nth-child(n+4) {
      display: block;
    }

    .mitushi-category-card.big {
      grid-column: 1;
      grid-row: 1 / span 3;
      min-height: 536px;
      aspect-ratio: auto;
    }

    .mitushi-categories-layout--single .mitushi-category-card.big {
      grid-column: 1;
      grid-row: 1;
      min-height: 420px;
    }

    .mitushi-category-card:not(.big):nth-child(2) {
      grid-column: 2;
      grid-row: 1;
    }

    .mitushi-category-card:not(.big):nth-child(3) {
      grid-column: 2;
      grid-row: 2;
    }

    .mitushi-category-card:not(.big):nth-child(4) {
      grid-column: 2;
      grid-row: 3;
    }

    .mitushi-category-card:not(.big) {
      min-height: 160px;
      aspect-ratio: auto;
    }
  }

  @media (min-width: 1200px) {
    .mitushi-categories-layout {
      min-height: 584px;
    }

    .mitushi-category-card.big {
      min-height: 584px;
    }
  }

  .mitushi-category-image--placeholder {
    background:
      radial-gradient(ellipse 80% 60% at 70% 30%, rgba(204, 19, 42, 0.18) 0%, transparent 70%),
      linear-gradient(145deg, rgba(255, 255, 255, 0.06) 0%, rgba(255, 255, 255, 0.02) 100%);
  }

  .mitushi-category-image-wrapper {
    position: absolute;
    inset: 0;
    overflow: hidden;
  }

  .mitushi-category-image {
    height: 100%;
    width: 100%;
    object-fit: cover;
    filter: grayscale(20%);
    transition: all 1.2s cubic-bezier(0.4, 0.0, 0.2, 1);
  }

  .mitushi-category-card:hover .mitushi-category-image {
    transform: scale(1.05);
    filter: grayscale(0%);
  }

  .mitushi-category-overlay {
    position: absolute;
    inset: 0;
    z-index: 1;
    background: linear-gradient(to top, #28282B, rgba(40, 40, 43, 0.2), transparent);
    opacity: 0.9;
    pointer-events: none;
  }

  .mitushi-category-content {
    position: absolute;
    inset: 0;
    z-index: 2;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    padding: 10px;
  }

  @media (min-width: 768px) {
    .mitushi-category-content {
      padding: 24px;
    }
  }

  @media (min-width: 1200px) {
    .mitushi-category-content {
      padding: 28px;
    }
  }

  .mitushi-category-top {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
  }

  .mitushi-category-jp {
    font-family: var(--font-jp);
    font-size: clamp(9px, 2.5vw, 12px);
    color: rgba(255, 255, 255, 0.7);
    line-height: 1.2;
  }

  .mitushi-category-bottom {
    display: flex;
    flex-direction: column;
  }

  .mitushi-category-bottom-row {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
  }

  .mitushi-category-name {
    font-family: var(--font-display);
    letter-spacing: 0.02em;
    font-size: clamp(1.25rem, 5.5vw, 1.75rem);
    font-weight: 700;
    line-height: 0.95;
    color: #f7f7f8;
  }

  @media (min-width: 768px) {
    .mitushi-category-name {
      font-size: 48px;
    }
  }

  @media (min-width: 1200px) {
    .mitushi-category-name {
      font-size: 52px;
    }
  }

  .mitushi-category-arrow {
    width: clamp(18px, 5vw, 28px);
    height: clamp(18px, 5vw, 28px);
    color: #cc132a;
    opacity: 0;
    transform: translateX(8px);
    transition: all 500ms cubic-bezier(0.16, 1, 0.3, 1);
  }

  .mitushi-category-card:hover .mitushi-category-arrow {
    opacity: 1;
    transform: translateX(0);
  }

  .mitushi-category-ring {
    position: absolute;
    inset: 0;
    z-index: 3;
    border: 1px solid transparent;
    transition: border-color 0.3s;
    pointer-events: none;
  }

  .mitushi-category-card:hover .mitushi-category-ring {
    border-color: rgba(204, 19, 42, 0.6);
  }

  @media (max-width: 767px) {
    .mitushi-categories {
      padding-top: 56px;
      padding-bottom: 56px;
    }

    .mitushi-categories-container {
      padding-inline: 1rem;
    }

    .mitushi-categories-header {
      justify-content: center;
      margin-bottom: 24px;
    }

    .mitushi-categories-title-group {
      width: 100%;
      text-align: center;
    }

    .mitushi-categories-title-group > h2 {
      font-size: clamp(1.5rem, 8vw, 2rem);
    }

    .mitushi-categories-title-group > div:first-child {
      font-size: 8px;
      letter-spacing: 0.35em;
      margin-bottom: 8px;
    }

    .mitushi-category-content {
      padding: 14px;
    }

    .mitushi-category-card.big .mitushi-category-content {
      padding: 18px;
    }

    .mitushi-category-name {
      font-size: clamp(1.35rem, 6vw, 1.65rem);
    }

    .mitushi-category-card.big .mitushi-category-name {
      font-size: clamp(2rem, 11vw, 2.5rem);
    }

    .mitushi-category-jp {
      font-size: 11px;
    }

  }
</style>

<section class="mitushi-categories" id="products">
  <div class="mitushi-categories-container">
    <div class="mitushi-categories-header">
      <div class="mitushi-categories-title-group">
        <div>{{ section.settings.subheading | default: '/ 01 — Collections' }}</div>
        <h2>{{ section.settings.heading | default: 'Shop by category' }}</h2>
      </div>
    </div>

    {%- liquid
      assign use_auto_collections = section.settings.use_shopify_collections
      assign max_stack = 3
      assign hero_col = blank
      assign stack_count = 0

      if use_auto_collections
        if section.settings.hero_collection != blank
          assign hero_col = section.settings.hero_collection
        endif

        if hero_col == blank or hero_col.handle == blank
          if collections['shirts'] != blank
            assign hero_col = collections['shirts']
          endif
        endif

        if hero_col == blank or hero_col.handle == blank
          for fallback_col in collections
            unless fallback_col.handle == 'all' or fallback_col.handle == 'frontpage'
              assign hero_col = fallback_col
              break
            endunless
          endfor
        endif

        if section.settings.stack_collections != blank and section.settings.stack_collections.size > 0
          for stack_col in section.settings.stack_collections
            if stack_count >= max_stack
              break
            endif
            if hero_col != blank and stack_col.id == hero_col.id
              continue
            endif
            assign stack_count = stack_count | plus: 1
          endfor
        else
          for stack_col in collections
            if stack_count >= max_stack
              break
            endif
            unless stack_col.handle == 'all' or stack_col.handle == 'frontpage'
              if hero_col != blank and stack_col.id == hero_col.id
                continue
              endif
              assign stack_count = stack_count | plus: 1
            endunless
          endfor
        endif
      else
        assign manual_blocks_shown = 0
        for block in section.blocks
          if block.settings.collection != blank
            assign manual_blocks_shown = manual_blocks_shown | plus: 1
          endif
        endfor
        if manual_blocks_shown > 4
          assign manual_blocks_shown = 4
        endif
        if manual_blocks_shown > 0
          assign hero_col = section.blocks.first.settings.collection
          assign stack_count = manual_blocks_shown | minus: 1
          if stack_count > max_stack
            assign stack_count = max_stack
          endif
        endif
      endif

      assign category_count = 0
      if hero_col != blank and hero_col.handle != blank
        assign category_count = 1 | plus: stack_count
      endif
    -%}

    {%- if hero_col != blank and hero_col.handle != blank -%}
      <div class="mitushi-categories-layout{% if stack_count == 0 %} mitushi-categories-layout--single{% endif %}">
        {%- if use_auto_collections -%}
          {%- render 'mitushi-category-card',
            col_obj: hero_col,
            is_big: true,
            japanese_label: '',
            image_override: blank
          -%}

          {%- if section.settings.stack_collections != blank and section.settings.stack_collections.size > 0 -%}
            {%- assign stack_rendered = 0 -%}
            {%- for stack_col in section.settings.stack_collections -%}
              {%- if stack_rendered >= max_stack -%}
                {%- break -%}
              {%- endif -%}
              {%- if stack_col.id == hero_col.id -%}
                {%- continue -%}
              {%- endif -%}
              {%- render 'mitushi-category-card',
                col_obj: stack_col,
                is_big: false,
                japanese_label: '',
                image_override: blank
              -%}
              {%- assign stack_rendered = stack_rendered | plus: 1 -%}
            {%- endfor -%}
          {%- else -%}
            {%- assign stack_rendered = 0 -%}
            {%- for stack_col in collections -%}
              {%- if stack_rendered >= max_stack -%}
                {%- break -%}
              {%- endif -%}
              {%- unless stack_col.handle == 'all' or stack_col.handle == 'frontpage' -%}
                {%- if stack_col.id == hero_col.id -%}
                  {%- continue -%}
                {%- endif -%}
                {%- render 'mitushi-category-card',
                  col_obj: stack_col,
                  is_big: false,
                  japanese_label: '',
                  image_override: blank
                -%}
                {%- assign stack_rendered = stack_rendered | plus: 1 -%}
              {%- endunless -%}
            {%- endfor -%}
          {%- endif -%}
        {%- else -%}
          {%- assign hero_block = section.blocks.first -%}
          {%- render 'mitushi-category-card',
            col_obj: hero_col,
            is_big: true,
            japanese_label: hero_block.settings.japanese,
            image_override: hero_block.settings.image,
            block: hero_block
          -%}

          {%- assign manual_rendered = 0 -%}
          {%- for block in section.blocks -%}
            {%- if manual_rendered >= max_stack -%}
              {%- break -%}
            {%- endif -%}
            {%- if forloop.first -%}
              {%- continue -%}
            {%- endif -%}
            {%- if block.settings.collection == blank -%}
              {%- continue -%}
            {%- endif -%}
            {%- render 'mitushi-category-card',
              col_obj: block.settings.collection,
              is_big: false,
              japanese_label: block.settings.japanese,
              image_override: block.settings.image,
              block: block
            -%}
            {%- assign manual_rendered = manual_rendered | plus: 1 -%}
          {%- endfor -%}
        {%- endif -%}
      </div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Categories Section",
  "settings": [
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "/ 01 — Collections"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Shop by category"
    },
    {
      "type": "checkbox",
      "id": "use_shopify_collections",
      "label": "Use Shopify collections",
      "default": true,
      "info": "Shows up to 4 collections: 1 large + 3 small. Extra collections are hidden to keep the layout fixed."
    },
    {
      "type": "collection",
      "id": "hero_collection",
      "label": "Large category",
      "info": "Shown in the big left card (e.g. Shirts). Defaults to Shirts if empty."
    },
    {
      "type": "collection_list",
      "id": "stack_collections",
      "label": "Small categories (max 3)",
      "info": "Up to 3 collections for the right column. Drag to reorder. Leave empty to auto-fill from your other collections."
    }
  ],
  "blocks": [
    {
      "type": "category",
      "name": "Category (manual mode)",
      "settings": [
        {
          "type": "collection",
          "id": "collection",
          "label": "Collection"
        },
        {
          "type": "text",
          "id": "japanese",
          "label": "Japanese label (optional)"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image override (optional)"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Categories Section"
    }
  ]
}
{% endschema %}
