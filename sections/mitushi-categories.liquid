<style>
  .mitushi-categories {
    position: relative;
    border-top: 1px solid rgba(255, 255, 255, 0.1);
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
    background-color: var(--ink);
    padding-top: 72px;
    padding-bottom: 72px;
  }

  .mitushi-categories-container {
    margin: 0 auto;
    max-width: 1360px;
    padding: 0 24px;
  }

  .mitushi-categories-header {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    margin-bottom: 36px;
  }

  .mitushi-categories-title-group > div:first-child {
    font-size: 10px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.5em;
    color: #cc132a;
    margin-bottom: 12px;
  }

  .mitushi-categories-title-group > h2 {
    font-family: var(--font-display);
    letter-spacing: 0.02em;
    font-size: 32px;
    font-weight: 700;
    color: #f7f7f8;
  }

  @media (min-width: 768px) {
    .mitushi-categories-title-group > h2 {
      font-size: 52px;
    }
  }

  @media (min-width: 1200px) {
    .mitushi-categories-title-group > h2 {
      font-size: 56px;
    }
  }

  .mitushi-categories-view-all {
    display: none;
    font-size: 12px;
    text-transform: uppercase;
    letter-spacing: 0.3em;
    color: rgba(255, 255, 255, 0.7);
    text-decoration: none;
    transition: color 0.3s;
  }

  .mitushi-categories-view-all:hover {
    color: #cc132a;
  }

  @media (min-width: 768px) {
    .mitushi-categories-view-all {
      display: block;
    }
  }

  /* Mobile: big card full-width on top, two smaller cards side-by-side below */
  .mitushi-categories-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    grid-template-rows: minmax(280px, 68vw) minmax(180px, 44vw);
    gap: 8px;
  }

  .mitushi-category-card:nth-child(2) {
    grid-column: 1;
    grid-row: 2;
  }

  .mitushi-category-card:nth-child(3) {
    grid-column: 2;
    grid-row: 2;
  }

  @media (min-width: 768px) {
    .mitushi-categories-grid {
      grid-template-columns: repeat(3, 1fr);
      grid-template-rows: 268px 268px;
      gap: 12px;
    }

    .mitushi-category-card:nth-child(2),
    .mitushi-category-card:nth-child(3) {
      grid-column: auto;
      grid-row: auto;
    }
  }

  @media (min-width: 1200px) {
    .mitushi-categories-grid {
      grid-template-rows: 292px 292px;
      gap: 12px;
    }
  }

  .mitushi-category-card {
    position: relative;
    display: block;
    height: 100%;
    min-height: 0;
    overflow: hidden;
    background-color: rgba(255, 255, 255, 0.05);
    text-decoration: none;
    color: inherit;
    border: 1px solid rgba(255, 255, 255, 0.1);
    transition: border-color 0.3s;
  }

  .mitushi-category-card:hover {
    border-color: rgba(204, 19, 42, 0.6);
  }

  .mitushi-category-card.big {
    grid-column: 1 / -1;
    grid-row: 1;
  }

  @media (min-width: 768px) {
    .mitushi-category-card.big {
      grid-column: span 2;
      grid-row: span 2;
    }
  }

  .mitushi-category-image-wrapper {
    position: absolute;
    inset: 0;
    overflow: hidden;
  }

  .mitushi-category-image {
    height: 100%;
    width: 100%;
    object-fit: cover;
    filter: grayscale(20%);
    transition: all 1.2s cubic-bezier(0.4, 0.0, 0.2, 1);
  }

  .mitushi-category-card:hover .mitushi-category-image {
    transform: scale(1.05);
    filter: grayscale(0%);
  }

  .mitushi-category-overlay {
    position: absolute;
    inset: 0;
    z-index: 1;
    background: linear-gradient(to top, #28282B, rgba(40, 40, 43, 0.2), transparent);
    opacity: 0.9;
    pointer-events: none;
  }

  .mitushi-category-content {
    position: absolute;
    inset: 0;
    z-index: 2;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    padding: 10px;
  }

  @media (min-width: 768px) {
    .mitushi-category-content {
      padding: 24px;
    }
  }

  @media (min-width: 1200px) {
    .mitushi-category-content {
      padding: 28px;
    }
  }

  .mitushi-category-top {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
  }

  .mitushi-category-jp {
    font-family: var(--font-jp);
    font-size: clamp(9px, 2.5vw, 12px);
    color: rgba(255, 255, 255, 0.7);
    line-height: 1.2;
  }

  .mitushi-category-bottom {
    display: flex;
    flex-direction: column;
  }

  .mitushi-category-bottom-row {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
  }

  .mitushi-category-name {
    font-family: var(--font-display);
    letter-spacing: 0.02em;
    font-size: clamp(1.25rem, 5.5vw, 1.75rem);
    font-weight: 700;
    line-height: 0.95;
    color: #f7f7f8;
  }

  @media (min-width: 768px) {
    .mitushi-category-name {
      font-size: 48px;
    }
  }

  @media (min-width: 1200px) {
    .mitushi-category-name {
      font-size: 52px;
    }
  }

  .mitushi-category-arrow {
    width: clamp(18px, 5vw, 28px);
    height: clamp(18px, 5vw, 28px);
    color: #cc132a;
    opacity: 0;
    transform: translateX(8px);
    transition: all 500ms cubic-bezier(0.16, 1, 0.3, 1);
  }

  .mitushi-category-card:hover .mitushi-category-arrow {
    opacity: 1;
    transform: translateX(0);
  }

  .mitushi-category-ring {
    position: absolute;
    inset: 0;
    z-index: 3;
    border: 1px solid transparent;
    transition: border-color 0.3s;
    pointer-events: none;
  }

  .mitushi-category-card:hover .mitushi-category-ring {
    border-color: rgba(204, 19, 42, 0.6);
  }

  @media (max-width: 767px) {
    .mitushi-categories {
      padding-top: 56px;
      padding-bottom: 56px;
    }

    .mitushi-categories-container {
      padding-inline: 1rem;
    }

    .mitushi-categories-header {
      justify-content: center;
      margin-bottom: 24px;
    }

    .mitushi-categories-title-group {
      width: 100%;
      text-align: center;
    }

    .mitushi-categories-title-group > h2 {
      font-size: clamp(1.5rem, 8vw, 2rem);
    }

    .mitushi-categories-title-group > div:first-child {
      font-size: 8px;
      letter-spacing: 0.35em;
      margin-bottom: 8px;
    }

    .mitushi-category-content {
      padding: 14px;
    }

    .mitushi-category-card.big .mitushi-category-content {
      padding: 18px;
    }

    .mitushi-category-name {
      font-size: clamp(1.35rem, 6vw, 1.65rem);
    }

    .mitushi-category-card.big .mitushi-category-name {
      font-size: clamp(2rem, 11vw, 2.5rem);
    }

    .mitushi-category-jp {
      font-size: 11px;
    }

  }
</style>

<section class="mitushi-categories" id="products">
  <div class="mitushi-categories-container">
    <div class="mitushi-categories-header">
      <div class="mitushi-categories-title-group">
        <div>{{ section.settings.subheading | default: '/ 01 — Collections' }}</div>
        <h2>{{ section.settings.heading | default: 'Shop by category' }}</h2>
      </div>
      {% if section.settings.view_all_label != blank %}
        <a href="{{ section.settings.view_all_link | default: '#' }}" class="mitushi-categories-view-all">{{ section.settings.view_all_label }}</a>
      {% endif %}
    </div>

    <div class="mitushi-categories-grid">
      {% for block in section.blocks %}
        {%- liquid
          assign is_big = false
          if forloop.first
            assign is_big = true
          endif

          assign col_url = '#'
          assign col_title = block.settings.title
          assign col_jp = block.settings.japanese

          if block.settings.collection != blank
            assign col_obj = block.settings.collection
            if col_obj.title == blank and block.settings.collection != blank
              assign col_obj = collections[block.settings.collection]
            endif
          else
            assign fallback_index = forloop.index0
            assign count = 0
            for collection in collections
              if collection.handle != 'all' and collection.handle != 'frontpage'
                if count == fallback_index
                  assign col_obj = collection
                  break
                endif
                assign count = count | plus: 1
              endif
            endfor
          endif

          if col_obj == blank
            continue
          endif

          if col_obj != blank
            assign col_url = col_obj.url
            assign col_title = col_obj.title
          endif

          if block.settings.image != blank
            assign cat_img = block.settings.image | img_url: '600x800'
          elsif block.settings.collection != blank and col_obj.image != blank
            assign cat_img = col_obj.image | img_url: '600x800'
          elsif block.settings.collection != blank and col_obj.products.first.featured_image != blank
            assign cat_img = col_obj.products.first.featured_image | img_url: '600x800'
          else
            if forloop.index == 1
              assign cat_img = 'cat-shirts.jpg' | asset_url
            elsif forloop.index == 2
              assign cat_img = 'cat-shorts.jpg' | asset_url
            else
              assign cat_img = 'cat-tanks.jpg' | asset_url
            endif
          endif
        -%}

        <a href="{{ col_url }}" class="mitushi-category-card{% if is_big %} big{% endif %}" {{ block.shopify_attributes }}>
          <div class="mitushi-category-image-wrapper">
            <img
              src="{{ cat_img }}"
              alt="{{ col_title | escape }}"
              loading="lazy"
              class="mitushi-category-image"
            />
          </div>
          <div class="mitushi-category-overlay"></div>
          <div class="mitushi-category-content">
            <div class="mitushi-category-top">
              <span class="mitushi-category-jp">{{ col_jp }}</span>
            </div>
            <div class="mitushi-category-bottom">
              <div class="mitushi-category-bottom-row">
                <h3 class="mitushi-category-name">{{ col_title }}</h3>
                <svg class="mitushi-category-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M7 17L17 7M17 7H7m10 0v10"></path>
                </svg>
              </div>
            </div>
          </div>
          <div class="mitushi-category-ring"></div>
        </a>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Categories Section",
  "settings": [
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "/ 01 — Collections"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Shop by category"
    },
    {
      "type": "text",
      "id": "view_all_label",
      "label": "View All Label",
      "default": "View all →"
    },
    {
      "type": "url",
      "id": "view_all_link",
      "label": "View All Link"
    }
  ],
  "blocks": [
    {
      "type": "category",
      "name": "Category",
      "settings": [
        {
          "type": "collection",
          "id": "collection",
          "label": "Select Collection"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Fallback/Override Title",
          "default": "Shirts"
        },
        {
          "type": "text",
          "id": "japanese",
          "label": "Japanese Name",
          "default": "シャツ"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Category Image Override"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Categories Section"
    }
  ]
}
{% endschema %}
