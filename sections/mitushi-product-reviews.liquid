{% comment %}
  Judge.me Review Widget for product pages.
  Uses metafields or Judge.me app blocks — no judgeme_widgets snippet required.
{% endcomment %}

{% render 'mitushi-judgeme-styles' %}

<style>
  .mitushi-product-reviews {
    background: var(--ink, #28282b);
    color: #f7f7f8;
    padding: 56px 0 72px;
    border-top: 1px solid rgba(255, 255, 255, 0.06);
  }

  .mitushi-product-reviews__inner {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 24px;
  }

  .mitushi-product-reviews__header {
    margin-bottom: 32px;
    text-align: center;
  }

  .mitushi-product-reviews__title {
    font-family: var(--font-display), inherit;
    font-size: clamp(28px, 4vw, 36px);
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #ffffff;
    margin: 0;
  }

  .mitushi-product-reviews__widget {
    background: rgba(255, 255, 255, 0.02);
    border: 1px solid rgba(255, 255, 255, 0.06);
    border-radius: 12px;
    padding: 28px 24px;
  }

  .mitushi-product-reviews__empty {
    text-align: center;
    color: rgba(255, 255, 255, 0.5);
    font-size: 14px;
    line-height: 1.7;
    margin: 0;
  }
</style>

<section
  id="judgeme_product_reviews"
  class="mitushi-product-reviews"
  data-ui-component="Mitushi Product Reviews Section"
>
  <div class="mitushi-product-reviews__inner">
    {%- if section.settings.show_heading -%}
      <header class="mitushi-product-reviews__header">
        <h2 class="mitushi-product-reviews__title">{{ section.settings.heading }}</h2>
      </header>
    {%- endif -%}

    <div class="mitushi-product-reviews__widget mitushi-judgeme-review-widget">
      {%- if section.blocks.size > 0 -%}
        {%- for block in section.blocks -%}
          {% render block %}
        {%- endfor -%}
      {%- elsif product.metafields.judgeme.widget != blank -%}
        <div class="jdgm-widget jdgm-review-widget" data-id="{{ product.id }}">
          {{ product.metafields.judgeme.widget }}
        </div>
      {%- else -%}
        <p class="mitushi-product-reviews__empty">
          Reviews will appear here after Judge.me syncs.
          In Judge.me click <strong>Install Review Widget</strong>, or add the <strong>Review Widget</strong> app block to this section in the theme editor.
        </p>
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Mitushi Product Reviews",
  "tag": "section",
  "class": "mitushi-product-reviews-section",
  "templates": ["product"],
  "settings": [
    {
      "type": "checkbox",
      "id": "show_heading",
      "label": "Show heading",
      "default": true
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Customer Reviews"
    }
  ],
  "blocks": [
    {
      "type": "@app"
    }
  ],
  "presets": [
    {
      "name": "Mitushi Product Reviews"
    }
  ]
}
{% endschema %}
