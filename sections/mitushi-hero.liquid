<style>
  .mitushi-hero {
    position: relative;
    min-height: 92vh;
    width: 100%;
    overflow: hidden;
    background-color: var(--ink);
    color: var(--bone);
    font-family: var(--font-sans);
    display: flex;
    align-items: center;
    perspective: 1400px;
  }

  .mitushi-hero-backdrop {
    position: absolute;
    inset: 0;
    background: radial-gradient(55% 60% at 70% 50%, rgba(204, 19, 42, 0.18) 0%, transparent 70%);
    pointer-events: none;
    will-change: transform;
    transform: translate3d(0, calc(var(--scroll-progress, 0) * 48px), 0);
  }

  .mitushi-hero-grid {
    position: absolute;
    inset: 0;
    opacity: 0.06;
    background-image: linear-gradient(var(--bone) 1px, transparent 1px), linear-gradient(90deg, var(--bone) 1px, transparent 1px);
    background-size: 80px 80px;
    mask-image: radial-gradient(ellipse at center, black 30%, transparent 75%);
    -webkit-mask-image: radial-gradient(ellipse at center, black 30%, transparent 75%);
    pointer-events: none;
    will-change: transform;
    transform: translate3d(0, calc(var(--scroll-progress, 0) * 18px), 0);
  }

  /* Big ghost background text */
  .mitushi-hero-ghost-text {
    pointer-events: none;
    position: absolute;
    inset: 0;
    z-index: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    transform: translate3d(0, calc(var(--scroll-progress, 0) * 72px), 0);
    will-change: transform;
    font-family: var(--font-display);
    font-size: clamp(10rem, 28vw, 26rem);
    line-height: 1;
    color: transparent;
    -webkit-text-stroke: 1px var(--bone);
    opacity: 0.08;
    user-select: none;
  }

  .mitushi-hero-badge-left {
    position: absolute;
    left: 24px;
    top: 24px;
    z-index: 20;
    font-size: 10px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.4em;
    color: rgba(244, 244, 244, 0.6);
  }

  .mitushi-hero-badge-right {
    position: absolute;
    right: 24px;
    top: 24px;
    z-index: 20;
    font-size: 10px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.4em;
    color: rgba(244, 244, 244, 0.6);
  }

  .mitushi-hero-vertical-jp {
    pointer-events: none;
    position: absolute;
    left: 32px;
    top: 50%;
    transform: translate3d(0, calc(-50% + var(--scroll-progress, 0) * 60px), 0);
    will-change: transform;
    z-index: 20;
    font-family: var(--font-jp);
    font-size: 11px;
    letter-spacing: 1em;
    color: rgba(244, 244, 244, 0.4);
    writing-mode: vertical-rl;
    text-orientation: mixed;
    display: none;
  }

  @media (min-width: 1024px) {
    .mitushi-hero-vertical-jp {
      display: block;
    }
  }

  .mitushi-hero-container {
    position: relative;
    z-index: 10;
    width: 100%;
    max-width: 1280px;
    margin: 0 auto;
    padding: 96px 24px 64px;
    display: grid;
    grid-template-columns: 1fr;
    align-items: center;
    gap: 48px;
  }

  @media (min-width: 768px) {
    .mitushi-hero-container {
      grid-template-columns: 1.1fr 0.9fr;
      gap: 64px;
      padding: 128px 32px 64px;
    }
  }

  /* Left Column Copy */
  .mitushi-hero-copy {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    will-change: transform, opacity;
    transform: translate3d(0, calc(var(--scroll-progress, 0) * -90px), 0);
    opacity: calc(1 - var(--scroll-progress, 0) * 1.2);
  }

  .mitushi-hero-live-badge {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    border: 1px solid rgba(244, 244, 244, 0.2);
    background-color: rgba(40, 40, 43, 0.4);
    padding: 6px 16px;
    border-radius: 9999px;
    font-size: 10px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.35em;
    color: rgba(244, 244, 244, 0.7);
    margin-bottom: 24px;
  }

  .mitushi-hero-live-dot {
    height: 6px;
    width: 6px;
    border-radius: 50%;
    background-color: var(--crimson);
    box-shadow: 0 0 10px var(--crimson);
    animation: mitushi-pulse 2s infinite;
  }

  @keyframes mitushi-pulse {
    0%, 100% { opacity: 0.5; }
    50% { opacity: 1; }
  }

  .mitushi-hero-title {
    font-family: var(--font-display);
    line-height: 0.85;
    font-size: clamp(48px, 8vw, 96px);
    text-transform: uppercase;
    margin: 0 0 24px 0;
  }

  .mitushi-hero-title span {
    display: block;
    will-change: transform;
  }

  .mitushi-hero-title .title-line-1 {
    transform: translate3d(0, calc(var(--scroll-progress, 0) * -36px), 0);
  }

  .mitushi-hero-title .title-line-2 {
    color: var(--crimson);
    transform: translate3d(0, calc(var(--scroll-progress, 0) * -90px), 0);
  }

  .mitushi-hero-title .title-line-3 {
    -webkit-text-stroke: 1px var(--bone);
    color: transparent;
    transform: translate3d(0, calc(var(--scroll-progress, 0) * -144px), 0);
  }

  .mitushi-hero-desc {
    max-width: 480px;
    font-size: 15px;
    line-height: 1.6;
    color: rgba(244, 244, 244, 0.7);
    margin: 0 0 32px 0;
  }

  .mitushi-hero-buttons {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 24px;
    margin-bottom: 48px;
  }

  .mitushi-hero-btn-primary {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    background-color: var(--crimson);
    color: var(--bone);
    padding: 16px 28px;
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.3em;
    text-decoration: none;
    transition: all 0.3s ease;
  }

  .mitushi-hero-btn-primary:hover {
    box-shadow: 0 0 30px rgba(204, 19, 42, 0.6);
  }

  .mitushi-hero-btn-primary span {
    transition: transform 0.3s ease;
  }

  .mitushi-hero-btn-primary:hover span {
    transform: translateX(4px);
  }

  /* Stats row */
  .mitushi-hero-stats {
    display: flex;
    align-items: center;
    gap: 32px;
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 0.3em;
    color: rgba(244, 244, 244, 0.5);
  }

  .mitushi-hero-stat-item .stat-num {
    font-family: var(--font-display);
    font-size: 32px;
    color: var(--bone);
    line-height: 1;
    margin-bottom: 4px;
  }

  .mitushi-hero-stat-item .stat-num.crimson {
    color: var(--crimson);
  }

  .mitushi-hero-stats-divider {
    height: 32px;
    width: 1px;
    background-color: rgba(244, 244, 244, 0.15);
  }

  /* Right Column Image & 3D Stage */
  .mitushi-hero-media {
    position: relative;
    width: 100%;
    max-width: 520px;
    margin: 0 auto;
    perspective: 1200px;
  }

  .mitushi-hero-image-wrapper {
    position: relative;
    width: 100%;
    aspect-ratio: 4 / 5;
    transition: transform 0.3s ease-out;
    will-change: transform;
    transform: translate3d(0, calc(var(--scroll-progress, 0) * -60px), 0) rotateX(calc(var(--tilt-y, 0) * -8deg)) rotateY(calc(var(--tilt-x, 0) * 12deg));
    transform-style: preserve-3d;
    z-index: 2;
  }

  .mitushi-hero-red-sun {
    position: absolute;
    left: 50%;
    top: 50%;
    width: 78%;
    height: 78%;
    border-radius: 50%;
    background-color: var(--crimson);
    filter: blur(1px);
    pointer-events: none;
    z-index: 1;
    will-change: transform;
    transform: translate3d(calc(-50% + var(--tilt-x, 0) * -30px), calc(-50% + var(--tilt-y, 0) * -30px), -80px) scale(calc(1 + var(--scroll-progress, 0) * 0.35));
  }

  .mitushi-hero-glow-ring {
    position: absolute;
    left: 50%;
    top: 50%;
    width: 88%;
    height: 88%;
    border-radius: 50%;
    border: 1px solid rgba(204, 19, 42, 0.4);
    pointer-events: none;
    will-change: transform;
    transform: translate(-50%, -50%) translateZ(-40px) scale(calc(1 + var(--scroll-progress, 0) * 0.2));
    box-shadow: 0 0 80px rgba(204, 19, 42, 0.35);
  }

  .mitushi-hero-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    mask-image: linear-gradient(to bottom, black 82%, transparent 100%);
    -webkit-mask-image: linear-gradient(to bottom, black 82%, transparent 100%);
    will-change: transform;
    transform: translateZ(40px) translate3d(calc(var(--tilt-x, 0) * 12px), calc(var(--tilt-y, 0) * 12px), 0);
  }

  /* Angled badges (floating in 3D) */
  .mitushi-hero-badge-float {
    position: absolute;
    z-index: 10;
    background-color: rgba(40, 40, 43, 0.8);
    backdrop-filter: blur(8px);
    border: 1px solid rgba(244, 244, 244, 0.15);
    padding: 12px 16px;
    will-change: transform;
  }

  .mitushi-hero-badge-float.top-right {
    top: 10%;
    right: -16px;
    border-color: rgba(204, 19, 42, 0.6);
    transform: translate3d(calc(var(--tilt-x, 0) * 40px), calc(var(--tilt-y, 0) * 40px), 100px) rotate(6deg);
  }

  .mitushi-hero-badge-float.bottom-left {
    bottom: 10%;
    left: -16px;
    transform: translate3d(calc(var(--tilt-x, 0) * 30px), calc(var(--tilt-y, 0) * 30px), 80px) rotate(-6deg);
  }

  .mitushi-hero-badge-float .badge-label {
    font-size: 9px;
    text-transform: uppercase;
    letter-spacing: 0.3em;
    color: rgba(244, 244, 244, 0.5);
  }

  .mitushi-hero-badge-float.top-right .badge-label {
    color: var(--crimson);
  }

  .mitushi-hero-badge-float .badge-val {
    font-family: var(--font-display);
    font-size: 20px;
    color: var(--bone);
    margin-top: 2px;
  }

  /* Scroll Indicator */
  .mitushi-hero-scroll-indicator {
    pointer-events: none;
    position: absolute;
    bottom: 24px;
    left: 50%;
    transform: translateX(-50%);
    z-index: 20;
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 0.4em;
    color: rgba(244, 244, 244, 0.5);
    opacity: calc(1 - var(--scroll-progress, 0) * 2);
    will-change: opacity;
  }

  .scroll-indicator-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
  }

  .scroll-line {
    display: block;
    height: 32px;
    width: 1px;
    background-color: var(--crimson);
    animation: scroll-line-pulse 2s infinite;
  }

  @keyframes scroll-line-pulse {
    0%, 100% { opacity: 0.3; }
    50% { opacity: 1; }
  }
</style>

<section class="mitushi-hero" id="home">
  <!-- Radial backdrop -->
  <div class="mitushi-hero-backdrop" aria-hidden="true"></div>

  <!-- Grid background -->
  <div class="mitushi-hero-grid" aria-hidden="true"></div>

  <!-- Ghost Text -->
  <div class="mitushi-hero-ghost-text" aria-hidden="true">MITUSHI</div>

  <!-- Corner badges -->
  <div class="mitushi-hero-badge-left">{{ section.settings.badge_left_text | default: 'FW · 26 / Drop 03' }}</div>
  <div class="mitushi-hero-badge-right">{{ section.settings.badge_right_text | default: 'Tokyo — Tel Aviv' }}</div>

  <!-- Japanese vertical text -->
  <div class="mitushi-hero-vertical-jp">{{ section.settings.vertical_jp_text | default: '匠 · 二〇二六' }}</div>

  <div class="mitushi-hero-container">
    <!-- Left Column: Copy -->
    <div class="mitushi-hero-copy">
      {% if section.settings.badge_text != blank %}
        <div class="mitushi-hero-live-badge">
          <span class="mitushi-hero-live-dot"></span>
          {{ section.settings.badge_text }}
        </div>
      {% endif %}
      
      <h1 class="mitushi-hero-title">
        <span class="title-line-1">{{ section.settings.title_line_1 | default: 'Wear the' }}</span>
        <span class="title-line-2">{{ section.settings.title_line_2 | default: 'Legend' }}</span>
        <span class="title-line-3">{{ section.settings.title_line_3 | default: 'In Silence' }}</span>
      </h1>
      
      {% if section.settings.description != blank %}
        <p class="mitushi-hero-desc">
          {{ section.settings.description }}
        </p>
      {% endif %}
      
      <div class="mitushi-hero-buttons">
        <a href="{{ section.settings.button_1_link | default: '/collections/all' }}" class="mitushi-hero-btn-primary">
          {{ section.settings.button_1_label | default: 'Shop the Drop' }} <span>→</span>
        </a>
      </div>

      {% if section.settings.show_stats %}
        <div class="mitushi-hero-stats">
          <div class="mitushi-hero-stat-item">
            <div class="stat-num">{{ section.settings.stat_1_num | default: '03' }}</div>
            <div>{{ section.settings.stat_1_label | default: 'Active Drops' }}</div>
          </div>
          <div class="mitushi-hero-stats-divider"></div>
          <div class="mitushi-hero-stat-item">
            <div class="stat-num">{{ section.settings.stat_2_num | default: '48H' }}</div>
            <div>{{ section.settings.stat_2_label | default: 'Until Restock' }}</div>
          </div>
          <div class="mitushi-hero-stats-divider"></div>
          <div class="mitushi-hero-stat-item">
            <div class="stat-num crimson">{{ section.settings.stat_3_num | default: '夢' }}</div>
            <div>{{ section.settings.stat_3_label | default: 'Dreams FW26' }}</div>
          </div>
        </div>
      {% endif %}
    </div>

    <!-- Right Column: Media (Image & Backdrops) -->
    <div class="mitushi-hero-media">
      <div class="mitushi-hero-image-wrapper">
        <!-- deep red sun backdrop inside 3D stage -->
        <div class="mitushi-hero-red-sun" aria-hidden="true"></div>
        <!-- glow ring inside 3D stage -->
        <div class="mitushi-hero-glow-ring" aria-hidden="true"></div>

        {% if section.settings.hero_image != blank %}
          {% assign hero_img_url = section.settings.hero_image | img_url: '520x650' %}
        {% else %}
          {% assign hero_img_url = 'hero-model.jpg' | asset_url %}
        {% endif %}
        <img
          src="{{ hero_img_url }}"
          alt="Mitushi anime streetwear model"
          width="520"
          height="650"
          class="mitushi-hero-image"
        />

        <!-- Floating Badges in 3D stage -->
        <div class="mitushi-hero-badge-float top-right">
          <div class="badge-label">{{ section.settings.float_badge_2_label | default: 'Limited' }}</div>
          <div class="badge-val">{{ section.settings.float_badge_2_val | default: '/ 300' }}</div>
        </div>
        <div class="mitushi-hero-badge-float bottom-left">
          <div class="badge-label">{{ section.settings.float_badge_1_label | default: 'Drop 03' }}</div>
          <div class="badge-val">{{ section.settings.float_badge_1_val | default: '夢 DREAMS' }}</div>
        </div>
      </div>
    </div>
  </div>

  <!-- Scroll Indicator -->
  <div class="mitushi-hero-scroll-indicator" aria-hidden="true">
    <div class="scroll-indicator-inner">
      <span>Scroll</span>
      <span class="scroll-line"></span>
    </div>
  </div>
</section>

<script>
  (function() {
    const section = document.querySelector('.mitushi-hero');
    if (!section) return;

    // Scroll parallax tracking
    const onScroll = () => {
      const rect = section.getBoundingClientRect();
      const height = rect.height || 1;
      const progress = Math.max(0, Math.min(1, -rect.top / height));
      section.style.setProperty('--scroll-progress', progress);
    };

    onScroll();
    window.addEventListener('scroll', onScroll, { passive: true });

    // 3D tilt tracking
    const media = section.querySelector('.mitushi-hero-media');
    if (media) {
      media.addEventListener('mousemove', (e) => {
        const r = media.getBoundingClientRect();
        const px = (e.clientX - r.left) / r.width - 0.5;
        const py = (e.clientY - r.top) / r.height - 0.5;
        section.style.setProperty('--tilt-x', px);
        section.style.setProperty('--tilt-y', py);
      });

      media.addEventListener('mouseleave', () => {
        section.style.setProperty('--tilt-x', '0');
        section.style.setProperty('--tilt-y', '0');
      });
    }
  })();
</script>

