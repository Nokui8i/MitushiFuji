<style>
  /* FAQ Page Styling overrides */
  .mitushi-faq {
    max-width: 900px !important;
    margin: 40px auto !important;
    padding: 0 20px !important;
  }

  .mitushi-faq details {
    background: rgba(255, 255, 255, 0.02) !important;
    border: 1px solid rgba(255, 255, 255, 0.06) !important;
    border-radius: 8px !important;
    margin-bottom: 16px !important;
    transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1) !important;
    overflow: hidden !important;
  }

  .mitushi-faq details:hover {
    background: rgba(255, 255, 255, 0.04) !important;
    border-color: rgba(204, 19, 42, 0.3) !important;
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.3) !important;
  }

  .mitushi-faq details[open] {
    background: rgba(255, 255, 255, 0.03) !important;
    border-color: var(--crimson) !important;
    box-shadow: 0 0 15px rgba(204, 19, 42, 0.15) !important;
  }

  .mitushi-faq summary {
    padding: 20px 24px !important;
    font-size: 14px !important;
    font-weight: 700 !important;
    text-transform: uppercase !important;
    letter-spacing: 0.15em !important;
    color: #ffffff !important;
    cursor: pointer !important;
    display: flex !important;
    align-items: center !important;
    justify-content: space-between !important;
    user-select: none !important;
    list-style: none !important;
    transition: color 0.3s ease !important;
  }

  .mitushi-faq summary::-webkit-details-marker {
    display: none !important;
  }

  .mitushi-faq summary:hover {
    color: var(--crimson) !important;
  }

  /* Custom expand indicator */
  .mitushi-faq summary::after {
    content: '+' !important;
    font-family: var(--font-sans) !important;
    font-size: 20px !important;
    font-weight: 300 !important;
    color: rgba(255, 255, 255, 0.6) !important;
    transition: transform 0.3s ease, color 0.3s ease !important;
    width: 32px !important;
    height: 32px !important;
    border: 1px solid rgba(255, 255, 255, 0.1) !important;
    border-radius: 50% !important;
    display: flex !important;
    align-items: center !important;
    justify-content: center !important;
  }

  .mitushi-faq details[open] summary::after {
    content: '−' !important; /* Elegant minus sign */
    transform: rotate(180deg) !important;
    color: var(--crimson) !important;
    border-color: var(--crimson) !important;
  }

  .mitushi-faq .mitushi-faq__a,
  .mitushi-faq details > div,
  .mitushi-faq details > p {
    padding: 0 24px 24px 24px !important;
    font-size: 14px !important;
    line-height: 1.8 !important;
    color: rgba(255, 255, 255, 0.7) !important;
    font-family: var(--font-sans) !important;
    margin: 0 !important;
  }

  /* Style main title on page if inside .mitushi-faq wrapper */
  .mitushi-faq h1, 
  .mitushi-faq .mitushi-faq__title {
    font-family: var(--font-display) !important;
    font-size: 42px !important;
    letter-spacing: 0.05em !important;
    text-align: center !important;
    text-transform: uppercase !important;
    color: #ffffff !important;
    margin-bottom: 8px !important;
  }

  /* Style subtitle to be centered and visible (light color) */
  .mitushi-faq > p,
  .mitushi-faq > div > p,
  .mitushi-faq p:first-of-type,
  .mitushi-faq p.mitushi-faq__subtitle,
  .mitushi-faq__subtitle,
  .mitushi-faq .mitushi-faq__subtitle,
  .rte .mitushi-faq__subtitle {
    text-align: center !important;
    color: #ffffff !important;
    font-size: 16px !important;
    margin: 0 auto 40px auto !important;
    letter-spacing: 0.05em !important;
    display: block !important;
    width: 100% !important;
    opacity: 1 !important;
  }

  /* Remove any nested arrows or buttons inside the summary, leaving only our custom '+' */
  .mitushi-faq summary button,
  .mitushi-faq summary svg,
  .mitushi-faq summary i,
  .mitushi-faq summary .icon,
  .mitushi-faq summary [class*="icon"],
  .mitushi-faq summary [class*="arrow"],
  .mitushi-faq summary [class*="chevron"],
  .mitushi-faq__chev,
  .mitushi-faq .mitushi-faq__chev,
  .rte .mitushi-faq__chev {
    display: none !important;
  }

  /* ==========================================
     MITUSHI LEGAL (Copyrights, Privacy, Terms) Page overrides
     ========================================== */
  .mitushi-legal,
  .rte .mitushi-legal {
    max-width: 800px !important;
    margin: 40px auto !important;
    padding: 0 20px !important;
    color: rgba(255, 255, 255, 0.7) !important;
    font-family: var(--font-body-family), system-ui, -apple-system, sans-serif !important;
  }

  .mitushi-legal h1,
  .rte .mitushi-legal h1 {
    font-family: var(--font-heading-family), inherit !important;
    font-weight: 800 !important;
    letter-spacing: 0.05em !important;
    text-transform: uppercase !important;
    font-size: clamp(32px, 4vw, 42px) !important;
    color: #ffffff !important;
    text-align: center !important;
    margin: 0 0 24px 0 !important;
  }

  .mitushi-legal h2,
  .rte .mitushi-legal h2 {
    font-family: var(--font-heading-family), inherit !important;
    font-weight: 700 !important;
    font-size: 18px !important;
    text-transform: uppercase !important;
    letter-spacing: 0.1em !important;
    color: var(--crimson, #cc132a) !important;
    margin: 40px 0 16px 0 !important;
    border-bottom: 1px solid rgba(255, 255, 255, 0.08) !important;
    padding-bottom: 8px !important;
  }

  .mitushi-legal p,
  .rte .mitushi-legal p {
    font-size: 15px !important;
    line-height: 1.8 !important;
    color: rgba(255, 255, 255, 0.75) !important;
    margin: 0 0 16px 0 !important;
  }

  .mitushi-legal strong,
  .rte .mitushi-legal strong {
    color: #ffffff !important;
    font-weight: 600 !important;
  }

  .mitushi-legal .divider,
  .rte .mitushi-legal .divider {
    margin: 24px 0 !important;
    height: 1px !important;
    background: rgba(255, 255, 255, 0.1) !important;
  }

  /* Default page RTE on dark Mitushi storefront */
  .s-content.rte {
    color: rgba(255, 255, 255, 0.75) !important;
    font-size: 15px !important;
    line-height: 1.8 !important;
    max-width: 800px !important;
  }

  .s-content.rte p {
    color: rgba(255, 255, 255, 0.75) !important;
    margin: 0 0 16px 0 !important;
  }

  .s-content.rte a {
    color: #cc132a !important;
  }
</style>

<div class="section color-{{ section.settings.color_scheme }} {{ section.settings.remove_padding_top | replace: 'true', 'section-top-zero' | replace: section.settings.remove_padding_top, '' }} {{ section.settings.remove_padding_bottom | replace: 'true', 'section-bottom-zero' | replace: section.settings.remove_padding_bottom, '' }} {% if section.settings.show_page_title == false and page.content == blank %}pb-0{% endif %}" data-ui-component="Main Page Section">
  <div class="ctnr">
    {% if section.settings.show_page_title %}
      {% render 'section-header',
        heading: page.title,
        content_align: 'ta-center'
      %}
    {% endif %}
    <div class="s-content m-auto rte" style="--w-md:10">
      {{ page.content }}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "t:general.page",
  "settings": [
    {
      "type": "header",
      "content": "t:general.general"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:general.color_scheme",
      "default": "accent-1"
    },
    {
      "type": "checkbox",
      "id": "show_page_title",
      "label": "t:general.show_page_title",
      "default": true
    },
    {
      "type": "header",
      "content": "t:general.layout"
    },
    {
      "type": "checkbox",
      "id": "remove_padding_top",
      "label": "t:general.remove_padding_top",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "remove_padding_bottom",
      "label": "t:general.remove_padding_bottom",
      "default": false
    }
  ]
}
{% endschema %}
