<style>
  .mitushi-product-carousel-wrapper {
    background-color: #28282B !important;
    color: #f7f7f8 !important;
    padding: 0 !important;
    display: block;
    width: 100%;
  }

</style>
{% render 'mitushi-carousel-styles' %}

<div class="mitushi-product-carousel-wrapper" data-ui-component="Featured Product Carousel Section">
  <section class="mitushi-product-carousel">
    <div class="mitushi-carousel-container">
      <div class="mitushi-carousel-header">
        <div class="mitushi-carousel-title-group">
          <div>/ 04 — Curated drops</div>
          <h2>{{ section.settings.heading }}</h2>
        </div>
        <div class="mitushi-carousel-controls">
          <button class="mitushi-carousel-btn" aria-label="Previous" onclick="scrollFeaturedCarousel(this, -1)">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16">
              <path d="M15 19l-7-7 7-7"></path>
            </svg>
          </button>
          <button class="mitushi-carousel-btn" aria-label="Next" onclick="scrollFeaturedCarousel(this, 1)">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16">
              <path d="M9 5l7 7-7 7"></path>
            </svg>
          </button>
        </div>
      </div>
      <div class="mitushi-carousel-track">
        {%- for prod_obj in section.settings.product_list -%}
          {%- liquid
            assign index_mod = forloop.index
            assign prod_name = prod_obj.title
            assign prod_tag = prod_obj.collections.first.title | default: prod_obj.vendor
            assign prod_price = prod_obj.price | money_without_trailing_zeros
            assign prod_url = prod_obj.url
            assign variant_id = prod_obj.selected_or_first_available_variant.id

            if prod_obj.featured_image != blank
              assign front_img = prod_obj.featured_image | img_url: '360x450'
            else
              if index_mod == 1 or index_mod == 5
                assign front_img = 'product-shirt-1.jpg' | asset_url
              elsif index_mod == 2
                assign front_img = 'product-shirt-2.jpg' | asset_url
              elsif index_mod == 3
                assign front_img = 'product-tank-1.jpg' | asset_url
              else
                assign front_img = 'product-shorts-1.jpg' | asset_url
              endif
            endif

            if prod_obj.images[1] != blank
              assign back_img = prod_obj.images[1] | img_url: '360x450'
            elsif prod_obj.featured_image != blank
              assign back_img = prod_obj.featured_image | img_url: '360x450'
            else
              if index_mod == 1 or index_mod == 5
                assign back_img = 'product-shirt-1-back.jpg' | asset_url
              elsif index_mod == 2
                assign back_img = 'product-shirt-2-back.jpg' | asset_url
              elsif index_mod == 3
                assign back_img = 'product-tank-1-back.jpg' | asset_url
              else
                assign back_img = 'product-shorts-1-back.jpg' | asset_url
              endif
            endif

            assign prod_badge = ''
            if prod_obj.compare_at_price > prod_obj.price
              assign prod_badge = 'SALE'
            else
              for tag in prod_obj.tags
                assign tag_down = tag | downcase
                if tag_down contains 'new'
                  assign prod_badge = 'NEW'
                  break
                elsif tag_down contains 'hot'
                  assign prod_badge = 'HOT'
                  break
                elsif tag_down contains 'drop'
                  assign prod_badge = tag | uppercase
                  break
                endif
              endfor
            endif
          -%}

          <article class="mitushi-product-card">
            <div class="mitushi-product-image-wrapper">
              <a href="{{ prod_url }}">
                <img
                  src="{{ front_img }}"
                  alt="{{ prod_name | escape }}"
                  loading="lazy"
                  class="mitushi-product-front"
                />
                <img
                  src="{{ back_img }}"
                  alt="{{ prod_name | escape }} (back)"
                  loading="lazy"
                  class="mitushi-product-back"
                />
              </a>
              {% comment %}
              {% if prod_badge != blank %}
                <span class="mitushi-product-badge">{{ prod_badge }}</span>
              {% endif %}
              {% endcomment %}
              


              <div class="mitushi-product-cta">
                <div class="mitushi-product-cta-content">
                  <div class="mitushi-product-cta-info">
                    <div class="mitushi-product-cta-label">Quick add</div>
                    <div class="mitushi-product-price">{{ prod_price }}</div>
                  </div>
                  <button class="mitushi-product-cart-btn" {% if variant_id != blank %}onclick="addProductToCart('{{ variant_id }}')"{% endif %}>Add to cart</button>
                </div>
              </div>
            </div>

            <div class="mitushi-product-info">
              <div class="mitushi-product-details">
                <h3 class="mitushi-product-name">
                  <a href="{{ prod_url }}" style="color: inherit; text-decoration: none;">{{ prod_name }}</a>
                </h3>
                <p class="mitushi-product-tag">{{ prod_tag }}</p>
              </div>
              <div class="mitushi-product-info-price">{{ prod_price }}</div>
            </div>
          </article>
        {%- endfor -%}
      </div>
    </div>
  </section>
</div>

<script>
  function scrollFeaturedCarousel(button, direction) {
    const section = button.closest('.mitushi-product-carousel');
    const track = section.querySelector('.mitushi-carousel-track');
    if (!track) return;
    const card = track.querySelector('.mitushi-product-card');
    const gap = 12;
    const amount = card ? card.offsetWidth + gap : 300;
    track.scrollBy({ left: direction * amount, behavior: 'smooth' });
  }

  if (typeof window.addProductToCart !== 'function') {
    window.addProductToCart = function(variantId) {
      if (!variantId) return;
      const formData = {
        'items': [{
          'id': variantId,
          'quantity': 1
        }]
      };
      fetch((window.Shopify && window.Shopify.routes && window.Shopify.routes.root) ? window.Shopify.routes.root + 'cart/add.js' : '/cart/add.js', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json'
        },
        body: JSON.stringify(formData)
      })
      .then(response => response.json())
      .then(data => {
        console.log('Product added successfully', data);
        fetch(((window.Shopify && window.Shopify.routes && window.Shopify.routes.root) ? window.Shopify.routes.root + 'cart.js' : '/cart.js'))
        .then(res => res.json())
        .then(cart => {
          const badges = document.querySelectorAll('.mitushi-cart-badge, .header__cart-count');
          badges.forEach(badge => {
            badge.textContent = cart.item_count;
          });
          document.dispatchEvent(new CustomEvent('cart:updated', {
            detail: { cart: cart }
          }));
        });
      })
      .catch((error) => {
        console.error('Error adding to cart:', error);
      });
    }
  }
</script>

