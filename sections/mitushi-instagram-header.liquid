{%- render 'mitushi-instafeed-section-styles', section: section -%}

<div
  class="section mitushi-apps-section-wrap mitushi-apps-section-wrap--header-only {{ section.settings.remove_padding_top | replace: 'true', 'section-top-zero' | replace: section.settings.remove_padding_top, '' }} color-{{- section.settings.color_scheme -}}"
  data-ui-component="Mitushi Instagram Header"
>
  <div class="mitushi-apps-section w-100 mitushi-apps-section--instafeed mitushi-apps-section--header-only">
    {%- if section.settings.show_hero_background -%}
      <div class="mitushi-apps-backdrop" aria-hidden="true"></div>
      <div class="mitushi-apps-grid" aria-hidden="true"></div>
      {%- if section.settings.ghost_text != blank -%}
        <div class="mitushi-apps-ghost" aria-hidden="true">{{ section.settings.ghost_text }}</div>
      {%- endif -%}
      {%- if section.settings.vertical_jp != blank -%}
        <div class="mitushi-apps-vertical-jp" aria-hidden="true">{{ section.settings.vertical_jp }}</div>
      {%- endif -%}
    {%- endif -%}

    <div class="mitushi-apps-container">
      {%- if section.settings.show_section_header -%}
        <header class="mitushi-apps-header mitushi-apps-header--instafeed">
          <div class="mitushi-apps-title-group">
            {%- if section.settings.subheading != blank -%}
              <p class="mitushi-apps-eyebrow mitushi-apps-eyebrow--crimson">{{ section.settings.subheading }}</p>
            {%- endif -%}
            {%- if section.settings.heading != blank -%}
              <h2 class="mitushi-apps-heading">{{ section.settings.heading }}</h2>
            {%- endif -%}
          </div>
          {%- assign instagram_url = section.settings.instagram_url | default: settings.social_instagram_link -%}
          {%- if section.settings.show_instagram_link and instagram_url != blank -%}
            {%- assign cta_style = section.settings.cta_style | default: 'split' -%}
            <a
              class="mitushi-ig-cta mitushi-ig-cta--{{ cta_style }}"
              href="{{ instagram_url }}"
              target="_blank"
              rel="noopener noreferrer"
            >
              <span class="mitushi-ig-cta__label">
                <span class="mitushi-ig-cta__label-desktop">{{ section.settings.instagram_link_label | default: 'Follow on Instagram' }}</span>
                <span class="mitushi-ig-cta__label-mobile">{{ section.settings.instagram_link_label_short | default: 'Follow' }}</span>
              </span>
              <span class="mitushi-ig-cta__icon" aria-hidden="true">
                {%- if cta_style == 'split' -%}
                  <svg class="mitushi-ig-cta__ig" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75">
                    <rect x="3" y="3" width="18" height="18" rx="5"/>
                    <circle cx="12" cy="12" r="4"/>
                    <circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none"/>
                  </svg>
                {%- else -%}
                  <span class="mitushi-ig-cta__arrow">→</span>
                {%- endif -%}
              </span>
            </a>
          {%- endif -%}
        </header>
      {%- endif -%}
    </div>
  </div>
</div>

<style>
  #shopify-section-{{ section.id }} .mitushi-apps-section--header-only {
    padding-bottom: 24px;
  }

  #shopify-section-{{ section.id }} .mitushi-apps-section-wrap--header-only {
    border-top: none !important;
    border-bottom: none !important;
  }
</style>

{% schema %}
{
  "name": "Mitushi Instagram header",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:general.color_scheme",
      "default": "scheme-1"
    },
    {
      "type": "checkbox",
      "id": "show_section_header",
      "label": "Show section header",
      "default": true
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Eyebrow",
      "default": "/ 03 — インスタグラム"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "From Instagram"
    },
    {
      "type": "checkbox",
      "id": "show_instagram_link",
      "label": "Show Instagram link",
      "default": true
    },
    {
      "type": "url",
      "id": "instagram_url",
      "label": "Instagram profile URL"
    },
    {
      "type": "text",
      "id": "instagram_link_label",
      "label": "Instagram link text (desktop)",
      "default": "Follow on Instagram"
    },
    {
      "type": "text",
      "id": "instagram_link_label_short",
      "label": "Instagram link text (mobile)",
      "default": "Follow"
    },
    {
      "type": "select",
      "id": "cta_style",
      "label": "Button style",
      "options": [
        { "value": "split", "label": "Split panel + IG icon" },
        { "value": "solid", "label": "Solid block (like hero)" },
        { "value": "minimal", "label": "Minimal underline" }
      ],
      "default": "split"
    },
    {
      "type": "checkbox",
      "id": "show_hero_background",
      "label": "Show grid and crimson glow (like hero)",
      "default": true
    },
    {
      "type": "text",
      "id": "ghost_text",
      "label": "Background ghost text",
      "default": "FEED"
    },
    {
      "type": "text",
      "id": "vertical_jp",
      "label": "Vertical side text (desktop)",
      "default": "ミツシ・フィード"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 80
    },
    {
      "type": "checkbox",
      "id": "remove_padding_top",
      "default": true,
      "label": "t:general.remove_padding_top"
    }
  ],
  "presets": [
    {
      "name": "Mitushi Instagram header"
    }
  ]
}
{% endschema %}
