<style>
  .mitushi-footer {
    position: relative;
    border-top: 1px solid rgba(255, 255, 255, 0.1);
    background-color: var(--ink);
    padding-top: 80px;
    padding-bottom: 40px;
  }

  .mitushi-footer-container {
    margin: 0 auto;
    max-width: 1400px;
    padding: 0 24px;
  }

  .mitushi-footer-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 48px;
  }

  @media (min-width: 768px) {
    .mitushi-footer-grid {
      grid-template-columns: repeat(12, 1fr);
    }
  }

  .mitushi-footer-brand {
    grid-column: span 1;
  }

  @media (min-width: 768px) {
    .mitushi-footer-brand {
      grid-column: span 4;
    }
  }

  .mitushi-footer-logo-wrapper {
    position: relative;
    display: inline-block;
  }

  .mitushi-footer-logo-glow {
    position: absolute;
    left: -12px;
    top: 50%;
    transform: translateY(-50%);
    width: 64px;
    height: 64px;
    border-radius: 50%;
    background-color: #cc132a;
    filter: blur(12px);
    opacity: 0.7;
  }

  .mitushi-footer-logo {
    position: relative;
    height: 56px;
    width: auto;
    filter: brightness(2.2) contrast(1.25) drop-shadow(0 0 10px rgba(204, 19, 42, 0.4));
  }

  .mitushi-footer-description {
    margin-top: 24px;
    max-width: 320px;
    font-family: var(--font-sans);
    font-size: 14px;
    line-height: 1.6;
    color: rgba(255, 255, 255, 0.7);
  }

  .mitushi-footer-social {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-top: 24px;
  }

  .mitushi-footer-social-link {
    display: grid;
    place-items: center;
    width: 44px;
    height: 44px;
    border: none;
    background: transparent;
    text-decoration: none;
    transition: transform 0.25s ease, filter 0.25s ease;
  }

  .mitushi-footer-social-link:hover {
    transform: translateY(-2px) scale(1.06);
    filter: drop-shadow(0 6px 16px rgba(204, 19, 42, 0.35));
  }

  .mitushi-footer-social-icon {
    width: 40px;
    height: 40px;
    object-fit: contain;
    display: block;
    /* Uploaded 3D icons have black bg — screen removes it on dark footer */
    mix-blend-mode: screen;
  }

  .mitushi-footer-links {
    grid-column: span 1;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 32px;
  }

  @media (min-width: 768px) {
    .mitushi-footer-links {
      grid-column: span 4;
      grid-template-columns: 1fr 1fr;
    }
  }

  .mitushi-footer-link-group h4 {
    margin-bottom: 24px;
    font-family: var(--font-display);
    font-size: 20px;
    font-weight: 400;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: #cc132a;
  }

  .mitushi-footer-link-group ul {
    display: flex;
    flex-direction: column;
    gap: 12px;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .mitushi-footer-link-group li {
    font-family: var(--font-sans);
    font-size: 14px;
    color: rgba(255, 255, 255, 0.8);
  }

  .mitushi-footer-link-group a {
    color: rgba(255, 255, 255, 0.8);
    text-decoration: none;
    transition: color 0.3s;
  }

  .mitushi-footer-link-group a:hover {
    color: #cc132a;
  }

  .mitushi-footer-newsletter {
    grid-column: span 1;
  }

  @media (min-width: 768px) {
    .mitushi-footer-newsletter {
      grid-column: span 4;
    }
  }

  .mitushi-footer-newsletter h4 {
    margin-bottom: 24px;
    font-family: var(--font-display);
    font-size: 20px;
    font-weight: 400;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: #cc132a;
  }

  .mitushi-footer-newsletter-desc {
    margin-bottom: 20px;
    font-family: var(--font-sans);
    font-size: 14px;
    line-height: 1.6;
    color: rgba(255, 255, 255, 0.7);
  }

  .mitushi-footer-form {
    display: flex;
    border: 1px solid rgba(255, 255, 255, 0.2);
    transition: border-color 0.3s;
  }

  .mitushi-footer-form:focus-within {
    border-color: #cc132a;
  }

  .mitushi-footer-input {
    flex: 1;
    background-color: transparent;
    padding: 12px 16px;
    font-family: var(--font-sans);
    font-size: 14px;
    color: #f7f7f8;
    border: none;
    outline: none;
  }

  .mitushi-footer-input::placeholder {
    color: rgba(255, 255, 255, 0.4);
  }

  .mitushi-footer-submit {
    background-color: #cc132a;
    padding: 12px 20px;
    color: #f7f7f8;
    border: none;
    cursor: pointer;
    transition: all 0.3s;
    display: grid;
    place-items: center;
  }

  .mitushi-footer-submit:hover {
    background-color: #ff1a3a;
  }

  .mitushi-footer-newsletter-legal {
    margin-top: 12px;
    font-family: var(--font-jp);
    font-size: 11px;
    letter-spacing: 0.2em;
    color: rgba(255, 255, 255, 0.4);
  }

  .mitushi-footer-brandmark-wrapper {
    position: relative;
    margin-top: 80px;
    overflow: hidden;
    border-top: 1px solid rgba(255, 255, 255, 0.1);
    padding-top: 40px;
  }

  .mitushi-footer-brandmark {
    font-family: var(--font-display);
    font-size: clamp(80px, 18vw, 280px);
    line-height: 1;
    user-select: none;
    color: transparent;
    -webkit-text-stroke: 1px rgba(255, 255, 255, 0.15);
    letter-spacing: 0.05em;
  }

  .mitushi-footer-bottom {
    margin-top: 24px;
    display: flex;
    flex-direction: column;
    gap: 12px;
    font-family: var(--font-sans);
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.3em;
    color: rgba(255, 255, 255, 0.5);
  }

  @media (min-width: 768px) {
    .mitushi-footer-bottom {
      flex-direction: row;
      justify-content: space-between;
      align-items: center;
    }
  }

  .mitushi-footer-bottom-links {
    display: flex;
    gap: 24px;
  }

  .mitushi-footer-bottom-links a {
    color: rgba(255, 255, 255, 0.5);
    text-decoration: none;
    transition: color 0.3s;
  }

  .mitushi-footer-bottom-links a:hover {
    color: #cc132a;
  }

  @media (max-width: 767px) {
    .mitushi-footer {
      padding-top: 56px;
    }

    .mitushi-footer-container {
      padding-inline: 1.25rem;
    }

    .mitushi-footer-grid {
      gap: 40px;
    }

    .mitushi-footer-brand {
      display: flex;
      flex-direction: column;
      align-items: center;
      text-align: center;
    }

    .mitushi-footer-logo-wrapper {
      margin-inline: auto;
    }

    .mitushi-footer-description {
      max-width: 28rem;
      margin-inline: auto;
    }

    .mitushi-footer-social {
      justify-content: center;
    }

    .mitushi-footer-links {
      width: 100%;
      max-width: 20rem;
      margin-inline: auto;
      justify-content: center;
      text-align: center;
    }

    .mitushi-footer-link-group ul {
      align-items: center;
    }

    .mitushi-footer-newsletter {
      display: flex;
      flex-direction: column;
      align-items: center;
      text-align: center;
      width: 100%;
    }

    .mitushi-footer-newsletter-desc {
      max-width: 28rem;
    }

    .mitushi-footer-form {
      width: 100%;
      max-width: 22rem;
    }

    .mitushi-footer-newsletter-legal {
      text-align: center;
    }

    .mitushi-footer-brandmark-wrapper {
      margin-top: 56px;
      text-align: center;
    }

    .mitushi-footer-brandmark {
      display: inline-block;
      width: 100%;
      text-align: center;
    }

    .mitushi-footer-bottom {
      text-align: center;
      align-items: center;
    }

    .mitushi-footer-bottom-links {
      flex-wrap: wrap;
      justify-content: center;
      gap: 12px 20px;
    }
  }
</style>

<footer class="mitushi-footer" id="contact">
  <div class="mitushi-footer-container">
    <div class="mitushi-footer-grid">
      <!-- Brand -->
      <div class="mitushi-footer-brand">
        <div class="mitushi-footer-logo-wrapper">
          <span class="mitushi-footer-logo-glow" aria-hidden="true"></span>
          {% if section.settings.logo != blank %}
            {% assign footer_logo_url = section.settings.logo | img_url: '240x120' %}
          {% else %}
            {% assign footer_logo_url = 'mitushi-logo.png' | asset_url %}
          {% endif %}
          <img
            src="{{ footer_logo_url }}"
            alt="Mitushi"
            class="mitushi-footer-logo"
            width="220"
            height="56"
            style="height: 56px; width: auto; filter: brightness(2.2) contrast(1.25);"
          />
        </div>
        <p class="mitushi-footer-description">
          {{ section.settings.description }}
        </p>
        {%- liquid
          assign footer_facebook_url = settings.social_facebook_link
          assign footer_instagram_url = settings.social_instagram_link
          assign footer_tiktok_url = settings.social_tiktok_link
          if section.settings.facebook_url != blank
            assign footer_facebook_url = section.settings.facebook_url
          endif
          if section.settings.instagram_url != blank
            assign footer_instagram_url = section.settings.instagram_url
          endif
          if section.settings.tiktok_url != blank
            assign footer_tiktok_url = section.settings.tiktok_url
          endif
        -%}
        <div class="mitushi-footer-social">
          {%- if footer_facebook_url != blank and footer_facebook_url != '#' -%}
            <a href="{{ footer_facebook_url }}" class="mitushi-footer-social-link" aria-label="Facebook" target="_blank" rel="noopener noreferrer">
              <img
                src="{{ 'mitushi-social-facebook.png' | asset_url }}"
                alt=""
                class="mitushi-footer-social-icon"
                width="40"
                height="40"
                loading="lazy"
              >
            </a>
          {%- endif -%}
          {%- if footer_instagram_url != blank and footer_instagram_url != '#' -%}
            <a href="{{ footer_instagram_url }}" class="mitushi-footer-social-link" aria-label="Instagram" target="_blank" rel="noopener noreferrer">
              <img
                src="{{ 'mitushi-social-instagram.png' | asset_url }}"
                alt=""
                class="mitushi-footer-social-icon"
                width="40"
                height="40"
                loading="lazy"
              >
            </a>
          {%- endif -%}
          {%- if footer_tiktok_url != blank and footer_tiktok_url != '#' -%}
            <a href="{{ footer_tiktok_url }}" class="mitushi-footer-social-link" aria-label="TikTok" target="_blank" rel="noopener noreferrer">
              <img
                src="{{ 'mitushi-social-tiktok.png' | asset_url }}"
                alt=""
                class="mitushi-footer-social-icon"
                width="40"
                height="40"
                loading="lazy"
              >
            </a>
          {%- endif -%}
        </div>
      </div>

      <!-- Links -->
      <div class="mitushi-footer-links">
        <div class="mitushi-footer-link-group">
          {%- assign footer_menu_1 = linklists[section.settings.menu_1] -%}
          <h4>{{ footer_menu_1.title | default: 'Shop' }}</h4>
          <ul>
            {%- if footer_menu_1.links != blank -%}
              {%- for link in footer_menu_1.links -%}
                <li><a href="{{ link.url }}">{{ link.title }}</a></li>
              {%- endfor -%}
            {%- else -%}
              {%- for collection in collections -%}
                {%- unless collection.handle == 'all' or collection.handle == 'frontpage' -%}
                  <li><a href="{{ collection.url }}">{{ collection.title }}</a></li>
                {%- endunless -%}
              {%- endfor -%}
              <li><a href="{{ routes.all_products_collection_url }}">All products</a></li>
            {%- endif -%}
          </ul>
        </div>
        <div class="mitushi-footer-link-group">
          {%- assign footer_menu_2 = linklists[section.settings.menu_2] -%}
          <h4>{{ footer_menu_2.title | default: 'Help' }}</h4>
          <ul>
            {%- if footer_menu_2.links != blank -%}
              {%- for link in footer_menu_2.links -%}
                <li><a href="{{ link.url }}">{{ link.title }}</a></li>
              {%- endfor -%}
            {%- else -%}
              <li><a href="/pages/contact">Contact</a></li>
              <li><a href="/pages/faq">FAQ</a></li>
              <li><a href="/pages/reviews">REVIEWS</a></li>
              <li><a href="/pages/copyrights">Copyrights</a></li>
              <li><a href="/pages/data-sharing-opt-out">Your Privacy Choices</a></li>
            {%- endif -%}
          </ul>
        </div>
      </div>

      <!-- Newsletter -->
      <div class="mitushi-footer-newsletter">
        <h4>Join the drop list</h4>
        <p class="mitushi-footer-newsletter-desc">
          {{ section.settings.newsletter_text }}
        </p>
        {% form 'customer', id: 'mitushi-footer-newsletter', class: 'mitushi-footer-form' %}
          <input type="hidden" name="contact[tags]" value="newsletter">
          <input
            type="email"
            name="contact[email]"
            placeholder="{{ 'general.newsletter.label' | t | default: 'Email' }}"
            class="mitushi-footer-input"
            autocomplete="email"
            required
          />
          <button type="submit" class="mitushi-footer-submit" aria-label="{{ 'general.newsletter.button_label' | t | default: 'Subscribe' }}">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="18" height="18">
              <path d="M5 12h14M12 5l7 7-7 7"/>
            </svg>
          </button>
        {% endform %}
        <p class="mitushi-footer-newsletter-legal">限定ドロップ · ミツシ・コミュニティへようこそ</p>
      </div>
    </div>

    <!-- Giant Brandmark -->
    <div class="mitushi-footer-brandmark-wrapper">
      <div class="mitushi-footer-brandmark">
        MITUSHI
      </div>
    </div>

    <!-- Bottom metadata -->
    <div class="mitushi-footer-bottom">
      <div>© {{ 'now' | date: "%Y" }} Mitushi Studio · All rights reserved</div>
      <div class="mitushi-footer-bottom-links">
        {%- assign footer_menu_bottom = linklists[section.settings.menu_bottom] -%}
        {%- if footer_menu_bottom.links != blank -%}
          {%- for link in footer_menu_bottom.links -%}
            <a href="{{ link.url }}">{{ link.title }}</a>
          {%- endfor -%}
        {%- else -%}
          <a href="/policies/shipping-policy">Shipping Policy</a>
          <a href="/policies/refund-policy">Refund Policy</a>
          <a href="/policies/privacy-policy">Privacy Policy</a>
          <a href="/policies/terms-of-service">Terms of Service</a>
          <a href="/pages/copyrights">Copyrights</a>
          <a href="/pages/data-sharing-opt-out">Your Privacy Choices</a>
          <a href="/pages/reviews">REVIEWS</a>
        {%- endif -%}
      </div>
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "Footer",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Brand Description",
      "default": "Premium anime streetwear, crafted in limited drops. Tokyo silhouettes, luxury construction, worn in silence."
    },
    {
      "type": "text",
      "id": "facebook_url",
      "label": "Facebook URL",
      "info": "Leave empty to use the Facebook link from Theme settings → Social media."
    },
    {
      "type": "text",
      "id": "instagram_url",
      "label": "Instagram URL",
      "info": "Leave empty to use the Instagram link from Theme settings → Social media."
    },
    {
      "type": "text",
      "id": "tiktok_url",
      "label": "TikTok URL",
      "info": "Leave empty to use the TikTok link from Theme settings → Social media."
    },
    {
      "type": "textarea",
      "id": "newsletter_text",
      "label": "Newsletter Description",
      "default": "First access to releases, exclusive sizes, and members-only fits."
    },
    {
      "type": "link_list",
      "id": "menu_1",
      "label": "First Link List (e.g. Shop)"
    },
    {
      "type": "link_list",
      "id": "menu_2",
      "label": "Second Link List (e.g. Help)",
      "default": "footer"
    },
    {
      "type": "link_list",
      "id": "menu_bottom",
      "label": "Bottom Link List (e.g. Policies)"
    }
  ],
  "presets": [
    {
      "name": "Footer"
    }
  ]
}
{% endschema %}
