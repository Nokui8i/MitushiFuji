{% comment %}
Mitushi Header Section
Combines a collapsible announcement bar with a sticky header.
{% endcomment %}

<div class="mitushi-header-section">
  <style>
    .mitushi-header-section {
      background: var(--ink);
      color: #f7f7f8;
      font-family: var(--font-sans);
    }

    .mitushi-announcement {
      overflow: hidden;
      background: #cc132a;
      color: #fff;
      transition: height 0.5s ease-out, opacity 0.5s ease-out;
      height: 36px;
      opacity: 1;
    }

    .mitushi-announcement-inner {
      display: flex;
      align-items: center;
      height: 36px;
      overflow: hidden;
      white-space: nowrap;
    }

    .mitushi-marquee {
      display: flex;
      align-items: center;
      gap: 4rem;
      padding-left: 2rem;
      font-size: 11px;
      font-weight: 600;
      letter-spacing: 0.32em;
      text-transform: uppercase;
      animation: mitushi-marquee 18s linear infinite;
    }

    .mitushi-marquee span {
      display: inline-flex;
      align-items: center;
      gap: 1rem;
    }

    .mitushi-marquee span[aria-hidden] {
      opacity: 0.6;
    }

    @keyframes mitushi-marquee {
      0% { transform: translateX(0); }
      100% { transform: translateX(-50%); }
    }

    .mitushi-sticky-header {
      border-bottom: 1px solid transparent;
      transition: all 0.3s ease;
      background: #28282B;
    }

    .mitushi-sticky-header.scrolled {
      background: rgba(40, 40, 43, 0.88);
      backdrop-filter: blur(22px);
      -webkit-backdrop-filter: blur(22px);
    }

    .shopify-section-group-header-group,
    #shopify-section-mitushi-header,
    div[id*="mitushi-header"] {
      position: sticky;
      top: 0;
      z-index: 100;
    }

    .mitushi-sticky-header.scrolled {
      border-color: rgba(255, 255, 255, 0.08);
      padding-block: 8px;
    }

    .mitushi-sticky-header:not(.scrolled) {
      padding-block: 12px;
    }

    .mitushi-header-inner {
      max-width: 1400px;
      margin: 0 auto;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 3rem;
      padding: 0 2rem;
    }

    .mitushi-logo-link {
      position: relative;
      display: inline-flex;
      align-items: center;
      text-decoration: none;
      flex-shrink: 0;
    }

    .mitushi-logo-glow {
      position: absolute;
      left: -12px;
      top: 50%;
      transform: translateY(-50%);
      width: 64px;
      height: 64px;
      border-radius: 50%;
      background-color: #cc132a;
      filter: blur(12px);
      opacity: 0.7;
    }

    .mitushi-logo-image {
      position: relative;
      height: 56px;
      width: auto;
      display: block;
      filter: brightness(2.2) contrast(1.25);
      max-width: 200px;
    }

    .mitushi-nav {
      display: none;
      align-items: center;
      gap: 0.25rem;
    }

    @media (min-width: 768px) {
      .md\:flex {
        display: flex;
      }

      .mitushi-nav {
        display: flex;
      }
    }

    .mitushi-nav-item {
      position: relative;
    }

    .mitushi-nav-link {
      display: inline-flex;
      align-items: center;
      gap: 0.25rem;
      padding: 0.75rem 1.25rem;
      font-size: 11px;
      font-weight: 500;
      text-transform: uppercase;
      letter-spacing: 0.28em;
      color: rgba(255, 255, 255, 0.8);
      text-decoration: none;
      transition: color 0.2s ease;
    }

    .mitushi-nav-link.active {
      color: #cc132a;
    }

    .mitushi-nav-link:hover {
      color: #f7f7f8;
    }

    .mitushi-nav-link.active::after {
      content: '';
      position: absolute;
      bottom: 4px;
      left: 50%;
      width: 24px;
      height: 1px;
      transform: translateX(-50%);
      background: #cc132a;
    }

    .mitushi-dropdown-trigger {
      position: absolute;
      left: 50%;
      top: 100%;
      transform: translateX(-50%);
      padding-top: 0.5rem;
      visibility: hidden;
      opacity: 0;
      transition: opacity 0.2s ease;
      pointer-events: none;
    }

    .mitushi-nav-item:hover .mitushi-dropdown-trigger {
      visibility: visible;
      opacity: 1;
      pointer-events: auto;
    }

    .mitushi-dropdown-menu {
      min-width: 180px;
      background: rgba(40, 40, 43, 0.75);
      backdrop-filter: blur(18px) saturate(140%);
      -webkit-backdrop-filter: blur(18px) saturate(140%);
      border: 1px solid rgba(255, 255, 255, 0.08);
      box-shadow: 0 24px 64px rgba(0, 0, 0, 0.16);
      border-radius: 8px;
      padding: 8px 0;
    }

    .mitushi-dropdown-link {
      display: block;
      padding: 0.625rem 1rem;
      font-size: 11px;
      text-transform: uppercase;
      letter-spacing: 0.24em;
      color: rgba(255, 255, 255, 0.8);
      text-decoration: none;
      transition: background-color 0.2s ease, color 0.2s ease;
    }

    .mitushi-dropdown-link:hover {
      background: rgba(204, 19, 42, 0.1);
      color: #cc132a;
    }

    .mitushi-utilities {
      display: flex;
      align-items: center;
      gap: 0.25rem;
    }

    .mitushi-utilities button,
    .mitushi-utilities a {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      border-radius: 9999px;
      border: 1px solid rgba(255, 255, 255, 0.36);
      background: transparent;
      color: rgba(255, 255, 255, 0.8);
      padding: 0.75rem 1.125rem;
      font-size: 13px;
      line-height: 1;
      transition: color 0.2s ease, background-color 0.2s ease, border-color 0.2s ease;
      text-decoration: none;
      cursor: pointer;
    }

    .mitushi-utilities button:hover,
    .mitushi-utilities a:hover {
      border-color: rgba(204, 19, 42, 0.6);
      background: rgba(204, 19, 42, 0.08);
      color: #cc132a;
    }

    .mitushi-currency-chip {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
    }

    .mitushi-flag {
      display: inline-flex;
      width: 1.5rem;
      height: 1rem;
      border-radius: 0.125rem;
      overflow: hidden;
      position: relative;
      background: #0038b8;
    }

    .mitushi-flag::before {
      content: '✡';
      position: absolute;
      inset: 0;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 9px;
      color: #fff;
    }

    .mitushi-cart-button {
      position: relative;
      padding: 0.75rem;
    }

    .mitushi-cart-badge {
      position: absolute;
      top: 4px;
      right: 4px;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 16px;
      height: 16px;
      border-radius: 50%;
      background: #cc132a;
      color: #ffffff;
      font-size: 9px;
      font-weight: 700;
    }

    .text-crimson { color: #cc132a; }
    .bg-crimson { background: #cc132a; }
    .text-foreground\/80 { color: rgba(255, 255, 255, 0.8); }
    .hover\:text-foreground:hover { color: #f7f7f8; }

    /* Currency dropdown */
    .mitushi-currency-wrapper {
      position: relative;
    }

    .mitushi-currency-dropdown {
      position: absolute;
      top: calc(100% + 0.5rem);
      right: 0;
      min-width: 160px;
      background: rgba(28, 28, 30, 0.96);
      backdrop-filter: blur(18px) saturate(140%);
      -webkit-backdrop-filter: blur(18px) saturate(140%);
      border: 1px solid rgba(255, 255, 255, 0.08);
      border-radius: 10px;
      box-shadow: 0 16px 40px rgba(0, 0, 0, 0.4);
      overflow: hidden;
      z-index: 200;
    }

    .mitushi-currency-dropdown:not([hidden]) {
      display: block;
      animation: mitushi-dropdown-in 0.15s ease;
    }

    @keyframes mitushi-dropdown-in {
      from { opacity: 0; transform: translateY(-6px); }
      to   { opacity: 1; transform: translateY(0); }
    }

    .mitushi-currency-option {
      display: block;
      width: 100%;
      padding: 0.65rem 1rem;
      font-size: 11px;
      font-weight: 500;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: rgba(255, 255, 255, 0.75);
      background: transparent;
      border: none;
      cursor: pointer;
      text-align: left;
      transition: background 0.15s ease, color 0.15s ease;
    }

    .mitushi-currency-option:hover {
      background: rgba(204, 19, 42, 0.12);
      color: #cc132a;
    }

    .mitushi-currency-option.active {
      color: #cc132a;
      font-weight: 700;
    }

    .mitushi-currency-option + .mitushi-currency-option {
      border-top: 1px solid rgba(255, 255, 255, 0.05);
    }

    /* Search button */
    .mitushi-search-btn {
      color: rgba(255, 255, 255, 0.8);
      background: transparent;
      border: 1px solid rgba(255, 255, 255, 0.2);
      border-radius: 9999px;
      padding: 0.625rem;
      cursor: pointer;
      transition: color 0.2s ease, background-color 0.2s ease, border-color 0.2s ease;
    }

    .mitushi-search-btn:hover {
      border-color: rgba(204, 19, 42, 0.6);
      background: rgba(204, 19, 42, 0.08);
      color: #cc132a;
    }

    /* Search overlay */
    .mitushi-search-overlay {
      position: fixed;
      inset: 0;
      z-index: 9999;
      pointer-events: none;
    }

    .mitushi-search-overlay:not([hidden]) {
      pointer-events: auto;
    }

    .mitushi-search-overlay-backdrop {
      position: absolute;
      inset: 0;
      background: rgba(0, 0, 0, 0);
      transition: background 0.25s ease;
    }

    .mitushi-search-overlay.is-open .mitushi-search-overlay-backdrop {
      background: rgba(0, 0, 0, 0.55);
    }

    .mitushi-search-overlay-panel {
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      background: rgba(28, 28, 30, 0.97);
      backdrop-filter: blur(20px) saturate(160%);
      -webkit-backdrop-filter: blur(20px) saturate(160%);
      border-bottom: 1px solid rgba(255, 255, 255, 0.08);
      transform: translateY(-100%);
      transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
      padding: 1.25rem 2rem;
    }

    .mitushi-search-overlay.is-open .mitushi-search-overlay-panel {
      transform: translateY(0);
    }

    .mitushi-search-form {
      display: flex;
      align-items: center;
      gap: 0.75rem;
      max-width: 720px;
      margin: 0 auto;
    }

    .mitushi-search-form-icon {
      flex-shrink: 0;
      color: rgba(255, 255, 255, 0.4);
    }

    .mitushi-search-input {
      flex: 1;
      background: transparent;
      border: none;
      outline: none;
      font-size: 1.15rem;
      font-weight: 400;
      color: #f4f4f4;
      letter-spacing: 0.02em;
      padding: 0.5rem 0;
      -webkit-appearance: none;
      appearance: none;
    }

    .mitushi-search-input::placeholder {
      color: rgba(255, 255, 255, 0.3);
    }

    .mitushi-search-input::-webkit-search-cancel-button {
      -webkit-appearance: none;
    }

    .mitushi-search-close-btn {
      flex-shrink: 0;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 36px;
      height: 36px;
      border-radius: 50%;
      border: 1px solid rgba(255, 255, 255, 0.12);
      background: transparent;
      color: rgba(255, 255, 255, 0.6);
      cursor: pointer;
      transition: background 0.2s ease, color 0.2s ease, border-color 0.2s ease;
    }

    .mitushi-search-close-btn:hover {
      background: rgba(204, 19, 42, 0.12);
      border-color: rgba(204, 19, 42, 0.4);
      color: #cc132a;
    }
  </style>

  <div id="mitushi-announcement-bar" class="mitushi-announcement" aria-hidden="false">
    <div class="mitushi-announcement-inner">
      <div class="mitushi-marquee">
        {% for i in (1..section.settings.announcement_repeat_count) %}
          <span>
            {{ section.settings.announcement_text_primary }}
            <span aria-hidden>✦</span>
            {{ section.settings.announcement_text_secondary }}
            <span aria-hidden>✦</span>
          </span>
        {% endfor %}
      </div>
    </div>
  </div>

  <header id="mitushi-sticky-header" class="mitushi-sticky-header">
    <div class="mitushi-header-inner">
      <a href="{{ section.settings.logo_link | default: routes.root_url }}" class="mitushi-logo-link">
        <span aria-hidden="true" class="mitushi-logo-glow"></span>
        {% if section.settings.logo_image != blank %}
          {% assign logo_img_url = section.settings.logo_image | image_url: width: 400 %}
        {% else %}
          {% assign logo_img_url = 'mitushi-logo.png' | asset_url %}
        {% endif %}
        <img src="{{ logo_img_url }}" alt="{{ section.settings.logo_alt | escape }}" class="mitushi-logo-image" width="220" height="56" style="height: 56px; width: auto; filter: brightness(2.2) contrast(1.25);" />
      </a>

      <nav class="mitushi-nav hidden items-center gap-1 md:flex" aria-label="Primary navigation">
        {%- assign menu_links = linklists[section.settings.menu].links -%}
        {%- if menu_links != blank -%}
          {% for link in menu_links %}
            <div class="group mitushi-nav-item">
              <a href="{{ link.url }}" class="mitushi-nav-link {% if link.active or link.child_active %}active{% endif %}">
                {{ link.title }}
                {% if link.links.size > 0 %}
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" class="h-3 w-3" width="12" height="12" fill="currentColor" aria-hidden="true" style="display:inline-block;vertical-align:middle;">
                    <path fill-rule="evenodd" d="M5.23 7.21a.75.75 0 011.06.02L10 10.94l3.71-3.71a.75.75 0 011.06 1.06l-4.24 4.24a.75.75 0 01-1.06 0L5.25 8.27a.75.75 0 01-.02-1.06z" clip-rule="evenodd" />
                  </svg>
                {% endif %}
              </a>
              {% if link.links.size > 0 %}
                <div class="mitushi-dropdown-trigger">
                  <div class="mitushi-dropdown-menu">
                    {% for childlink in link.links %}
                      <a href="{{ childlink.url }}" class="mitushi-dropdown-link">
                        {{ childlink.title }}
                      </a>
                    {% endfor %}
                  </div>
                </div>
              {% endif %}
            </div>
          {% endfor %}
        {%- else -%}
          {% for block in section.blocks %}
            <div class="group mitushi-nav-item" {{ block.shopify_attributes }}>
              <a href="{{ block.settings.href }}" class="mitushi-nav-link {% if block.settings.active %}active{% endif %}">
                {{ block.settings.label }}
                {% if block.settings.dropdown_items != blank %}
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" class="h-3 w-3" width="12" height="12" fill="currentColor" aria-hidden="true" style="display:inline-block;vertical-align:middle;">
                    <path fill-rule="evenodd" d="M5.23 7.21a.75.75 0 011.06.02L10 10.94l3.71-3.71a.75.75 0 011.06 1.06l-4.24 4.24a.75.75 0 01-1.06 0L5.25 8.27a.75.75 0 01-.02-1.06z" clip-rule="evenodd" />
                  </svg>
                {% endif %}
              </a>
              {% if block.settings.dropdown_items != blank %}
                <div class="mitushi-dropdown-trigger">
                  <div class="mitushi-dropdown-menu">
                    {% assign dropdown_links = block.settings.dropdown_items | split: '\n' %}
                    {% for dropdown_item in dropdown_links %}
                      {% assign trimmed = dropdown_item | strip %}
                      {% if trimmed != blank %}
                        {% assign item_parts = trimmed | split: '|' %}
                        <a href="{{ item_parts[1] | default: '#' | strip }}" class="mitushi-dropdown-link">
                          {{ item_parts[0] | strip }}
                        </a>
                      {% endif %}
                    {% endfor %}
                  </div>
                </div>
              {% endif %}
            </div>
          {% endfor %}
        {%- endif -%}
      </nav>

      <div class="mitushi-utilities flex items-center gap-1">

        {%- if section.settings.show_currency_selector and shop.enabled_currencies.size > 1 -%}
          <div class="mitushi-currency-wrapper" id="mitushi-currency-wrapper">
            <button type="button" class="mitushi-currency-button" id="mitushi-currency-btn" aria-expanded="false" aria-haspopup="listbox">
              <span class="mitushi-flag"></span>
              <span class="font-medium tracking-wide" id="mitushi-currency-label">{{ cart.currency.iso_code }}</span>
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" width="12" height="12" fill="currentColor" aria-hidden="true" style="margin-left:0.25rem; transition: transform 0.2s ease;" id="mitushi-currency-arrow">
                <path fill-rule="evenodd" d="M5.23 7.21a.75.75 0 011.06.02L10 10.94l3.71-3.71a.75.75 0 011.06 1.06l-4.24 4.24a.75.75 0 01-1.06 0L5.25 8.27a.75.75 0 01-.02-1.06z" clip-rule="evenodd" />
              </svg>
            </button>
            <div class="mitushi-currency-dropdown" id="mitushi-currency-dropdown" hidden>
              <form action="/cart/update" method="post" id="mitushi-currency-form">
                {%- for currency in shop.enabled_currencies -%}
                  <button
                    type="submit"
                    name="updates[]"
                    class="mitushi-currency-option {% if currency == cart.currency %}active{% endif %}"
                    onclick="this.form.action='/currency/billing_address'; document.getElementById('currency_code_input').value='{{ currency.iso_code }}'; return true;"
                  >
                    {{ currency.iso_code }} &mdash; {{ currency.symbol }}
                  </button>
                {%- endfor -%}
                <input type="hidden" name="currency" id="currency_code_input" value="{{ cart.currency.iso_code }}">
              </form>
            </div>
          </div>
        {%- elsif section.settings.show_currency_selector -%}
          <button type="button" class="mitushi-currency-button">
            <span class="mitushi-flag"></span>
            <span class="font-medium tracking-wide">{{ cart.currency.iso_code }}</span>
          </button>
        {%- endif -%}

        <button type="button" id="mitushi-search-toggle" aria-label="Open search" class="mitushi-search-btn rounded-full p-2.5 transition inline-flex items-center justify-center">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" style="width:18px; height:18px;" width="18" height="18">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-4.35-4.35m0 0A7.5 7.5 0 1110.5 3a7.5 7.5 0 016.15 12.65z" />
          </svg>
        </button>

        <a href="{{ routes.cart_url }}" aria-label="Cart" class="mitushi-cart-button rounded-full p-2.5 text-foreground\/80 hover:bg-crimson\/10 hover:text-crimson transition inline-block">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="width:18px; height:18px;" width="18" height="18">
            <path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"></path>
            <line x1="3" y1="6" x2="21" y2="6"></line>
            <path d="M16 10a4 4 0 0 1-8 0"></path>
          </svg>
          <span class="mitushi-cart-badge">{{ cart.item_count }}</span>
        </a>
      </div>
    </div>
  </header>

  {%- comment -%} Search Overlay {%- endcomment -%}
  <div id="mitushi-search-overlay" class="mitushi-search-overlay" hidden aria-hidden="true">
    <div class="mitushi-search-overlay-backdrop" id="mitushi-search-backdrop"></div>
    <div class="mitushi-search-overlay-panel">
      <form action="{{ routes.search_url }}" method="get" class="mitushi-search-form" role="search">
        <input type="hidden" name="type" value="product,article,page">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" class="mitushi-search-form-icon" width="20" height="20" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-4.35-4.35m0 0A7.5 7.5 0 1110.5 3a7.5 7.5 0 016.15 12.65z" />
        </svg>
        <input
          id="mitushi-search-input"
          type="search"
          name="q"
          placeholder="Search products, drops, collections…"
          autocomplete="off"
          class="mitushi-search-input"
          aria-label="Search"
        >
        <button type="button" id="mitushi-search-close" class="mitushi-search-close-btn" aria-label="Close search">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" width="20" height="20">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </form>
    </div>
  </div>

</div>

<script>
  (function () {
    var announcementBar = document.getElementById('mitushi-announcement-bar');
    var stickyHeader = document.getElementById('mitushi-sticky-header');

    function updateScrollState() {
      var scrollY = window.scrollY || window.pageYOffset;
      var atTop = scrollY < 4;
      var scrolled = scrollY > 12;

      if (announcementBar) {
        announcementBar.style.height = atTop ? '36px' : '0px';
        announcementBar.style.opacity = atTop ? '1' : '0';
        announcementBar.setAttribute('aria-hidden', atTop ? 'false' : 'true');
      }

      if (stickyHeader) {
        if (scrolled) {
          stickyHeader.classList.add('scrolled');
        } else {
          stickyHeader.classList.remove('scrolled');
        }
      }
    }

    updateScrollState();
    window.addEventListener('scroll', updateScrollState, { passive: true });
    
    // Also run on DOMContentLoaded just in case it is still loading
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', updateScrollState);
    }

    // Currency dropdown toggle
    var currencyBtn = document.getElementById('mitushi-currency-btn');
    var currencyDropdown = document.getElementById('mitushi-currency-dropdown');
    var currencyArrow = document.getElementById('mitushi-currency-arrow');

    if (currencyBtn && currencyDropdown) {
      currencyBtn.addEventListener('click', function (e) {
        e.stopPropagation();
        var isOpen = !currencyDropdown.hidden;
        currencyDropdown.hidden = isOpen;
        currencyBtn.setAttribute('aria-expanded', String(!isOpen));
        if (currencyArrow) {
          currencyArrow.style.transform = isOpen ? '' : 'rotate(180deg)';
        }
      });

      // Close on outside click
      document.addEventListener('click', function () {
        currencyDropdown.hidden = true;
        currencyBtn.setAttribute('aria-expanded', 'false');
        if (currencyArrow) currencyArrow.style.transform = '';
      });

      // Prevent closing when clicking inside dropdown
      currencyDropdown.addEventListener('click', function (e) {
        e.stopPropagation();
      });
    }

    // Search overlay
    var searchToggle = document.getElementById('mitushi-search-toggle');
    var searchOverlay = document.getElementById('mitushi-search-overlay');
    var searchClose = document.getElementById('mitushi-search-close');
    var searchBackdrop = document.getElementById('mitushi-search-backdrop');
    var searchInput = document.getElementById('mitushi-search-input');

    function openSearch() {
      if (!searchOverlay) return;
      searchOverlay.removeAttribute('hidden');
      searchOverlay.setAttribute('aria-hidden', 'false');
      // Trigger animation on next frame
      requestAnimationFrame(function () {
        searchOverlay.classList.add('is-open');
        if (searchInput) searchInput.focus();
      });
    }

    function closeSearch() {
      if (!searchOverlay) return;
      searchOverlay.classList.remove('is-open');
      searchOverlay.setAttribute('aria-hidden', 'true');
      setTimeout(function () {
        searchOverlay.setAttribute('hidden', '');
        if (searchInput) searchInput.value = '';
      }, 300);
      if (searchToggle) searchToggle.focus();
    }

    if (searchToggle) searchToggle.addEventListener('click', openSearch);
    if (searchClose) searchClose.addEventListener('click', closeSearch);
    if (searchBackdrop) searchBackdrop.addEventListener('click', closeSearch);

    document.addEventListener('keydown', function (e) {
      if (e.key === 'Escape' && searchOverlay && !searchOverlay.hidden) {
        closeSearch();
      }
    });
  })();
</script>

