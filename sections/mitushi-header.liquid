{% comment %}
Mitushi Header Section
Combines a collapsible announcement bar with a sticky header.
{% endcomment %}

<sht-header class="mitushi-header-section d-block">
  <style>
    .mitushi-header-section {
      background: #28282b;
      color: #f7f7f8;
      font-family: var(--font-sans);
      position: relative;
      isolation: isolate;
    }

    .mitushi-announcement {
      overflow: hidden;
      background: #cc132a;
      color: #fff;
      height: 0;
      max-height: 0;
      opacity: 1;
      pointer-events: none;
      transition: none;
    }

    .mitushi-announcement.is-open {
      height: 36px;
      max-height: 36px;
      pointer-events: auto;
    }

    .mitushi-announcement-inner {
      display: flex;
      align-items: center;
      height: 36px;
      overflow: hidden;
      white-space: nowrap;
    }

    .mitushi-marquee {
      display: flex;
      align-items: center;
      gap: 4rem;
      padding-left: 2rem;
      font-size: 11px;
      font-weight: 600;
      letter-spacing: 0.32em;
      text-transform: uppercase;
      animation: mitushi-marquee 18s linear infinite;
    }

    .mitushi-marquee span {
      display: inline-flex;
      align-items: center;
      gap: 1rem;
    }

    .mitushi-marquee span[aria-hidden] {
      opacity: 0.6;
    }

    @keyframes mitushi-marquee {
      0% { transform: translateX(0); }
      100% { transform: translateX(-50%); }
    }

    .mitushi-sticky-header {
      border-bottom: 1px solid transparent;
      background: #28282b;
      /* Promote a stable compositor layer — prevents Chrome white-bar paint glitch on logo hover */
      transform: translateZ(0);
      -webkit-backface-visibility: hidden;
      backface-visibility: hidden;
    }

    .mitushi-sticky-header.scrolled {
      background: rgba(40, 40, 43, 0.96);
      border-color: rgba(255, 255, 255, 0.08);
      padding-block: 8px;
    }

    .mitushi-sticky-header:not(.scrolled) {
      padding-block: 12px;
    }

    /* Single sticky shell — dark, opaque, isolated from page paint */
    .shopify-section-group-header-group,
    #shopify-section-mitushi-header,
    div[id*="mitushi-header"],
    .shopify-section-group-header-group .shopify-section {
      position: sticky;
      top: 0;
      z-index: 100;
      background: #28282b !important;
      background-color: #28282b !important;
      color: #f7f7f8;
      transform: translateZ(0);
      -webkit-backface-visibility: hidden;
      backface-visibility: hidden;
      isolation: isolate;
      /* do NOT set overflow:clip — clips product dropdowns */
    }

    .mitushi-header-inner {
      max-width: 1400px;
      margin: 0 auto;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 3rem;
      padding: 0 2rem;
      position: relative;
      z-index: 1;
    }

    .mitushi-logo-link {
      position: relative;
      display: inline-flex;
      align-items: center;
      text-decoration: none !important;
      flex-shrink: 0;
      background: transparent !important;
      box-shadow: none !important;
      outline: none !important;
      -webkit-tap-highlight-color: transparent;
      /* Avoid new compositor layers on hover */
      transform: translateZ(0);
    }

    .mitushi-logo-link:hover,
    .mitushi-logo-link:focus,
    .mitushi-logo-link:focus-visible,
    .mitushi-logo-link:active,
    .mitushi-logo-link:hover *,
    .mitushi-header-section a.mitushi-logo-link:hover {
      color: inherit !important;
      background: transparent !important;
      text-decoration: none !important;
      outline: none !important;
      box-shadow: none !important;
      filter: none !important;
    }

    /* Soft glow via box-shadow on the image — no separate blurred layer */
    .mitushi-logo-glow {
      display: none !important;
    }

    .mitushi-logo-image {
      position: relative;
      z-index: 1;
      height: 56px;
      width: auto;
      display: block;
      max-width: 200px;
      border-radius: 0;
      box-shadow: -10px 0 28px rgba(204, 19, 42, 0.45);
      pointer-events: none;
    }

    .mitushi-nav {
      display: none;
      align-items: center;
      gap: 0.25rem;
    }

    @media (min-width: 768px) {
      .md\:flex {
        display: flex;
      }

      .mitushi-nav {
        display: flex;
      }
    }

    .mitushi-nav-item {
      position: relative;
    }

    .mitushi-nav-link {
      display: inline-flex;
      align-items: center;
      gap: 0.25rem;
      padding: 0.625rem 1.25rem;
      font-size: 12px;
      line-height: 1;
      font-weight: 500;
      text-transform: uppercase;
      letter-spacing: 0.28em;
      color: rgba(255, 255, 255, 0.8);
      text-decoration: none;
      transition: color 0.2s ease;
    }

    .mitushi-nav-link.active {
      color: #cc132a;
    }

    .mitushi-nav-link:hover {
      color: #f7f7f8;
    }

    .mitushi-nav-link.active::after {
      content: '';
      position: absolute;
      bottom: 4px;
      left: 50%;
      width: 24px;
      height: 1px;
      transform: translateX(-50%);
      background: #cc132a;
    }

    .mitushi-dropdown-trigger {
      position: absolute;
      left: 50%;
      top: 100%;
      transform: translateX(-50%);
      padding-top: 0.5rem;
      visibility: hidden;
      opacity: 0;
      transition: opacity 0.2s ease;
      pointer-events: none;
    }

    .mitushi-nav-item:hover .mitushi-dropdown-trigger {
      visibility: visible;
      opacity: 1;
      pointer-events: auto;
    }

    .mitushi-dropdown-menu {
      min-width: 180px;
      background: rgba(40, 40, 43, 0.75);
      backdrop-filter: blur(18px) saturate(140%);
      -webkit-backdrop-filter: blur(18px) saturate(140%);
      border: 1px solid rgba(255, 255, 255, 0.08);
      box-shadow: 0 24px 64px rgba(0, 0, 0, 0.16);
      border-radius: 8px;
      padding: 8px 0;
    }

    .mitushi-dropdown-link {
      display: block;
      padding: 0.625rem 1rem;
      font-size: 11px;
      text-transform: uppercase;
      letter-spacing: 0.24em;
      color: rgba(255, 255, 255, 0.8);
      text-decoration: none;
      transition: background-color 0.2s ease, color 0.2s ease;
    }

    .mitushi-dropdown-link:hover {
      background: rgba(204, 19, 42, 0.1);
      color: #cc132a;
    }

    .mitushi-utilities {
      display: flex;
      align-items: center;
      gap: 0.25rem;
    }

    .mitushi-utilities button,
    .mitushi-utilities a {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      border-radius: 9999px;
      border: 1px solid rgba(255, 255, 255, 0.36);
      background: transparent;
      color: rgba(255, 255, 255, 0.8);
      padding: 0.75rem 1.125rem;
      font-size: 13px;
      line-height: 1;
      transition: color 0.2s ease, background-color 0.2s ease, border-color 0.2s ease;
      text-decoration: none;
      cursor: pointer;
    }

    .mitushi-utilities button:hover,
    .mitushi-utilities a:hover {
      border-color: rgba(204, 19, 42, 0.6);
      background: rgba(204, 19, 42, 0.08);
      color: #cc132a;
    }

    .mitushi-currency-chip {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
    }

    .mitushi-country-flag {
      display: inline-flex;
      width: 1.25rem;
      height: 0.83rem;
      border-radius: 0.125rem;
      overflow: hidden;
      object-fit: cover;
      vertical-align: middle;
    }

    .mitushi-cart-button {
      position: relative;
      padding: 0.625rem !important;
      border: 1px solid transparent !important;
    }

    .mitushi-search-btn svg,
    .mitushi-cart-button svg {
      width: 20px;
      height: 20px;
      flex-shrink: 0;
    }

    .mitushi-cart-button:hover {
      border-color: transparent !important;
      background: rgba(204, 19, 42, 0.08) !important;
      color: #cc132a !important;
    }

    .mitushi-cart-badge {
      position: absolute;
      top: 4px;
      right: 4px;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-width: 16px;
      height: 16px;
      padding: 0 4px;
      border-radius: 999px;
      background: #cc132a;
      color: #ffffff;
      font-size: 9px;
      font-weight: 700;
      line-height: 1;
      transition: transform 0.3s cubic-bezier(0.34, 1.56, 0.64, 1), opacity 0.2s ease;
    }

    .mitushi-cart-badge.is-empty {
      opacity: 0;
      transform: scale(0);
      pointer-events: none;
    }

    @keyframes mitushi-badge-bump {
      0% { transform: scale(1); }
      35% { transform: scale(1.45); }
      70% { transform: scale(0.92); }
      100% { transform: scale(1); }
    }

    .mitushi-cart-badge.is-bump {
      animation: mitushi-badge-bump 0.5s cubic-bezier(0.34, 1.56, 0.64, 1);
    }

    .mitushi-cart-anchor {
      position: relative;
    }

    @keyframes mitushi-cart-received {
      0% { transform: scale(1) rotate(0deg); }
      20% { transform: scale(1.14) rotate(-6deg); }
      45% { transform: scale(0.94) rotate(4deg); }
      70% { transform: scale(1.06) rotate(-2deg); }
      100% { transform: scale(1) rotate(0deg); }
    }

    .mitushi-cart-button--received {
      animation: mitushi-cart-received 0.68s cubic-bezier(0.34, 1.56, 0.64, 1);
    }

    .mitushi-cart-button--received .mitushi-cart-badge:not(.is-empty) {
      box-shadow: 0 0 0 0 rgba(204, 19, 42, 0.55);
      animation: mitushi-badge-bump 0.5s cubic-bezier(0.34, 1.56, 0.64, 1), mitushi-badge-glow 0.68s ease;
    }

    @keyframes mitushi-badge-glow {
      0% { box-shadow: 0 0 0 0 rgba(204, 19, 42, 0.55); }
      60% { box-shadow: 0 0 0 8px rgba(204, 19, 42, 0); }
      100% { box-shadow: 0 0 0 0 rgba(204, 19, 42, 0); }
    }

    .mitushi-cart-fly-particle {
      position: fixed;
      z-index: 9999;
      pointer-events: none;
      border-radius: 10px;
      overflow: hidden;
      box-shadow: 0 8px 24px rgba(0, 0, 0, 0.35);
      border: 2px solid rgba(255, 255, 255, 0.2);
      will-change: left, top, transform, opacity;
    }

    .mitushi-cart-fly-particle img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
    }

    .mitushi-cart-fly-particle--dot {
      background: radial-gradient(circle at 30% 30%, #ff4d63, #cc132a 70%);
      border-radius: 50%;
      border: none;
      box-shadow: 0 0 18px rgba(204, 19, 42, 0.55);
    }

    @media (min-width: 1024px) {
      #cartNotificationPanel.cart-notification {
        display: none !important;
      }
    }

    .text-crimson { color: #cc132a; }
    .bg-crimson { background: #cc132a; }
    .text-foreground\/80 { color: rgba(255, 255, 255, 0.8); }
    .hover\:text-foreground:hover { color: #f7f7f8; }

    /* Currency dropdown */
    .mitushi-currency-wrapper {
      position: relative;
    }

    .mitushi-currency-dropdown {
      position: absolute;
      top: calc(100% + 0.5rem);
      right: 0;
      min-width: 160px;
      background: rgba(28, 28, 30, 0.96);
      backdrop-filter: blur(18px) saturate(140%);
      -webkit-backdrop-filter: blur(18px) saturate(140%);
      border: 1px solid rgba(255, 255, 255, 0.08);
      border-radius: 10px;
      box-shadow: 0 16px 40px rgba(0, 0, 0, 0.4);
      overflow: hidden;
      z-index: 200;
    }

    .mitushi-currency-dropdown:not([hidden]) {
      display: block;
      animation: mitushi-dropdown-in 0.15s ease;
    }

    @keyframes mitushi-dropdown-in {
      from { opacity: 0; transform: translateY(-6px); }
      to   { opacity: 1; transform: translateY(0); }
    }

    .mitushi-currency-option {
      display: block;
      width: 100%;
      padding: 0.65rem 1rem;
      font-size: 11px;
      font-weight: 500;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: rgba(255, 255, 255, 0.75);
      background: transparent;
      border: none;
      cursor: pointer;
      text-align: left;
      transition: background 0.15s ease, color 0.15s ease;
    }

    .mitushi-currency-option:hover {
      background: rgba(204, 19, 42, 0.12);
      color: #cc132a;
    }

    .mitushi-currency-option.active {
      color: #cc132a;
      font-weight: 700;
    }

    .mitushi-currency-option + .mitushi-currency-option {
      border-top: 1px solid rgba(255, 255, 255, 0.05);
    }

    /* Search button */
    .mitushi-search-btn {
      color: rgba(255, 255, 255, 0.8);
      background: transparent;
      border: 1px solid transparent !important;
      border-radius: 9999px;
      padding: 0.625rem;
      cursor: pointer;
      transition: color 0.2s ease, background-color 0.2s ease, border-color 0.2s ease;
    }

    .mitushi-search-btn:hover {
      border-color: transparent !important;
      background: rgba(204, 19, 42, 0.08);
      color: #cc132a;
    }

    /* Search overlay */
    .mitushi-search-overlay {
      position: fixed;
      inset: 0;
      z-index: 9999;
      pointer-events: none;
    }

    .mitushi-search-overlay:not([hidden]) {
      pointer-events: auto;
    }

    .mitushi-search-overlay-backdrop {
      position: absolute;
      inset: 0;
      background: rgba(0, 0, 0, 0);
      transition: background 0.25s ease;
    }

    .mitushi-search-overlay.is-open .mitushi-search-overlay-backdrop {
      background: rgba(0, 0, 0, 0.55);
    }

    .mitushi-search-overlay-panel {
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      background: rgba(28, 28, 30, 0.97);
      backdrop-filter: blur(20px) saturate(160%);
      -webkit-backdrop-filter: blur(20px) saturate(160%);
      border-bottom: 1px solid rgba(255, 255, 255, 0.08);
      transform: translateY(-100%);
      transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
      padding: 1.25rem 2rem;
    }

    .mitushi-search-overlay.is-open .mitushi-search-overlay-panel {
      transform: translateY(0);
    }

    .mitushi-search-form {
      display: flex;
      align-items: center;
      gap: 0.75rem;
      max-width: 720px;
      margin: 0 auto;
    }

    .mitushi-search-form-icon {
      flex-shrink: 0;
      color: rgba(255, 255, 255, 0.4);
    }

    .mitushi-search-input {
      flex: 1;
      background: transparent;
      border: none;
      outline: none;
      font-size: 1.15rem;
      font-weight: 400;
      color: #f4f4f4;
      letter-spacing: 0.02em;
      padding: 0.5rem 0;
      -webkit-appearance: none;
      appearance: none;
    }

    .mitushi-search-input::placeholder {
      color: rgba(255, 255, 255, 0.3);
    }

    .mitushi-search-input::-webkit-search-cancel-button {
      -webkit-appearance: none;
    }

    .mitushi-search-close-btn {
      flex-shrink: 0;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 36px;
      height: 36px;
      border-radius: 50%;
      border: 1px solid rgba(255, 255, 255, 0.12);
      background: transparent;
      color: rgba(255, 255, 255, 0.6);
      cursor: pointer;
      transition: background 0.2s ease, color 0.2s ease, border-color 0.2s ease;
    }

    .mitushi-search-close-btn:hover {
      background: rgba(204, 19, 42, 0.12);
      border-color: rgba(204, 19, 42, 0.4);
      color: #cc132a;
    }

    .mitushi-header-start {
      display: none;
      align-items: center;
      flex-shrink: 0;
    }

    /* Mobile menu toggle */
    .mitushi-menu-toggle {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      padding: 0.625rem;
      border: 1px solid transparent;
      border-radius: 9999px;
      background: transparent;
      color: rgba(255, 255, 255, 0.85);
      cursor: pointer;
      transition: color 0.2s ease, background-color 0.2s ease;
    }

    .mitushi-menu-toggle svg {
      width: 22px;
      height: 22px;
    }

    .mitushi-menu-toggle:hover,
    .mitushi-menu-toggle[aria-expanded="true"] {
      background: rgba(204, 19, 42, 0.08);
      color: #cc132a;
    }

    /* Mobile drawer */
    .mitushi-mobile-drawer {
      position: fixed;
      inset: 0;
      z-index: 10050;
      pointer-events: none;
      visibility: hidden;
    }

    .mitushi-mobile-drawer.is-open {
      pointer-events: auto;
      visibility: visible;
    }

    .mitushi-mobile-drawer__backdrop {
      position: absolute;
      inset: 0;
      background: rgba(0, 0, 0, 0);
      transition: background 0.3s ease;
    }

    .mitushi-mobile-drawer.is-open .mitushi-mobile-drawer__backdrop {
      background: rgba(0, 0, 0, 0.55);
    }

    .mitushi-mobile-drawer__panel {
      position: absolute;
      top: 0;
      inset-inline-end: 0;
      width: min(100%, 320px);
      height: 100%;
      max-height: 100dvh;
      display: flex;
      flex-direction: column;
      background: rgba(28, 28, 30, 0.98);
      backdrop-filter: blur(22px) saturate(140%);
      -webkit-backdrop-filter: blur(22px) saturate(140%);
      border-inline-start: 1px solid rgba(255, 255, 255, 0.08);
      box-shadow: -16px 0 48px rgba(0, 0, 0, 0.35);
      transform: translate3d(100%, 0, 0);
      transition: transform 0.32s cubic-bezier(0.4, 0, 0.2, 1);
      overflow: hidden;
    }

    [dir="rtl"] .mitushi-mobile-drawer__panel {
      transform: translate3d(-100%, 0, 0);
      box-shadow: 16px 0 48px rgba(0, 0, 0, 0.35);
    }

    .mitushi-mobile-drawer.is-open .mitushi-mobile-drawer__panel {
      transform: translate3d(0, 0, 0);
    }

    .mitushi-mobile-drawer__head {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 1rem;
      padding: 1rem 1.25rem;
      border-bottom: 1px solid rgba(255, 255, 255, 0.08);
      flex-shrink: 0;
    }

    .mitushi-mobile-drawer__title {
      font-size: 11px;
      font-weight: 600;
      letter-spacing: 0.32em;
      text-transform: uppercase;
      color: rgba(255, 255, 255, 0.5);
    }

    .mitushi-mobile-drawer__close {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 40px;
      height: 40px;
      border-radius: 50%;
      border: 1px solid rgba(255, 255, 255, 0.12);
      background: transparent;
      color: rgba(255, 255, 255, 0.75);
      cursor: pointer;
      transition: background 0.2s ease, color 0.2s ease, border-color 0.2s ease;
    }

    .mitushi-mobile-drawer__close:hover {
      background: rgba(204, 19, 42, 0.12);
      border-color: rgba(204, 19, 42, 0.35);
      color: #cc132a;
    }

    .mitushi-mobile-drawer__body {
      flex: 1;
      overflow-y: auto;
      overscroll-behavior: contain;
      padding: 0.5rem 0 1.5rem;
      -webkit-overflow-scrolling: touch;
    }

    .mitushi-mobile-nav-list {
      list-style: none;
      margin: 0;
      padding: 0;
    }

    .mitushi-mobile-nav-item {
      border-bottom: 1px solid rgba(255, 255, 255, 0.06);
    }

    .mitushi-mobile-link {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 0.75rem;
      padding: 1rem 1.25rem;
      font-size: 13px;
      font-weight: 500;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: rgba(255, 255, 255, 0.88);
      text-decoration: none;
      transition: color 0.2s ease, background 0.2s ease;
    }

    .mitushi-mobile-link:hover,
    .mitushi-mobile-link.is-active {
      color: #cc132a;
      background: rgba(204, 19, 42, 0.06);
    }

    .mitushi-mobile-link--summary {
      list-style: none;
      cursor: pointer;
    }

    .mitushi-mobile-link--summary::-webkit-details-marker {
      display: none;
    }

    .mitushi-mobile-accordion[open] .mitushi-mobile-chevron {
      transform: rotate(180deg);
    }

    .mitushi-mobile-chevron {
      flex-shrink: 0;
      opacity: 0.6;
      transition: transform 0.2s ease;
    }

    .mitushi-mobile-submenu {
      display: flex;
      flex-direction: column;
      padding: 0 0 0.5rem;
      background: rgba(0, 0, 0, 0.2);
    }

    .mitushi-mobile-sublink {
      display: block;
      padding: 0.75rem 1.25rem 0.75rem 2rem;
      font-size: 12px;
      font-weight: 500;
      letter-spacing: 0.16em;
      text-transform: uppercase;
      color: rgba(255, 255, 255, 0.7);
      text-decoration: none;
      transition: color 0.2s ease, background 0.2s ease;
    }

    [dir="rtl"] .mitushi-mobile-sublink {
      padding: 0.75rem 2rem 0.75rem 1.25rem;
    }

    .mitushi-mobile-sublink:hover {
      color: #cc132a;
      background: rgba(204, 19, 42, 0.08);
    }

    body.mitushi-menu-open {
      overflow: hidden;
    }

    @media (max-width: 767px) {
      .mitushi-header-start {
        display: flex;
        grid-column: 1;
        grid-row: 1;
        justify-self: start;
        min-width: 44px;
      }

      .mitushi-header-inner {
        display: grid;
        grid-template-columns: minmax(44px, 1fr) auto minmax(44px, 1fr);
        align-items: center;
        gap: 0.5rem;
        padding-inline: 1rem;
      }

      .mitushi-logo-link {
        justify-self: center;
        grid-column: 2;
        grid-row: 1;
      }

      .mitushi-nav {
        display: none !important;
      }

      .mitushi-utilities {
        justify-self: end;
        grid-column: 3;
        grid-row: 1;
      }

      .mitushi-logo-image {
        height: 44px;
      }

      .mitushi-logo-glow {
        width: 40px;
        height: 40px;
        left: -6px;
      }

      .mitushi-sticky-header:not(.scrolled) {
        padding-block: 10px;
      }

      .mitushi-sticky-header.scrolled {
        padding-block: 8px;
      }

      .mitushi-marquee {
        font-size: 10px;
        gap: 2.5rem;
        padding-inline-start: 1rem;
      }

      .mitushi-search-overlay-panel {
        padding: 1rem;
      }

      .mitushi-search-input {
        font-size: 1rem;
      }
    }
  </style>

  <div id="mitushi-announcement-bar" class="mitushi-announcement is-open" aria-hidden="false">
    <div class="mitushi-announcement-inner">
      <div class="mitushi-marquee">
        {%- liquid
          assign announce_primary = section.settings.announcement_text_primary | strip
          assign announce_secondary = section.settings.announcement_text_secondary | strip

          if announce_primary == blank and section.settings.announcement_use_free_shipping
            assign free_ship_cents = settings.cart_minimum_order_price_for_free_shipping | times: 100
            assign free_ship_money = free_ship_cents | money
            assign announce_primary = 'Free shipping on orders over ' | append: free_ship_money
          elsif announce_primary == blank
            assign announce_primary = shop.name
          endif
        -%}
        {% for i in (1..section.settings.announcement_repeat_count) %}
          <span>
            {{ announce_primary }}
            {%- if announce_secondary != blank -%}
              <span aria-hidden>✦</span>
              {{ announce_secondary }}
              <span aria-hidden>✦</span>
            {%- endif -%}
          </span>
        {% endfor %}
      </div>
    </div>
  </div>

  <header id="mitushi-sticky-header" class="mitushi-sticky-header">
    <div class="mitushi-header-inner">
      <div class="mitushi-header-start">
        <button
          type="button"
          id="mitushi-menu-toggle"
          class="mitushi-menu-toggle"
          aria-label="Open menu"
          aria-expanded="false"
          aria-controls="mitushi-mobile-drawer"
        >
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path fill-rule="evenodd" clip-rule="evenodd" d="M21 7H3V5h18v2zm0 6H3v-2h18v2zm-5 6H3v-2h13v2z" />
          </svg>
        </button>
      </div>

      <a href="{{ section.settings.logo_link | default: routes.root_url }}" class="mitushi-logo-link">
        <span aria-hidden="true" class="mitushi-logo-glow"></span>
        {% if section.settings.logo_image != blank %}
          {% assign logo_img_url = section.settings.logo_image | image_url: width: 400 %}
        {% else %}
          {% assign logo_img_url = 'mitushi-logo-header.png' | asset_url %}
        {% endif %}
        <img src="{{ logo_img_url }}" alt="{{ section.settings.logo_alt | escape }}" class="mitushi-logo-image" width="220" height="56" style="height: 56px; width: auto;" />
      </a>

      <nav class="mitushi-nav hidden items-center gap-1 md:flex" aria-label="Primary navigation">
        {%- assign menu_links = linklists[section.settings.menu].links -%}
        {%- if menu_links != blank -%}
          {%- liquid
            assign has_categories_link = false
            for link in menu_links
              assign link_title_down = link.title | downcase
              if link_title_down == 'products' or link_title_down == 'categories' or link_title_down == 'collections'
                assign has_categories_link = true
              endif
            endfor
            assign categories_rendered = false
          -%}
          {% for link in menu_links %}
            {%- liquid
              assign is_products_link = false
              assign link_title_down = link.title | downcase
              if link_title_down == 'products' or link_title_down == 'categories' or link_title_down == 'collections'
                assign is_products_link = true
              endif
            -%}
            <div class="group mitushi-nav-item">
              <a href="{% if is_products_link %}{{ routes.all_products_collection_url }}{% else %}{{ link.url }}{% endif %}" class="mitushi-nav-link {% if link.active or link.child_active %}active{% endif %}">
                {% if is_products_link %}Products{% else %}{{ link.title }}{% endif %}
                {% if link.links.size > 0 or is_products_link %}
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" class="h-3 w-3" width="12" height="12" fill="currentColor" aria-hidden="true" style="display:inline-block;vertical-align:middle;">
                    <path fill-rule="evenodd" d="M5.23 7.21a.75.75 0 011.06.02L10 10.94l3.71-3.71a.75.75 0 011.06 1.06l-4.24 4.24a.75.75 0 01-1.06 0L5.25 8.27a.75.75 0 01-.02-1.06z" clip-rule="evenodd" />
                  </svg>
                {% endif %}
              </a>
              {% if is_products_link %}
                <div class="mitushi-dropdown-trigger">
                  <div class="mitushi-dropdown-menu">
                    {% for collection in collections %}
                      {% unless collection.handle == 'all' or collection.handle == 'frontpage' %}
                        <a href="{{ collection.url }}" class="mitushi-dropdown-link">
                          {{ collection.title }}
                        </a>
                      {% endunless %}
                    {% endfor %}
                  </div>
                </div>
              {% elsif link.links.size > 0 %}
                <div class="mitushi-dropdown-trigger">
                  <div class="mitushi-dropdown-menu">
                    {% for childlink in link.links %}
                      <a href="{{ childlink.url }}" class="mitushi-dropdown-link">
                        {{ childlink.title }}
                      </a>
                    {% endfor %}
                  </div>
                </div>
              {% endif %}
            </div>

            {%- liquid
              assign should_render_categories = false
              if has_categories_link == false and categories_rendered == false
                if link_title_down == 'home'
                  assign should_render_categories = true
                elsif forloop.last
                  assign should_render_categories = true
                endif
              endif
            -%}

            {%- if should_render_categories -%}
              {%- assign categories_rendered = true -%}
              <div class="group mitushi-nav-item">
                <a href="{{ routes.all_products_collection_url }}" class="mitushi-nav-link">
                  PRODUCTS
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" class="h-3 w-3" width="12" height="12" fill="currentColor" aria-hidden="true" style="display:inline-block;vertical-align:middle;">
                    <path fill-rule="evenodd" d="M5.23 7.21a.75.75 0 011.06.02L10 10.94l3.71-3.71a.75.75 0 011.06 1.06l-4.24 4.24a.75.75 0 01-1.06 0L5.25 8.27a.75.75 0 01-.02-1.06z" clip-rule="evenodd" />
                  </svg>
                </a>
                <div class="mitushi-dropdown-trigger">
                  <div class="mitushi-dropdown-menu">
                    {% for collection in collections %}
                      {% unless collection.handle == 'all' or collection.handle == 'frontpage' %}
                        <a href="{{ collection.url }}" class="mitushi-dropdown-link">
                          {{ collection.title }}
                        </a>
                      {% endunless %}
                    {% endfor %}
                  </div>
                </div>
              </div>
            {%- endif -%}
          {% endfor %}
        {%- else -%}
          {%- liquid
            assign has_categories_block = false
            for block in section.blocks
              assign block_label_down = block.settings.label | downcase
              if block_label_down == 'products' or block_label_down == 'categories' or block_label_down == 'collections'
                assign has_categories_block = true
              endif
            endfor
            assign categories_rendered_block = false
          -%}
          {% for block in section.blocks %}
            {%- liquid
              assign is_products_block = false
              assign block_label_down = block.settings.label | downcase
              if block_label_down == 'products' or block_label_down == 'categories' or block_label_down == 'collections'
                assign is_products_block = true
              endif
            -%}
            <div class="group mitushi-nav-item" {{ block.shopify_attributes }}>
              <a href="{% if is_products_block %}{{ routes.all_products_collection_url }}{% else %}{{ block.settings.href }}{% endif %}" class="mitushi-nav-link {% if block.settings.active %}active{% endif %}">
                {{ block.settings.label }}
                {% if block.settings.dropdown_items != blank or is_products_block %}
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" class="h-3 w-3" width="12" height="12" fill="currentColor" aria-hidden="true" style="display:inline-block;vertical-align:middle;">
                    <path fill-rule="evenodd" d="M5.23 7.21a.75.75 0 011.06.02L10 10.94l3.71-3.71a.75.75 0 011.06 1.06l-4.24 4.24a.75.75 0 01-1.06 0L5.25 8.27a.75.75 0 01-.02-1.06z" clip-rule="evenodd" />
                  </svg>
                {% endif %}
              </a>
              {% if is_products_block %}
                <div class="mitushi-dropdown-trigger">
                  <div class="mitushi-dropdown-menu">
                    {% for collection in collections %}
                      {% unless collection.handle == 'all' or collection.handle == 'frontpage' %}
                        <a href="{{ collection.url }}" class="mitushi-dropdown-link">
                          {{ collection.title }}
                        </a>
                      {% endunless %}
                    {% endfor %}
                  </div>
                </div>
              {% elsif block.settings.dropdown_items != blank %}
                <div class="mitushi-dropdown-trigger">
                  <div class="mitushi-dropdown-menu">
                    {% assign dropdown_links = block.settings.dropdown_items | split: '\n' %}
                    {% for dropdown_item in dropdown_links %}
                      {% assign trimmed = dropdown_item | strip %}
                      {% if trimmed != blank %}
                        {% assign item_parts = trimmed | split: '|' %}
                        <a href="{{ item_parts[1] | default: '#' | strip }}" class="mitushi-dropdown-link">
                          {{ item_parts[0] | strip }}
                        </a>
                      {% endif %}
                    {% endfor %}
                  </div>
                </div>
              {% endif %}
            </div>

            {%- liquid
              assign should_render_categories_block = false
              if has_categories_block == false and categories_rendered_block == false
                if block_label_down == 'home'
                  assign should_render_categories_block = true
                elsif forloop.last
                  assign should_render_categories_block = true
                endif
              endif
            -%}

            {%- if should_render_categories_block -%}
              {%- assign categories_rendered_block = true -%}
              <div class="group mitushi-nav-item">
                <a href="{{ routes.all_products_collection_url }}" class="mitushi-nav-link">
                  PRODUCTS
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" class="h-3 w-3" width="12" height="12" fill="currentColor" aria-hidden="true" style="display:inline-block;vertical-align:middle;">
                    <path fill-rule="evenodd" d="M5.23 7.21a.75.75 0 011.06.02L10 10.94l3.71-3.71a.75.75 0 011.06 1.06l-4.24 4.24a.75.75 0 01-1.06 0L5.25 8.27a.75.75 0 01-.02-1.06z" clip-rule="evenodd" />
                  </svg>
                </a>
                <div class="mitushi-dropdown-trigger">
                  <div class="mitushi-dropdown-menu">
                    {% for collection in collections %}
                      {% unless collection.handle == 'all' or collection.handle == 'frontpage' %}
                        <a href="{{ collection.url }}" class="mitushi-dropdown-link">
                          {{ collection.title }}
                        </a>
                      {% endunless %}
                    {% endfor %}
                  </div>
                </div>
              </div>
            {%- endif -%}
          {% endfor %}
        {%- endif -%}
      </nav>

      <div class="mitushi-utilities flex items-center gap-1">
        <button type="button" id="mitushi-search-toggle" aria-label="Open search" class="mitushi-search-btn rounded-full transition inline-flex items-center justify-center">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-4.35-4.35m0 0A7.5 7.5 0 1110.5 3a7.5 7.5 0 016.15 12.65z" />
          </svg>
        </button>

        <div class="mitushi-cart-anchor">
          <a
            href="{{ routes.cart_url }}"
            id="mitushiCartButton"
            aria-label="Cart"
            class="mitushi-cart-button js-header-cart-status-btn rounded-full text-foreground\/80 hover:bg-crimson\/10 hover:text-crimson transition inline-flex items-center justify-center"
          >
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"></path>
              <line x1="3" y1="6" x2="21" y2="6"></line>
              <path d="M16 10a4 4 0 0 1-8 0"></path>
            </svg>
            <span class="mitushi-cart-badge js-cart-form-item_count{% if cart.item_count == 0 %} is-empty{% endif %}">{{ cart.item_count }}</span>
          </a>
        </div>
      </div>
    </div>
  </header>

  {%- comment -%} Mobile menu drawer {%- endcomment -%}
  <div id="mitushi-mobile-drawer" class="mitushi-mobile-drawer" hidden aria-hidden="true">
    <div class="mitushi-mobile-drawer__backdrop" id="mitushi-mobile-drawer-backdrop" aria-hidden="true"></div>
    <div class="mitushi-mobile-drawer__panel" role="dialog" aria-modal="true" aria-label="Menu">
      <div class="mitushi-mobile-drawer__head">
        <span class="mitushi-mobile-drawer__title">Menu</span>
        <button type="button" class="mitushi-mobile-drawer__close" id="mitushi-mobile-drawer-close" aria-label="Close menu">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" width="20" height="20" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </div>
      <div class="mitushi-mobile-drawer__body">
        <nav aria-label="Mobile navigation">
          {% render 'mitushi-mobile-nav', section: section %}
        </nav>
      </div>
    </div>
  </div>

  {%- comment -%} Search Overlay {%- endcomment -%}
  <div id="mitushi-search-overlay" class="mitushi-search-overlay" hidden aria-hidden="true">
    <div class="mitushi-search-overlay-backdrop" id="mitushi-search-backdrop"></div>
    <div class="mitushi-search-overlay-panel">
      <form action="{{ routes.search_url }}" method="get" class="mitushi-search-form" role="search">
        <input type="hidden" name="type" value="product,article,page">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" class="mitushi-search-form-icon" width="20" height="20" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-4.35-4.35m0 0A7.5 7.5 0 1110.5 3a7.5 7.5 0 016.15 12.65z" />
        </svg>
        <input
          id="mitushi-search-input"
          type="search"
          name="q"
          placeholder="Search products, drops, collections…"
          autocomplete="off"
          class="mitushi-search-input"
          aria-label="Search"
        >
        <button type="button" id="mitushi-search-close" class="mitushi-search-close-btn" aria-label="Close search">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" width="20" height="20">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </form>
    </div>
  </div>

  {%- render 'cart-notification-panel' -%}
</sht-header>

<script>
  (function () {
    var announcementBar = document.getElementById('mitushi-announcement-bar');
    var stickyHeader = document.getElementById('mitushi-sticky-header');
    var announceOpen = true;
    var SCROLL_TOP_THRESHOLD = 8;
    var ANNOUNCE_BAR_HEIGHT = 36;
    var scrollTicking = false;

    function getAnnouncementHeight() {
      if (!announcementBar) return ANNOUNCE_BAR_HEIGHT;
      var inner = announcementBar.querySelector('.mitushi-announcement-inner');
      return inner && inner.offsetHeight ? inner.offsetHeight : ANNOUNCE_BAR_HEIGHT;
    }

    function setAnnouncementOpen(open) {
      if (!announcementBar || announceOpen === open) return;

      announceOpen = open;
      announcementBar.classList.toggle('is-open', open);
      announcementBar.setAttribute('aria-hidden', open ? 'false' : 'true');
    }

    function updateScrollState() {
      var scrollY = window.scrollY || window.pageYOffset;
      var atTop = scrollY <= SCROLL_TOP_THRESHOLD;

      setAnnouncementOpen(atTop);

      if (stickyHeader) {
        stickyHeader.classList.toggle('scrolled', !atTop);
      }
    }

    function onScroll() {
      if (scrollTicking) return;
      scrollTicking = true;
      window.requestAnimationFrame(function () {
        updateScrollState();
        scrollTicking = false;
      });
    }

    updateScrollState();
    window.addEventListener('scroll', onScroll, { passive: true });

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', updateScrollState);
    }

    // Currency dropdown toggle
    var currencyBtn = document.getElementById('mitushi-currency-btn');
    var currencyDropdown = document.getElementById('mitushi-currency-dropdown');
    var currencyArrow = document.getElementById('mitushi-currency-arrow');

    if (currencyBtn && currencyDropdown) {
      currencyBtn.addEventListener('click', function (e) {
        e.stopPropagation();
        var isOpen = !currencyDropdown.hidden;
        currencyDropdown.hidden = isOpen;
        currencyBtn.setAttribute('aria-expanded', String(!isOpen));
        if (currencyArrow) {
          currencyArrow.style.transform = isOpen ? '' : 'rotate(180deg)';
        }
      });

      // Close on outside click
      document.addEventListener('click', function () {
        currencyDropdown.hidden = true;
        currencyBtn.setAttribute('aria-expanded', 'false');
        if (currencyArrow) currencyArrow.style.transform = '';
      });

      // Prevent closing when clicking inside dropdown
      currencyDropdown.addEventListener('click', function (e) {
        e.stopPropagation();
      });
    }

    // Search overlay
    var searchToggle = document.getElementById('mitushi-search-toggle');
    var searchOverlay = document.getElementById('mitushi-search-overlay');
    var searchClose = document.getElementById('mitushi-search-close');
    var searchBackdrop = document.getElementById('mitushi-search-backdrop');
    var searchInput = document.getElementById('mitushi-search-input');

    function openSearch() {
      if (!searchOverlay) return;
      searchOverlay.removeAttribute('hidden');
      searchOverlay.setAttribute('aria-hidden', 'false');
      // Trigger animation on next frame
      requestAnimationFrame(function () {
        searchOverlay.classList.add('is-open');
        if (searchInput) searchInput.focus();
      });
    }

    function closeSearch() {
      if (!searchOverlay) return;
      searchOverlay.classList.remove('is-open');
      searchOverlay.setAttribute('aria-hidden', 'true');
      setTimeout(function () {
        searchOverlay.setAttribute('hidden', '');
        if (searchInput) searchInput.value = '';
      }, 300);
      if (searchToggle) searchToggle.focus();
    }

    if (searchToggle) searchToggle.addEventListener('click', openSearch);
    if (searchClose) searchClose.addEventListener('click', closeSearch);
    if (searchBackdrop) searchBackdrop.addEventListener('click', closeSearch);

    document.addEventListener('keydown', function (e) {
      if (e.key === 'Escape' && searchOverlay && !searchOverlay.hidden) {
        closeSearch();
      }
    });

    // Mobile menu drawer
    var menuToggle = document.getElementById('mitushi-menu-toggle');
    var mobileDrawer = document.getElementById('mitushi-mobile-drawer');
    var mobileDrawerClose = document.getElementById('mitushi-mobile-drawer-close');
    var mobileDrawerBackdrop = document.getElementById('mitushi-mobile-drawer-backdrop');

    function openMobileMenu() {
      if (!mobileDrawer) return;
      mobileDrawer.removeAttribute('hidden');
      mobileDrawer.setAttribute('aria-hidden', 'false');
      document.body.classList.add('mitushi-menu-open');
      if (menuToggle) menuToggle.setAttribute('aria-expanded', 'true');
      requestAnimationFrame(function () {
        mobileDrawer.classList.add('is-open');
      });
    }

    function closeMobileMenu() {
      if (!mobileDrawer) return;
      mobileDrawer.classList.remove('is-open');
      mobileDrawer.setAttribute('aria-hidden', 'true');
      document.body.classList.remove('mitushi-menu-open');
      if (menuToggle) {
        menuToggle.setAttribute('aria-expanded', 'false');
        menuToggle.focus();
      }
      setTimeout(function () {
        mobileDrawer.setAttribute('hidden', '');
      }, 320);
    }

    if (menuToggle) menuToggle.addEventListener('click', openMobileMenu);
    if (mobileDrawerClose) mobileDrawerClose.addEventListener('click', closeMobileMenu);
    if (mobileDrawerBackdrop) mobileDrawerBackdrop.addEventListener('click', closeMobileMenu);

    if (mobileDrawer) {
      mobileDrawer.querySelectorAll('a.mitushi-mobile-link, a.mitushi-mobile-sublink').forEach(function (link) {
        link.addEventListener('click', closeMobileMenu);
      });
    }

    document.addEventListener('keydown', function (e) {
      if (e.key === 'Escape' && mobileDrawer && mobileDrawer.classList.contains('is-open')) {
        closeMobileMenu();
      }
    });

    window.addEventListener('resize', function () {
      if (window.innerWidth >= 768 && mobileDrawer && mobileDrawer.classList.contains('is-open')) {
        closeMobileMenu();
      }
    });
  })();
</script>

{% schema %}
{
  "name": "Mitushi Header",
  "enabled_on": {
    "groups": ["header"]
  },
  "settings": [
    {
      "type": "image_picker",
      "id": "logo_image",
      "label": "Logo image"
    },
    {
      "type": "text",
      "id": "logo_alt",
      "label": "Logo alt text",
      "default": "Mitushi"
    },
    {
      "type": "url",
      "id": "logo_link",
      "label": "Logo link"
    },
    {
      "type": "link_list",
      "id": "menu",
      "label": "Menu",
      "default": "main-menu"
    },
    {
      "type": "header",
      "content": "Announcement bar (top marquee)"
    },
    {
      "type": "text",
      "id": "announcement_text_primary",
      "label": "Announcement text — line 1",
      "default": "FREE SHIPPING ON ORDERS OVER $199",
      "info": "Main scrolling message. Edit this to change what visitors see in the red bar."
    },
    {
      "type": "text",
      "id": "announcement_text_secondary",
      "label": "Announcement text — line 2 (optional)",
      "default": "新作コレクション",
      "info": "Second phrase after ✦ (e.g. 新作コレクション = New Collection). Leave empty to hide."
    },
    {
      "type": "checkbox",
      "id": "announcement_use_free_shipping",
      "label": "Auto free-shipping text when line 1 is empty",
      "default": false,
      "info": "Only used if line 1 is blank. Uses your cart free-shipping threshold from theme settings."
    },
    {
      "type": "number",
      "id": "announcement_repeat_count",
      "label": "Announcement repeat count",
      "default": 8
    },
    {
      "type": "checkbox",
      "id": "show_currency_selector",
      "label": "Show currency selector",
      "default": true,
      "info": "Only shows if your store has multiple currencies enabled in Shopify Markets"
    }
  ],
  "blocks": [
    {
      "type": "nav_item",
      "name": "Navigation item",
      "settings": [
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "default": "Home"
        },
        {
          "type": "url",
          "id": "href",
          "label": "Link"
        },
        {
          "type": "checkbox",
          "id": "active",
          "label": "Active item",
          "default": false
        },
        {
          "type": "textarea",
          "id": "dropdown_items",
          "label": "Dropdown items (one per line, format: Label | URL)",
          "default": "Shirts | #shirts\nShorts | #shorts\nTanks | #tanks"
        }
      ]
    }
  ],
  "max_blocks": 10,
  "presets": [
    {
      "name": "Mitushi Header",
      "category": "Header",
      "blocks": [
        {
          "type": "nav_item",
          "settings": {
            "label": "Home",
            "href": "#home",
            "active": true,
            "dropdown_items": ""
          }
        },
        {
          "type": "nav_item",
          "settings": {
            "label": "Products",
            "href": "#products",
            "active": false,
            "dropdown_items": "Shirts | #shirts\nShorts | #shorts\nTanks | #tanks"
          }
        },
        {
          "type": "nav_item",
          "settings": {
            "label": "About us",
            "href": "#about",
            "active": false,
            "dropdown_items": ""
          }
        },
        {
          "type": "nav_item",
          "settings": {
            "label": "Contact",
            "href": "#contact",
            "active": false,
            "dropdown_items": ""
          }
        }
      ]
    },
    {
