{%- liquid
  if cart == empty
    assign cart_empty_hide = 'hidden'
    assign cart_empty_show = 'block'
  else
    assign cart_empty_hide = 'block'
    assign cart_empty_show = 'hidden'
  endif
-%}
<div class="bg-background text-foreground min-h-screen" id="mainCart" data-ui-component="Main Cart Section">
  <style>
    /* Cart page specific size adjustments to ensure high readability */
    #mainCartContainer {
      font-size: 16px;
    }
    #mainCartContainer .text-\[10px\] {
      font-size: 12px !important;
    }
    #mainCartContainer .text-\[11px\] {
      font-size: 13px !important;
    }
    #mainCartContainer .text-\[12px\] {
      font-size: 14px !important;
    }
    #mainCartContainer .text-xs {
      font-size: 14px !important;
    }
    #mainCartContainer .text-sm {
      font-size: 16px !important;
    }
    #mainCartContainer .text-base {
      font-size: 18px !important;
    }
    #mainCartContainer .text-lg {
      font-size: 20px !important;
    }
    #mainCartContainer .text-xl {
      font-size: 23px !important;
    }
    #mainCartContainer .text-2xl {
      font-size: 28px !important;
    }
    #mainCartContainer .text-4xl {
      font-size: 38px !important;
    }
    #mainCartContainer .text-5xl {
      font-size: 48px !important;
    }
    #mainCartContainer .text-6xl {
      font-size: 58px !important;
    }
    
    /* Make quantity input a bit larger to match */
    #mainCartContainer .js-quantity-input {
      font-size: 14px !important;
      width: 2.5rem !important;
    }
    #mainCartContainer .js-quantity-btn svg {
      width: 14px !important;
      height: 14px !important;
    }
    #mainCartContainer .field_quantity button {
      width: 2.5rem !important;
      height: 2.5rem !important;
    }

    /* Hide browser number spinners — use +/- buttons only */
    #mainCartContainer .js-quantity-input::-webkit-outer-spin-button,
    #mainCartContainer .js-quantity-input::-webkit-inner-spin-button {
      -webkit-appearance: none;
      margin: 0;
    }
    #mainCartContainer .js-quantity-input {
      -moz-appearance: textfield;
      appearance: textfield;
    }

    #mainCartContainer .cart-item__unit-price {
      display: none !important;
    }

    #mainCartContainer .cart-item__title {
      font-family: var(--font-body-family) !important;
      font-weight: 600 !important;
      letter-spacing: 0.01em !important;
      text-transform: none !important;
    }

    /* Free shipping bar — Lovable order summary (scratch_showcase cart.tsx) */
    .mitushi-cart-summary .mitushi-freeship {
      margin-top: 1.25rem;
    }

    .mitushi-freeship__message-wrap {
      font-size: 11px;
      line-height: 1.45;
      letter-spacing: 0.25em;
      text-transform: uppercase;
      color: rgba(247, 247, 248, 0.7);
    }

    .mitushi-freeship__track {
      height: 4px;
      width: 100%;
      overflow: hidden;
      background: rgba(255, 255, 255, 0.1);
      border-radius: 999px;
    }

    .mitushi-freeship__fill {
      display: block;
      height: 100%;
      width: 0;
      background: #cc132a;
      border-radius: inherit;
      transition: width 0.65s cubic-bezier(0.16, 1, 0.3, 1);
      will-change: width;
    }

    @media (prefers-reduced-motion: reduce) {
      .mitushi-freeship__fill {
        transition-duration: 0.01ms;
      }
    }

    .mitushi-freeship__progress-native {
      position: absolute;
      width: 1px;
      height: 1px;
      opacity: 0;
      pointer-events: none;
      overflow: hidden;
    }

    @media (max-width: 767px) {
      #mainCartContainer {
        padding: 1.25rem 1rem 2.5rem !important;
      }

      .mitushi-cart-header {
        flex-direction: column;
        align-items: center;
        text-align: center;
        margin-bottom: 1.75rem !important;
        gap: 0.5rem;
      }

      .mitushi-cart-header-eyebrow {
        margin-bottom: 0.5rem !important;
        letter-spacing: 0.35em !important;
      }

      .mitushi-cart-header h1 {
        font-size: clamp(1.75rem, 9vw, 2.25rem) !important;
        line-height: 1.05;
      }

      .mitushi-cart-item-count {
        margin-top: 0.35rem;
        font-size: 11px !important;
        letter-spacing: 0.28em;
        color: rgba(247, 247, 248, 0.45);
      }

      #mainCartContainer .js-cart-items {
        border: none;
        background: rgba(255, 255, 255, 0.03);
      }

      #mainCartContainer .cart-item {
        flex-direction: row;
        align-items: center;
        gap: 0.75rem;
        padding: 0.75rem 0.85rem !important;
        margin: 0;
        border-bottom-color: rgba(255, 255, 255, 0.08) !important;
      }

      #mainCartContainer .cart-item > a {
        width: 108px !important;
        height: 128px !important;
        flex-shrink: 0;
        border-radius: 2px;
      }

      #mainCartContainer .cart-item__details {
        flex: 1;
        min-width: 0;
        display: flex;
        flex-direction: column;
        align-items: center;
        text-align: center;
        gap: 0.5rem;
      }

      #mainCartContainer .cart-item__top {
        flex-direction: column;
        align-items: center !important;
        text-align: center;
        gap: 0.35rem;
        width: 100%;
      }

      #mainCartContainer .cart-item__info {
        width: 100%;
        text-align: center;
      }

      #mainCartContainer .cart-item__info > a {
        display: block;
      }

      #mainCartContainer .cart-item__price {
        text-align: center !important;
        width: 100%;
      }

      #mainCartContainer .cart-item__price .font-display {
        font-size: 1.2rem !important;
      }

      #mainCartContainer .cart-item__title {
        font-size: clamp(1.2rem, 5.2vw, 1.45rem) !important;
        line-height: 1.15;
      }

      #mainCartContainer .cart-item__info .text-xs {
        margin-top: 0.35rem !important;
        justify-content: center;
        display: flex;
        align-items: center;
        flex-wrap: wrap;
        gap: 0.25rem;
      }

      #mainCartContainer .cart-item__controls {
        width: 100%;
        padding-top: 0;
        justify-content: center;
        gap: 0.75rem;
      }

      #mainCartContainer .cart-item__qty {
        border-color: rgba(255, 255, 255, 0.18) !important;
      }

      #mainCartContainer .cart-item__qty .field_quantity button {
        width: 1.65rem !important;
        height: 1.65rem !important;
      }

      #mainCartContainer .cart-item__qty .js-quantity-input {
        width: 1.5rem !important;
        font-size: 11px !important;
        padding: 0 !important;
      }

      #mainCartContainer .cart-item__qty .js-quantity-btn svg {
        width: 10px !important;
        height: 10px !important;
      }

      #mainCartContainer .cart-item__remove {
        font-size: 11px !important;
        letter-spacing: 0.22em !important;
        color: rgba(247, 247, 248, 0.55) !important;
        padding: 0.35rem 0;
      }

      .mitushi-cart-continue {
        display: flex !important;
        justify-content: center;
        width: 100%;
        margin-top: 1.5rem !important;
        font-size: 11px !important;
      }

      .mitushi-cart-summary {
        border: none !important;
        background: linear-gradient(180deg, rgba(255, 255, 255, 0.06) 0%, rgba(255, 255, 255, 0.02) 100%);
        padding: 1.5rem 1.25rem 1.35rem !important;
        margin-top: 0.5rem;
      }

      .mitushi-cart-summary h2 {
        text-align: center;
        font-size: 1.35rem !important;
      }

      .mitushi-cart-summary .mitushi-freeship {
        margin-top: 1rem;
        text-align: center;
      }

      .mitushi-cart-summary dl {
        margin-top: 0 !important;
      }

      .mitushi-cart-summary .checkout-btn {
        border-radius: 2px;
      }

      .mitushi-cart-summary .checkout-btn .relative {
        height: 3.25rem !important;
        font-size: 10px !important;
        letter-spacing: 0.18em !important;
        white-space: nowrap;
        gap: 0.5rem !important;
      }

      .mitushi-cart-trust {
        flex-direction: column;
        align-items: center;
        gap: 0.65rem !important;
        margin-top: 1rem !important;
        font-size: 9px !important;
        letter-spacing: 0.2em !important;
      }

      #mainCartContainer .grid {
        gap: 1.5rem !important;
      }
    }

    #mainCartContainer .js-cart-form-errors:empty {
      display: none;
    }

    #mainCartContainer .cart-item.is-removing {
      opacity: 0.45;
      pointer-events: none;
    }

    #mainCartContainer .cart-item__remove.is-removing {
      opacity: 0.5;
      cursor: wait;
    }

    #mainCartContainer .js-cart-form-errors {
      margin-top: 0.75rem;
      padding: 0.65rem 0.75rem;
      font-size: 11px;
      letter-spacing: 0.06em;
      text-transform: uppercase;
      text-align: center;
      color: #ff6b6b;
      background: rgba(255, 107, 107, 0.08);
      border: 1px solid rgba(255, 107, 107, 0.25);
    }
  </style>
  <main class="mx-auto max-w-[1400px] px-6 py-12" id="mainCartContainer">
    <sht-cart-frm class="cart-content section d-block">
      
      <!-- Cart Header Row -->
      <div class="js-cart-page-header mitushi-cart-header mb-10 flex items-end justify-between gap-6 {{ cart_empty_hide }}">
        <div>
          <div class="mitushi-cart-header-eyebrow mb-3 text-[10px] font-medium uppercase tracking-[0.5em] text-crimson">
            / Bag
          </div>
          <h1 class="font-display text-5xl md:text-6xl text-foreground">Your cart</h1>
          <p class="mitushi-cart-item-count text-xs uppercase tracking-[0.3em] text-foreground/50 md:hidden">
            <span class="js-cart-form-item_count">{{ cart.item_count }}</span> item{% if cart.item_count != 1 %}s{% endif %}
          </p>
        </div>
        <div class="hidden text-xs uppercase tracking-[0.3em] text-foreground/50 md:block">
          <span class="js-cart-form-item_count">{{ cart.item_count }}</span> item{% if cart.item_count != 1 %}s{% endif %}
        </div>
      </div>

      <!-- Empty State Header -->
      <div class="js-cart-page-empty border border-border/60 py-24 text-center {{ cart_empty_show }}">
        <div class="mb-4 text-[10px] uppercase tracking-[0.5em] text-crimson">/ Empty</div>
        <h2 class="font-display text-4xl text-foreground">Your bag is quiet</h2>
        <p class="mt-3 text-sm text-foreground/60">No drops yet. The next release won't wait.</p>
        <a class="mt-8 inline-flex items-center gap-2 bg-crimson px-6 py-3 text-[11px] font-bold uppercase tracking-[0.3em] text-white hover:bg-crimson-glow transition" href="{{ routes.all_products_collection_url }}">
          Explore the drop
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="width: 14px; height: 14px;">
            <line x1="5" y1="12" x2="19" y2="12"></line>
            <polyline points="12 5 19 12 12 19"></polyline>
          </svg>
        </a>
      </div>

      <!-- Cart Form -->
      <form action="{{ routes.cart_url }}" method="post" id="cartForm" class="js-cart-page-form {{ cart_empty_hide }}">
        {%- liquid
          assign fs_minimum = settings.cart_minimum_order_price_for_free_shipping | default: '199'
          if fs_minimum == blank
            assign fs_minimum = '199'
          endif
          assign free_shipping_threshold = fs_minimum | times: 100
        -%}
        {%- if cart != empty -%}
          <div class="js-cart-form-errors" role="alert" aria-live="polite"></div>
        {%- endif -%}
        <div class="grid grid-cols-1 gap-10 lg:grid-cols-3">
          
          <!-- Left Column: Items List -->
          <div class="pb-50 js-cart-form-wrapper lg:col-span-2" id="mainCartForm" data-section-id="{{ section.id }}">
            <div class="js-cart-form-content-cart-items">
              {%- if cart != empty -%}
                <div class="border-y border-border/60 js-cart-items">
                  {% for line_item in cart.items %}
                    {%- liquid
                      assign line_inventory_max = nil
                      if line_item.variant.inventory_management != nil and line_item.variant.inventory_policy == 'deny'
                        assign line_inventory_max = line_item.variant.inventory_quantity
                      endif
                    -%}
                    <div
                      class="flex gap-5 border-b border-border/60 py-6 last:border-b-0 cart-item sm:py-6"
                      id="cartItem-{{ line_item.index | plus: 1 }}"
                      data-unit-price="{{ line_item.variant.price }}"
                      {% if line_inventory_max %}data-inventory-max="{{ line_inventory_max }}"{% endif %}
                    >
                      
                      <!-- Item Image -->
                      <a href="{{ line_item.url }}" class="cart-item__image block h-28 w-24 flex-shrink-0 overflow-hidden bg-card sm:h-32 sm:w-28">
                        {% if line_item.image %}
                          <img src="{{ line_item.image | image_url: width: 300 }}" alt="{{ line_item.product.title | escape }}" class="h-full w-full object-cover transition-transform duration-500 hover:scale-105" />
                        {% else %}
                          {{ 'detailed-apparel-1' | placeholder_svg_tag: 'placeholder' }}
                        {% endif %}
                      </a>

                      <!-- Item Details -->
                      <div class="cart-item__details flex flex-1 flex-col justify-between gap-3">
                        
                        <!-- Top Row: Title, Tag, Size & Price -->
                        <div class="cart-item__top flex items-start justify-between gap-3">
                          <div class="cart-item__info">
                            <!-- Title -->
                            <a href="{{ line_item.url }}">
                              <h3 class="cart-item__title text-xl leading-snug text-foreground hover:text-crimson transition">{{ line_item.product.title | escape }}</h3>
                            </a>
                            <!-- Size Option -->
                            {%- if line_item.product.has_only_default_variant == false -%}
                              <p class="mt-2 text-xs text-foreground/70">
                                Size 
                                <span class="ml-1 inline-block border border-border/60 px-2 py-0.5 text-[10px] font-bold tracking-wider">
                                  {%- for option in line_item.options_with_values -%}
                                    {{ option.value }}
                                    {%- unless forloop.last -%}, {%- endunless -%}
                                  {%- endfor -%}
                                </span>
                              </p>
                            {%- endif -%}
                          </div>

                          <!-- Price Info (Aligned Right) -->
                          <div class="cart-item__price text-right">
                            <div class="font-display text-lg text-foreground">
                              {{ line_item.final_line_price | money }}
                            </div>
                            <div class="cart-item__unit-price text-[10px] uppercase tracking-[0.25em] text-foreground/40 mt-1 hidden">
                              {{ line_item.variant.price | money }} EA
                            </div>
                          </div>
                        </div>

                        <!-- Bottom Controls Row -->
                        <div class="cart-item__controls flex items-center justify-between">
                          <!-- Quantity Input Wrapper -->
                          <div class="cart-item__qty flex items-center border border-border/60">
                            <sht-qty-inp class="field_quantity flex items-center">
                              <button class="js-quantity-btn js-quantity-btn-minus grid h-9 w-9 place-items-center text-foreground/70 hover:text-crimson transition bg-transparent border-none cursor-pointer" name="minus" data-name="minus" type="button" aria-label="Decrease">
                                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-3 w-3"><line x1="5" y1="12" x2="19" y2="12"></line></svg>
                              </button>
                              <input
                                class="js-quantity-input input-number w-8 text-center text-xs font-medium tabular-nums bg-transparent border-none outline-none focus:outline-none"
                                type="number"
                                name="updates[]"
                                value="{{ line_item.quantity }}"
                                data-cart-quantity="{{ cart | item_count_for_variant: line_item.variant.id }}"
                                min="0"
                                {% if line_inventory_max %}max="{{ line_inventory_max }}" data-inventory-max="{{ line_inventory_max }}"{% endif %}
                                aria-label="{{ line_item.product.title | escape }}"
                                id="quantity-{{ line_item.index | plus: 1 }}"
                                data-index="{{ line_item.index | plus: 1 }}"
                              >
                              <button class="js-quantity-btn js-quantity-btn-plus grid h-9 w-9 place-items-center text-foreground/70 hover:text-crimson transition bg-transparent border-none cursor-pointer" name="plus" data-name="plus" type="button" aria-label="Increase">
                                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-3 w-3"><line x1="12" y1="5" x2="12" y2="19"></line><line x1="5" y1="12" x2="19" y2="12"></line></svg>
                              </button>
                            </sht-qty-inp>
                          </div>

                          <!-- Remove -->
                          <sht-cart-rmv-btn data-index="{{ line_item.index | plus: 1 }}">
                            <button
                              type="button"
                              class="cart-item__remove flex items-center gap-1.5 text-[10px] uppercase tracking-[0.3em] text-foreground/50 hover:text-crimson transition bg-transparent border-none cursor-pointer p-0"
                              data-cart-remove
                              aria-label="Remove {{ line_item.product.title | escape }}"
                            >
                              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-3.5 w-3.5">
                                <polyline points="3 6 5 6 21 6"></polyline>
                                <path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path>
                                <line x1="10" y1="11" x2="10" y2="17"></line>
                                <line x1="14" y1="11" x2="14" y2="17"></line>
                              </svg>
                              Remove
                            </button>
                          </sht-cart-rmv-btn>
                        </div>
                      </div>
                    </div>
                  {% endfor %}
                </div>
              {%- endif -%}

              <!-- Continue Shopping Bottom Link -->
              <a href="{{ routes.all_products_collection_url }}" class="mitushi-cart-continue mt-6 inline-flex items-center gap-2 text-[11px] uppercase tracking-[0.3em] text-foreground/60 hover:text-crimson transition">
                ← Continue shopping
              </a>
            </div>
          </div>

          <!-- Right Column: Sidebar Order Summary -->
          <aside class="lg:sticky lg:top-28 lg:self-start js-cart-form-footer {% if cart == empty %}d-none{% endif %}">
            <div class="mitushi-cart-summary border border-border/60 bg-card p-7 js-cart-form-content-cart-total">
              
              <!-- Title -->
              <h2 class="font-display text-2xl text-foreground">Order summary</h2>

              {%- render 'mitushi-free-shipping-bar' -%}

              <!-- Subtotal & Shipping summary rows -->
              <dl class="mt-6 space-y-3 text-sm">
                <div class="flex items-center justify-between">
                  <dt class="text-foreground/70">Subtotal</dt>
                  <dd class="text-foreground font-semibold js-cart-total">{{ cart.total_price | money }}</dd>
                </div>
                <div class="flex items-center justify-between">
                  <dt class="text-foreground/70">Shipping</dt>
                  <dd class="text-foreground font-semibold">
                    {%- liquid
                      if cart.total_price >= free_shipping_threshold
                        echo '<span class="text-crimson font-bold">FREE</span>'
                      else
                        echo 'Calculated at checkout'
                      endif
                    -%}
                  </dd>
                </div>
                <div class="my-4 h-px bg-border/60"></div>
                <div class="flex items-center justify-between">
                  <dt class="text-[11px] uppercase tracking-[0.3em] text-foreground/70">Total</dt>
                  <dd class="font-display text-2xl text-foreground">{{ cart.total_price | money }}</dd>
                </div>
              </dl>

              <!-- Checkout Button -->
              <div class="w-100">
                <div class="cart__checkout mt-7">
                  <button
                    type="submit"
                    name="checkout"
                    class="group relative block w-full overflow-hidden bg-crimson hover:bg-crimson-glow transition duration-300 checkout-btn cursor-pointer"
                    {% if cart == empty %}
                      disabled
                    {% endif %}
                    form="cartForm"
                    style="border: none; outline: none;"
                  >
                    <span class="absolute inset-0 origin-left scale-x-0 bg-crimson transition-transform duration-500 ease-[cubic-bezier(0.16,1,0.3,1)] group-hover:scale-x-100"></span>
                    <span class="relative flex h-14 items-center justify-center gap-3 text-[12px] font-bold uppercase tracking-[0.35em] text-white">
                      Proceed to checkout
                      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="h-4 w-4 transition-transform duration-500 group-hover:translate-x-1.5">
                        <line x1="5" y1="12" x2="19" y2="12"></line>
                        <polyline points="12 5 19 12 12 19"></polyline>
                      </svg>
                    </span>
                  </button>
                </div>

                <!-- Secure Checkout Badges -->
                <div class="mitushi-cart-trust mt-5 flex items-center justify-between text-[10px] uppercase tracking-[0.25em] text-foreground/50">
                  <span class="flex items-center gap-1.5">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-3 w-3">
                      <rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect>
                      <path d="M7 11V7a5 5 0 0 1 10 0v4"></path>
                    </svg>
                    Secure checkout
                  </span>
                  <span class="flex items-center gap-1.5">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-3 w-3">
                      <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path>
                    </svg>
                    14-day returns
                  </span>
                </div>

              </div>

            </div>
          </aside>

        </div>
      </form>
    </sht-cart-frm>
  </main>
</div>

<script>
  (function () {
    function formatMoney(cents) {
      if (typeof SHTHelper !== 'undefined' && SHTHelper.formatMoney && window.theme_variables?.settings?.money_format) {
        return SHTHelper.formatMoney(cents, window.theme_variables.settings.money_format);
      }
      if (typeof Shopify !== 'undefined' && Shopify.formatMoney) {
        return Shopify.formatMoney(cents);
      }
      return '$' + (cents / 100).toFixed(2);
    }

    function getFreeshipRoot() {
      return document.querySelector('#mainCartContainer .mitushi-freeship');
    }

    function updateProgress(totalCents) {
      const root = getFreeshipRoot();
      if (!root) return;
      const bar = root.querySelector('.js-free-shipping-progress');
      const fill = root.querySelector('.js-free-shipping-progress-visual');
      const msg = root.querySelector('.mitushi-freeship__message-wrap');
      const threshold = parseInt(root.dataset.freeshipThreshold, 10) || parseInt(bar?.getAttribute('max'), 10) || 19900;
      const val = Math.max(0, totalCents || 0);
      const pct = Math.min(100, Math.max(0, (val / threshold) * 100));
      const remaining = Math.max(0, threshold - val);

      if (bar) {
        bar.value = val;
        bar.max = threshold;
      }
      if (fill) {
        fill.classList.toggle('is-complete', val >= threshold);
        fill.style.width = pct + '%';
      }
      if (msg) {
        if (val >= threshold) {
          msg.innerHTML = '<span class="text-crimson">★ You unlocked free shipping</span>';
        } else {
          msg.innerHTML = 'Add <span class="text-crimson mitushi-freeship__remaining">' + formatMoney(remaining) + '</span> for free shipping';
        }
      }
    }

    window.MitushiCart = { updateProgress: updateProgress };

    document.addEventListener('DOMContentLoaded', function () {
      const bar = getFreeshipRoot()?.querySelector('.js-free-shipping-progress');
      if (bar) updateProgress(parseFloat(bar.value) || 0);
    });
  })();

  document.addEventListener('DOMContentLoaded', () => {
    const btn = document.querySelector('.checkout-btn');
    if (btn) {
      btn.addEventListener('mousemove', (e) => {
        const rect = btn.getBoundingClientRect();
        const x = ((e.clientX - rect.left) / rect.width - 0.5) * 16;
        const y = ((e.clientY - rect.top) / rect.height - 0.5) * 10;
        btn.style.transform = `translate(${x}px, ${y}px)`;
        btn.style.transition = 'transform 0.1s ease';
      });
      btn.addEventListener('mouseleave', () => {
        btn.style.transform = 'translate(0px, 0px)';
        btn.style.transition = 'transform 0.4s cubic-bezier(0.16,1,0.3,1)';
      });
    }
  });
</script>

{%- liquid
  assign files = "component-cart.js" | split: ', '
  render 'js-loader', files: files
-%}

