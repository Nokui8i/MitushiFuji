{%- liquid
  assign variant_label = settings.variant_swatches_option | downcase | default: 'color'
  assign place_holder = 'product-apparel-1' | placeholder_svg_tag: 'placeholder js-image-lazy w-100 h-100 p-absolute'
  assign section_id = section.id | md5 | truncate: 12, ""
  assign is_first_image = false
  assign product_form_id = 'productForm-' | append: section.id
  assign sticky_product_form_id = 'productStickyForm-' | append: section.id
  assign product_form_installment_id = 'productFormInstallment-' | append: section.id
  assign first_3d_model = product.media | where: 'media_type', 'model' | first
  assign size_guide_block = nil
  assign size_guide_dialog_id = ''
  assign popup_content_block = nil
  assign popup_content_dialog_id = ''
  
  for block in section.blocks
    if block.type == 'size_guide'
      assign size_guide_block = block
      assign size_guide_dialog_id = 'productSizeGuide-' | append: block.id | append: '-' | append: section.id
    endif
    if block.type == 'popup'
      assign popup_content_block = block
      assign popup_content_dialog_id = 'productPopup-' | append: block.id | append: '-' | append: section.id
    endif
  endfor
-%}
<div class="bg-background text-foreground min-h-screen py-10" id="mainProduct" data-ui-component="Main Product Section">
  <main class="mx-auto max-w-[1400px] px-6">
    <!-- Breadcrumb -->
    <nav class="mb-8 flex items-center gap-2 text-[10px] uppercase tracking-[0.3em] text-foreground/50">
      <a href="/" class="hover:text-crimson">Home</a>
      <span>/</span>
      <span>{{ product.collections.first.title | default: "Streetwear" }}</span>
      <span>/</span>
      <span class="text-foreground">{{ product.title }}</span>
    </nav>

    <div class="grid grid-cols-1 gap-12 lg:grid-cols-2">
      <!-- Gallery -->
      <div class="flex flex-col-reverse gap-4 lg:flex-row">
        <!-- Thumbnails -->
        <div class="flex gap-3 lg:flex-col overflow-x-auto lg:overflow-visible hide-scrollbar">
          {%- for media in product.media -%}
            <button
              type="button"
              data-index="{{ forloop.index0 }}"
              class="thumb-btn relative aspect-square w-20 flex-shrink-0 overflow-hidden border transition-all {% if forloop.first %}border-crimson{% else %}border-border/60 hover:border-foreground/40{% endif %} bg-card cursor-pointer"
            >
              <img src="{{ media.src | image_url: width: 160 }}" alt="{{ media.alt | escape }}" class="h-full w-full object-cover" />
            </button>
          {%- endfor -%}
        </div>
        
        <!-- Main Image -->
        <div class="relative flex-1">
          <div class="relative aspect-[4/5] overflow-hidden bg-card">
            {%- for media in product.media -%}
              <img
                src="{{ media.src | image_url: width: 1000 }}"
                alt="{{ media.alt | escape }}"
                data-index="{{ forloop.index0 }}"
                class="main-gallery-img absolute inset-0 h-full w-full object-cover transition-opacity duration-500 {% if forloop.first %}opacity-100{% else %}opacity-0{% endif %}"
              />
            {%- endfor -%}
            
            {%- assign has_drop_tag = false -%}
            {%- for tag in product.tags -%}
              {%- if tag contains 'Drop' or tag contains 'drop' -%}
                <span class="absolute left-4 top-4 bg-crimson px-2.5 py-1 text-[10px] font-bold uppercase tracking-[0.3em] text-white">
                  {{ tag | escape }}
                </span>
                {%- assign has_drop_tag = true -%}
              {%- endif -%}
            {%- endfor -%}
            {%- unless has_drop_tag -%}
              <span class="absolute left-4 top-4 bg-crimson px-2.5 py-1 text-[10px] font-bold uppercase tracking-[0.3em] text-white">
                Drop 03
              </span>
            {%- endunless -%}
          </div>
        </div>
      </div>

      <!-- Info -->
      <div class="lg:pl-8">
        <div class="mb-2 text-[10px] font-medium uppercase tracking-[0.5em] text-crimson">
          / {{ product.type | default: 'GHOST' | uppercase }} — 鬼
        </div>
        <h1 class="font-display text-5xl md:text-6xl leading-none text-foreground uppercase">{{ product.title }}</h1>
        <div class="mt-4 flex items-baseline gap-3">
          <span class="font-display text-3xl text-crimson product-price-display">{{ product.selected_or_first_available_variant.price | money }}</span>
          <span class="text-xs uppercase tracking-[0.3em] text-foreground/50">{{ cart.currency.iso_code }}</span>
        </div>
        
        <!-- Short description -->
        <p class="mt-6 max-w-md text-sm leading-relaxed text-foreground/70">
          {%- if product.metafields.descriptors.subtitle != blank -%}
            {{ product.metafields.descriptors.subtitle }}
          {%- else -%}
            {{ product.description | replace: '<br>', ' ' | replace: '</p>', ' ' | strip_html | truncatewords: 30 }}
          {%- endif -%}
        </p>

        <!-- Product form -->
        {%- form 'product', product, id: 'product-form', class: 'mt-10', novalidate: 'novalidate' -%}
          <input type="hidden" name="return_to" value="/cart" />
          
          <select name="id" id="ProductSelect-{{ section.id }}" class="hidden">
            {%- for variant in product.variants -%}
              <option value="{{ variant.id }}"
                {% if variant == product.selected_or_first_available_variant %}selected="selected"{% endif %}
                data-price="{{ variant.price | money }}"
                data-available="{{ variant.available }}"
                data-options="{%- for opt in variant.options -%}{{ opt | escape }}{%- unless forloop.last -%},{%- endunless -%}{%- endfor -%}"
              >
                {{ variant.title }}
              </option>
            {%- endfor -%}
          </select>

          <!-- Size options buttons -->
          {%- unless product.has_only_default_variant -%}
            {%- for option in product.options_with_values -%}
              <div class="mb-8 variant-option-group" data-option-index="{{ forloop.index0 }}" data-option-name="{{ option.name | escape }}">
                <div class="mb-3 flex items-center justify-between">
                  <span class="text-[10px] font-medium uppercase tracking-[0.3em] text-foreground/70">{{ option.name }}</span>
                  {%- if option.name == 'Size' or option.name == 'size' -%}
                    {%- if size_guide_block -%}
                      <sht-dialog-open-btn class="no-js-hidden" data-dialog-id="{{ size_guide_dialog_id }}">
                        <button type="button" class="flex items-center gap-1.5 text-[10px] uppercase tracking-[0.3em] text-foreground/60 hover:text-crimson transition bg-transparent border-none cursor-pointer">
                          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-3 w-3">
                            <path d="M5 16v-6"></path><path d="M9 16v-4"></path><path d="M13 16v-6"></path><path d="M17 16v-4"></path><path d="M21 16V8"></path><rect x="2" y="4" width="20" height="12" rx="2"></rect>
                          </svg>
                          Size chart
                        </button>
                      </sht-dialog-open-btn>
                    {%- endif -%}
                  {%- endif -%}
                </div>
                <div class="flex flex-wrap gap-2">
                  {%- for value in option.values -%}
                    {%- assign is_selected = false -%}
                    {%- if option.selected_value == value -%}
                      {%- assign is_selected = true -%}
                    {%- endif -%}
                    <button
                      type="button"
                      data-value="{{ value | escape }}"
                      class="variant-value-btn h-12 w-12 border text-xs font-bold uppercase tracking-wider transition-all cursor-pointer {% if is_selected %}border-crimson bg-crimson text-white{% else %}border-border/60 text-foreground hover:border-crimson bg-transparent{% endif %}"
                    >
                      {{ value }}
                    </button>
                  {%- endfor -%}
                </div>
              </div>
            {%- endfor -%}
          {%- endunless -%}

          <!-- Quantity & CTA buttons -->
          <div class="mt-8 flex flex-wrap items-stretch gap-3">
            <div class="flex items-center border border-border/60 bg-transparent">
              <button
                type="button"
                class="qty-btn-minus grid h-12 w-12 place-items-center text-foreground/70 hover:text-crimson transition bg-transparent border-none cursor-pointer"
                aria-label="Decrease"
              >
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-3.5 w-3.5"><line x1="5" y1="12" x2="19" y2="12"></line></svg>
              </button>
              <span class="product-qty-display w-10 text-center text-sm font-medium tabular-nums text-foreground">1</span>
              <input type="hidden" name="quantity" class="product-qty-input" value="1" />
              <button
                type="button"
                class="qty-btn-plus grid h-12 w-12 place-items-center text-foreground/70 hover:text-crimson transition bg-transparent border-none cursor-pointer"
                aria-label="Increase"
              >
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-3.5 w-3.5"><line x1="12" y1="5" x2="12" y2="19"></line><line x1="5" y1="12" x2="19" y2="12"></line></svg>
              </button>
            </div>

            {%- assign current_variant = product.selected_or_first_available_variant -%}
            <button
              type="submit"
              name="add"
              class="product-atc-submit-btn group relative flex-1 overflow-hidden border min-w-[200px] cursor-pointer bg-foreground text-ink"
              {% unless current_variant.available %}disabled{% endunless %}
              style="border: 1px solid var(--foreground);"
            >
              <span class="absolute inset-0 origin-left scale-x-0 bg-crimson transition-transform duration-500 ease-[cubic-bezier(0.16,1,0.3,1)] group-hover:scale-x-100"></span>
              <span class="relative flex h-12 items-center justify-center gap-2 text-[11px] font-bold uppercase tracking-[0.3em] transition-colors duration-500 group-hover:text-white atc-btn-text text-ink">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-4 w-4">
                  <path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"></path>
                  <line x1="3" y1="6" x2="21" y2="6"></line>
                  <path d="M16 10a4 4 0 0 1-8 0"></path>
                </svg>
                {%- if current_variant.available -%}
                  Add to cart
                {%- else -%}
                  Sold out
                {%- endif -%}
              </span>
            </button>

            <button
              type="button"
              aria-label="Wishlist"
              class="grid h-12 w-12 place-items-center border border-border/60 text-foreground/70 hover:text-crimson hover:border-crimson transition bg-transparent cursor-pointer"
            >
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-4 w-4">
                <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"></path>
              </svg>
            </button>
          </div>
        {%- endform -%}

        <!-- Shipping tagline -->
        <div class="mt-6 flex items-center gap-2 text-xs text-foreground/60">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-3.5 w-3.5 text-crimson">
            <rect x="1" y="3" width="15" height="13"></rect><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"></polygon><circle cx="5.5" cy="18.5" r="2.5"></circle><circle cx="18.5" cy="18.5" r="2.5"></circle>
          </svg>
          Free worldwide shipping over $199
        </div>

        <!-- Accordions -->
        <div class="mt-10 border-t border-border/60">
          <!-- Tab 1: Description -->
          <div class="border-b border-border/60 accordion-item">
            <button type="button" class="accordion-trigger flex w-full items-center justify-between py-5 text-left font-bold text-[11px] uppercase tracking-[0.3em] cursor-pointer bg-transparent border-none">
              <span class="text-foreground">Description</span>
              <span class="accordion-icon relative grid h-5 w-5 place-items-center transition-transform duration-300">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-4 w-4 text-foreground"><line x1="12" y1="5" x2="12" y2="19"></line><line x1="5" y1="12" x2="19" y2="12"></line></svg>
              </span>
            </button>
            <div class="accordion-panel grid overflow-hidden transition-all duration-500 ease-[cubic-bezier(0.16,1,0.3,1)]" style="grid-template-rows: 0fr;">
              <div class="min-h-0">
                <div class="pb-5 pr-8 text-sm leading-relaxed text-foreground/65">
                  {{ product.description }}
                </div>
              </div>
            </div>
          </div>



          <!-- Tab 3: Fabric & Care -->
          <div class="border-b border-border/60 accordion-item">
            <button type="button" class="accordion-trigger flex w-full items-center justify-between py-5 text-left font-bold text-[11px] uppercase tracking-[0.3em] cursor-pointer bg-transparent border-none">
              <span class="text-foreground">Fabric & Care</span>
              <span class="accordion-icon relative grid h-5 w-5 place-items-center transition-transform duration-300">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-4 w-4 text-foreground"><line x1="12" y1="5" x2="12" y2="19"></line><line x1="5" y1="12" x2="19" y2="12"></line></svg>
              </span>
            </button>
            <div class="accordion-panel grid overflow-hidden transition-all duration-500 ease-[cubic-bezier(0.16,1,0.3,1)]" style="grid-template-rows: 0fr;">
              <div class="min-h-0">
                <p class="pb-5 pr-8 text-sm leading-relaxed text-foreground/65">
                  100% combed organic cotton. Cold wash inside-out. Hang dry to preserve print. Do not iron directly on graphics.
                </p>
              </div>
            </div>
          </div>
        </div>

      </div>
    </div>
  </main>
</div>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    // 1. Gallery switcher
    const thumbBtns = document.querySelectorAll('.thumb-btn');
    const mainImgs = document.querySelectorAll('.main-gallery-img');

    function setActiveImage(index) {
      thumbBtns.forEach(btn => {
        if (btn.getAttribute('data-index') === index) {
          btn.classList.remove('border-border/60');
          btn.classList.add('border-crimson');
        } else {
          btn.classList.remove('border-crimson');
          btn.classList.add('border-border/60');
        }
      });

      mainImgs.forEach(img => {
        if (img.getAttribute('data-index') === index) {
          img.classList.remove('opacity-0');
          img.classList.add('opacity-100');
        } else {
          img.classList.remove('opacity-100');
          img.classList.add('opacity-0');
        }
      });
    }

    thumbBtns.forEach(btn => {
      const idx = btn.getAttribute('data-index');
      btn.addEventListener('mouseenter', () => setActiveImage(idx));
      btn.addEventListener('click', () => setActiveImage(idx));
    });

    // 2. Quantity selector
    const qtyDisplay = document.querySelector('.product-qty-display');
    const qtyInput = document.querySelector('.product-qty-input');
    const qtyMinus = document.querySelector('.qty-btn-minus');
    const qtyPlus = document.querySelector('.qty-btn-plus');

    if (qtyInput && qtyDisplay && qtyMinus && qtyPlus) {
      qtyMinus.addEventListener('click', () => {
        const val = parseInt(qtyInput.value) || 1;
        const newVal = Math.max(1, val - 1);
        qtyInput.value = newVal;
        qtyDisplay.textContent = newVal;
      });
      qtyPlus.addEventListener('click', () => {
        const val = parseInt(qtyInput.value) || 1;
        const newVal = val + 1;
        qtyInput.value = newVal;
        qtyDisplay.textContent = newVal;
      });
    }

    // 3. Variant selector
    const variantSelect = document.getElementById('ProductSelect-{{ section.id }}');
    const valueButtons = document.querySelectorAll('.variant-value-btn');
    const priceDisplay = document.querySelector('.product-price-display');
    const atcBtn = document.querySelector('.product-atc-submit-btn');
    const atcText = document.querySelector('.atc-btn-text');

    function updateSelectedVariant() {
      const optionGroups = document.querySelectorAll('.variant-option-group');
      const selectedOptions = [];
      optionGroups.forEach(group => {
        const activeBtn = group.querySelector('.variant-value-btn.border-crimson');
        if (activeBtn) {
          selectedOptions.push(activeBtn.getAttribute('data-value'));
        }
      });

      const matchString = selectedOptions.join(',');

      if (variantSelect) {
        let matched = false;
        Array.from(variantSelect.options).forEach(opt => {
          const optString = opt.getAttribute('data-options');
          if (optString === matchString) {
            opt.selected = true;
            matched = true;

            if (priceDisplay) {
              priceDisplay.textContent = opt.getAttribute('data-price');
            }

            const available = opt.getAttribute('data-available') === 'true';
            if (atcBtn) {
              if (available) {
                atcBtn.removeAttribute('disabled');
                if (atcText) {
                  atcText.innerHTML = `
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-4 w-4">
                      <path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"></path>
                      <line x1="3" y1="6" x2="21" y2="6"></line>
                      <path d="M16 10a4 4 0 0 1-8 0"></path>
                    </svg>
                    Add to cart
                  `;
                }
              } else {
                atcBtn.setAttribute('disabled', 'disabled');
                if (atcText) {
                  atcText.innerHTML = `
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-4 w-4">
                      <path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"></path>
                      <line x1="3" y1="6" x2="21" y2="6"></line>
                      <path d="M16 10a4 4 0 0 1-8 0"></path>
                    </svg>
                    Sold out
                  `;
                }
              }
            }
          }
        });
      }
    }

    valueButtons.forEach(btn => {
      btn.addEventListener('click', () => {
        const parentGroup = btn.closest('.variant-option-group');
        if (parentGroup) {
          parentGroup.querySelectorAll('.variant-value-btn').forEach(b => {
            b.classList.remove('border-crimson', 'bg-crimson', 'text-white');
            b.classList.add('border-border/60', 'text-foreground', 'bg-transparent');
          });
        }
        btn.classList.remove('border-border/60', 'text-foreground', 'bg-transparent');
        btn.classList.add('border-crimson', 'bg-crimson', 'text-white');
        updateSelectedVariant();
      });
    });

    // 4. Accordions
    const accordions = document.querySelectorAll('.accordion-item');
    accordions.forEach(item => {
      const trigger = item.querySelector('.accordion-trigger');
      const panel = item.querySelector('.accordion-panel');
      const icon = item.querySelector('.accordion-icon');

      trigger.addEventListener('click', () => {
        const isOpen = panel.style.gridTemplateRows === '1fr';
        
        accordions.forEach(otherItem => {
          otherItem.querySelector('.accordion-panel').style.gridTemplateRows = '0fr';
          otherItem.querySelector('.accordion-icon').classList.remove('rotate-45', 'text-crimson');
        });

        if (!isOpen) {
          panel.style.gridTemplateRows = '1fr';
          icon.classList.add('rotate-45', 'text-crimson');
        }
      });
    });

    // 5. AJAX Add to Cart
    const productForm = document.getElementById('product-form');
    if (productForm) {
      productForm.addEventListener('submit', (e) => {
        e.preventDefault();
        
        const atcBtn = productForm.querySelector('.product-atc-submit-btn');
        const atcText = productForm.querySelector('.atc-btn-text');
        
        if (atcBtn && atcBtn.hasAttribute('disabled')) return;
        
        // Add loading state
        if (atcBtn) {
          atcBtn.setAttribute('disabled', 'disabled');
          atcBtn.style.opacity = '0.7';
        }
        const originalText = atcText ? atcText.innerHTML : 'Add to cart';
        if (atcText) {
          atcText.innerHTML = `
            <svg class="animate-spin -ml-1 mr-3 h-4 w-4 text-white" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" style="animation: spin 1s linear infinite; display: inline-block; width: 1rem; height: 1rem; margin-right: 0.5rem; vertical-align: middle;">
              <style>
                @keyframes spin {
                  from { transform: rotate(0deg); }
                  to { transform: rotate(360deg); }
                }
              </style>
              <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4" style="opacity: 0.25;"></circle>
              <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z" style="opacity: 0.75;"></path>
            </svg>
            Adding...
          `;
        }
        
        const cartNotification = document.getElementById('cartNotificationPanel');
        const formData = new FormData(productForm);
        
        // Include sections to render for the cart notification popup
        if (cartNotification && typeof cartNotification.getSectionsToRender === 'function') {
          const sectionsToRender = cartNotification.getSectionsToRender() || [];
          sectionsToRender.forEach(sect => {
            formData.append('sections', sect.section || sect.id);
          });
          formData.append('sections_url', window.location.pathname);
        }
        
        fetch(window.routes?.cart_add_url || '/cart/add.js', {
          method: 'POST',
          body: formData
        })
        .then(response => response.json())
        .then(data => {
          if (data.status === 422 || data.status === 'bad_request' || data.description) {
            alert(data.description || data.message || 'Error adding to cart');
          } else {
            // Successfully added!
            if (cartNotification && typeof cartNotification.renderContents === 'function') {
              cartNotification.renderContents(data, true, atcBtn);
            }
            
            // Trigger header cart status animation & update if necessary
            const headerCartStatus = document.getElementById('headerCartStatus');
            if (headerCartStatus) {
              headerCartStatus.classList.add('header-cart-status--animate');
            }
          }
        })
        .catch(error => {
          console.error('Error adding to cart:', error);
        })
        .finally(() => {
          // Restore button state
          if (atcBtn) {
            atcBtn.removeAttribute('disabled');
            atcBtn.style.opacity = '1';
          }
          if (atcText) {
            atcText.innerHTML = originalText;
          }
        });
      });
    }
  });
</script>
{%- liquid
  if size_guide_block
    render 'product-size-guide', size_guide_dialog_id: size_guide_dialog_id, size_guide_block: size_guide_block, size_guide_heading: size_guide_block.settings.heading
  endif
  if popup_content_block
    render 'product-popup-content', popup_content_dialog_id: popup_content_dialog_id, popup_content_block: popup_content_block
  endif
  render 'main-product-gallery-dialog', product: product, place_holder: place_holder, rand: section_id, ratio: ratio_thubnails, object_fit: object_fit, media_background: section.settings.media_background
-%}
{%- liquid
  assign js_files = "component-add-to-cart.js" | split: ', '
  render 'js-loader', files: js_files
  render 'product-google-snippet', product: product
-%}

{% schema %}
{
  "name": "t:general.product_details",
  "settings": [
    {
      "type": "header",
      "content": "t:general.general"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:general.color_scheme",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "t:general.layout"
    },
    {
      "type": "checkbox",
      "id": "enable_sticky_content",
      "label": "t:general.enable_sticky_content",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "remove_padding_top",
      "label": "t:general.remove_padding_top",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "remove_padding_bottom",
      "label": "t:general.remove_padding_bottom",
      "default": false
    },
    {
      "type": "header",
      "content": "t:general.media",
      "info": "t:general.media_info"
    },
    {
      "type": "select",
      "id": "media_ratio",
      "label": "t:general.media_ratio",
      "default": "2/3",
      "options": [
        {
          "value": "1/1",
          "label": "t:general.square"
        },
        {
          "value": "2/3",
          "label": "t:general.portrait_2_3"
        },
        {
          "value": "3/2",
          "label": "t:general.landscape_3_2"
        },
        {
          "value": "auto",
          "label": "t:general.adapt_to_image"
        }
      ]
    },
    {
      "type": "select",
      "id": "thumbnails_ratio",
      "label": "t:general.thumbnail_ratio",
      "default": "1/1",
      "options": [
        {
          "group": "t:general.fill",
          "value": "1/1",
          "label": "t:general.square"
        },
        {
          "group": "t:general.fill",
          "value": "2/3",
          "label": "t:general.portrait_2_3"
        },
        {
          "group": "t:general.fill",
          "value": "3/2",
          "label": "t:general.landscape_3_2"
        },
        {
          "group": "t:general.fit",
          "value": "1/1 fit",
          "label": "t:general.square"
        },
        {
          "group": "t:general.fit",
          "value": "2/3 fit",
          "label": "t:general.portrait_2_3"
        },
        {
          "group": "t:general.fit",
          "value": "3/2 fit",
          "label": "t:general.landscape_3_2"
        },
        {
          "group": "t:general.fit",
          "value": "adapt",
          "label": "Adapt to image"
        }
      ]
    },
    {
      "type": "checkbox",
      "id": "enable_media_zoom",
      "label": "t:general.enable_media_zoom",
      "default": true
    },
    {
      "type": "select",
      "id": "media_layout",
      "label": "t:general.layout_on_large_screen",
      "options": [
        {
          "group": "t:general.main_media_with_thumbnails",
          "value": "slideshow-left",
          "label": "t:general.option_thumbnails_left"
        },
        {
          "group": "t:general.main_media_with_thumbnails",
          "value": "slideshow-right",
          "label": "t:general.option_thumbnails_right"
        },
        {
          "group": "t:general.main_media_with_thumbnails",
          "value": "slideshow-below",
          "label": "t:general.option_thumbnails_below"
        },
        {
          "group": "t:general.media_gallery",
          "value": "layout-grid-collage",
          "label": "t:general.option_collage"
        },
        {
          "group": "t:general.media_gallery",
          "value": "layout-grid-1-column",
          "label": "t:general.option_1_column"
        },
        {
          "group": "t:general.media_gallery",
          "value": "layout-grid-2-columns",
          "label": "t:general.option_2_columns"
        }
      ],
      "default": "layout-grid-collage"
    },
    {
      "type": "select",
      "id": "width_on_large_screen",
      "label": "t:general.width_on_large_screen",
      "default": "product__media-wrapper--full",
      "options": [
        {
          "value": "product__media-wrapper--full",
          "label": "t:general.wide"
        },
        {
          "value": "product__media-wrapper--compact",
          "label": "t:general.compact"
        }
      ]
    },
    {
      "type": "checkbox",
      "id": "enable_pagination_mobile",
      "label": "t:general.show_paginations_as_number_on_mobile",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "enable_thumbnail_mobile",
      "label": "t:general.show_media_thumbnails_mobile",
      "default": true
    },
    {
      "type": "color",
      "id": "media_background",
      "label": "t:general.media_background",
      "info": "t:general.media_background_info"
    },
    {
      "type": "header",
      "content": "t:general.advanced_description",
      "info": "t:general.advanced_description_info"
    },
    {
      "type": "select",
      "id": "content_source",
      "label": "t:general.content_source",
      "default": "static-page",
      "options": [
        {
          "value": "product-metafield",
          "label": "t:general.product_metafield"
        },
        {
          "value": "static-page",
          "label": "t:general.static_page"
        }
      ]
    },
    {
      "type": "page",
      "id": "static_page",
      "label": "t:general.static_page"
    },
    {
      "type": "text",
      "id": "product_metafield_name",
      "label": "t:general.product_metafield_name"
    },
    {
      "type": "header",
      "content": "t:general.sticky_bar"
    },
    {
      "type": "checkbox",
      "id": "show_sticky_purchasing_bar",
      "label": "t:general.show_sticky_purchasing_bar",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_price_sticky_bar",
      "label": "t:general.show_price",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_variants_sticky_bar",
      "label": "t:general.show_variants",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_product_information_on_mobile",
      "label": "t:general.show_product_info_mobile",
      "default": true
    },
    {
      "type": "select",
      "id": "sticky_button_type",
      "label": "t:general.button_type",
      "default": "add_to_cart",
      "options": [
        {
          "value": "add_to_cart",
          "label": "t:general.add_to_cart"
        },
        {
          "value": "dynamic_checkout",
          "label": "t:general.dynamic_checkout"
        }
      ]
    },
    {
      "type": "select",
      "id": "purchasing_bar_position",
      "label": "t:general.purchasing_bar_position",
      "info": "t:general.purchasing_bar_position_info",
      "options": [
        {
          "value": "left-0 product__sticky--left",
          "label": "t:general.bottom_left"
        },
        {
          "value": "right-0 product__sticky--right",
          "label": "t:general.bottom_right"
        }
      ],
      "default": "right-0 product__sticky--right"
    }
  ],
  "blocks": [
    {
      "type": "@app"
    },
    {
      "type": "title",
      "name": "t:general.title",
      "limit": 1,
      "settings": [
        {
          "type": "checkbox",
          "id": "enable_share",
          "label": "t:general.enable_share",
          "default": true
        }
      ]
    },
    {
      "type": "vendor",
      "name": "t:general.vendor",
      "limit": 1
    },
    {
      "type": "SKU",
      "name": "t:general.sku",
      "limit": 1
    },
    {
      "type": "price",
      "name": "t:general.price",
      "limit": 1,
      "settings": [
        {
          "type": "checkbox",
          "id": "show_sale_badge",
          "label": "t:general.show_sale_badge",
          "default": true
        },
        {
          "type": "checkbox",
          "id": "show_tax_and_shipping_policy",
          "label": "t:general.show_tax_and_shipping_policy",
          "default": true
        },
        {
          "type": "header",
          "content": "t:general.appearance"
        },
        {
          "type": "checkbox",
          "id": "show_background",
          "label": "t:general.show_background",
          "default": false
        },
        {
          "type": "select",
          "id": "heading_size",
          "label": "t:general.text_size",
          "default": "h4",
          "options": [
            {
              "value": "h6",
              "label": "t:general.small"
            },
            {
              "value": "h4",
              "label": "t:general.medium"
            },
            {
              "value": "h2",
              "label": "t:general.large"
            },
            {
              "value": "custom-size",
              "label": "t:general.custom"
            }
          ]
        },
        {
          "type": "range",
          "id": "custom_text_size",
          "label": "t:general.custom_text_size",
          "min": 14,
          "max": 48,
          "step": 1,
          "default": 16,
          "unit": "px",
          "visible_if": "{{ block.settings.heading_size == 'custom-size' }}"
        },
        {
          "type": "color",
          "id": "color_product_price",
          "label": "t:general.text_color",
          "default": "#000000"
        }
      ]
    },
    {
      "type": "variants",
      "name": "t:general.variants",
      "limit": 1,
      "settings": [
        {
          "type": "header",
          "content": "t:general.stock_number"
        },
        {
          "type": "checkbox",
          "id": "show_stock_number",
          "label": "t:general.show_stock_number",
          "info": "t:general.show_stock_number_info",
          "default": true
        },
        {
          "type": "header",
          "content": "t:general.selector"
        },
        {
          "type": "select",
          "id": "variant_picker_type",
          "label": "t:general.selector_type",
          "default": "button",
          "options": [
            {
              "value": "button",
              "label": "t:general.button"
            },
            {
              "value": "dropdown",
              "label": "t:general.dropdown"
            }
          ]
        },
        {
          "type": "checkbox",
          "id": "enable_variant_swatches",
          "label": "t:general.show_variant_swatches",
          "info": "t:general.configure_variant_swatches_info",
          "default": true
        },
        {
          "type": "checkbox",
          "id": "enable_variant_scroll",
          "label": "Enable scroll for variant buttons (slider)",
          "info": "When enabled, variant buttons become a horizontal scrollable slider",
          "default": false
        }
      ]
    },
    {
      "type": "purchasing",
      "name": "t:general.purchasing",
      "limit": 1,
      "settings": [
        {
          "type": "header",
          "content": "t:general.quantity_selector"
        },
        {
          "type": "select",
          "id": "show_quantity_selector",
          "label": "t:general.show_quantity_selector",
          "default": "add-to-cart",
          "options": [
            {
              "value": "add-to-cart",
              "label": "t:general.after_adding_to_cart_once"
            },
            {
              "value": "always",
              "label": "t:general.always"
            },
            {
              "value": "never",
              "label": "t:general.never"
            }
          ],
          "info": "t:general.show_quantity_selector_info"
        },
        {
          "type": "header",
          "content": "t:general.buy_buttons"
        },
        {
          "type": "checkbox",
          "id": "show_dynamic_checkout_buttons",
          "label": "t:general.show_dynamic_checkout_buttons",
          "info": "t:general.show_dynamic_checkout_buttons_info",
          "default": true
        },
        {
          "type": "checkbox",
          "id": "show_gift_card_recipient",
          "label": "t:general.show_gift_card_recipient",
          "info": "t:general.gift_card_recipient_info",
          "default": false
        }
      ]
    },
    {
      "type": "basic_description",
      "name": "t:general.basic_description",
      "limit": 1,
      "settings": [
        {
          "type": "header",
          "content": "t:general.content"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "t:general.heading"
        },
        {
          "type": "checkbox",
          "id": "enable_collapsible",
          "label": "t:general.enable_collapsible",
          "default": false
        },
        {
          "type": "checkbox",
          "id": "expand_collapsible_by_default",
          "label": "t:general.expand_collapsible_by_default",
          "default": true,
          "visible_if": "{{ block.settings.enable_collapsible == true }}"
        },
        {
          "type": "header",
          "content": "t:general.header_icon"
        },
        {
          "type": "checkbox",
          "id": "enable_icon",
          "label": "t:general.enable_icon",
          "default": false
        },
        {
          "type": "select",
          "id": "accent_scheme",
          "label": "t:general.accent_scheme",
          "info": "t:general.icon_color_info",
          "default": "color-accent-bg-1",
          "options": [
            {
              "value": "color-accent-bg-1",
              "label": "t:general.main"
            },
            {
              "value": "color-accent-bg-2",
              "label": "t:general.extra"
            },
            {
              "value": "none",
