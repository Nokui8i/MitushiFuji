<style>
  .mitushi-product-carousel-wrapper {
    background-color: #28282B !important;
    color: #f7f7f8 !important;
    padding: 0 !important;
    display: block;
    width: 100%;
  }

  .mitushi-product-carousel {
    background-color: #28282B;
    padding-top: 96px;
    padding-bottom: 96px;
  }

  .mitushi-carousel-container {
    margin: 0 auto;
    max-width: 1400px;
    padding: 0 24px;
  }

  .mitushi-carousel-header {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 24px;
    margin-bottom: 40px;
  }

  .mitushi-carousel-title-group > div:first-child {
    font-size: 10px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.5em;
    color: #cc132a;
    margin-bottom: 12px;
  }

  .mitushi-carousel-title-group > h2 {
    font-family: var(--font-display);
    letter-spacing: 0.02em;
    font-size: 32px;
    font-weight: 700;
    color: #f7f7f8;
    margin: 0;
  }

  @media (min-width: 768px) {
    .mitushi-carousel-title-group > h2 {
      font-size: 56px;
    }
  }

  .mitushi-carousel-controls {
    display: flex;
    gap: 8px;
  }

  .mitushi-carousel-btn {
    display: grid;
    place-items: center;
    width: 40px;
    height: 40px;
    border: 1px solid rgba(255, 255, 255, 0.2);
    background: transparent;
    color: #f7f7f8;
    cursor: pointer;
    transition: all 0.3s;
  }

  .mitushi-carousel-btn:hover {
    border-color: #cc132a;
    color: #cc132a;
  }

  .mitushi-carousel-track {
    display: flex;
    gap: 20px;
    overflow-x: auto;
    padding-bottom: 16px;
    scroll-snap-type: x mandatory;
    scroll-behavior: smooth;
    -ms-overflow-style: none;
    scrollbar-width: none;
  }

  .mitushi-carousel-track::-webkit-scrollbar {
    display: none;
  }

  .mitushi-product-card {
    position: relative;
    flex-shrink: 0;
    width: 78vw;
    snap-start: always;
  }

  @media (min-width: 640px) {
    .mitushi-product-card {
      width: 360px;
    }
  }

  .mitushi-product-image-wrapper {
    position: relative;
    aspect-ratio: 4 / 5;
    overflow: hidden;
    background-color: rgba(255, 255, 255, 0.05);
  }

  .mitushi-product-front,
  .mitushi-product-back {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: opacity 500ms;
  }

  .mitushi-product-back {
    opacity: 0;
  }

  .mitushi-product-card:hover .mitushi-product-back {
    opacity: 1;
  }

  .mitushi-product-card:hover .mitushi-product-front {
    opacity: 0;
  }

  .mitushi-product-badge {
    position: absolute;
    left: 12px;
    top: 12px;
    background-color: #cc132a;
    padding: 4px 10px;
    font-size: 10px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.3em;
    color: #f7f7f8;
    z-index: 10;
  }

  .mitushi-product-add-btn {
    position: absolute;
    right: 12px;
    top: 12px;
    display: grid;
    place-items: center;
    width: 40px;
    height: 40px;
    background-color: rgba(247, 247, 248, 0.95);
    color: #28282B;
    border: none;
    cursor: pointer;
    opacity: 0;
    transition: all 0.3s;
    z-index: 10;
  }

  .mitushi-product-card:hover .mitushi-product-add-btn {
    opacity: 1;
  }

  .mitushi-product-add-btn:hover {
    background-color: #cc132a;
    color: #f7f7f8;
  }

  .mitushi-product-cta {
    position: absolute;
    inset-x: 0;
    bottom: 0;
    background-color: rgba(40, 40, 43, 0.95);
    padding: 16px;
    backdrop-filter: blur(4px);
    transform: translateY(100%);
    transition: transform 500ms cubic-bezier(0.16, 1, 0.3, 1);
  }

  .mitushi-product-card:hover .mitushi-product-cta {
    transform: translateY(0);
  }

  .mitushi-product-cta-content {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
  }

  .mitushi-product-cta-info {
    display: flex;
    flex-direction: column;
  }

  .mitushi-product-cta-label {
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 0.3em;
    color: rgba(255, 255, 255, 0.6);
  }

  .mitushi-product-price {
    font-family: var(--font-display);
    letter-spacing: 0.02em;
    font-size: 20px;
    font-weight: 700;
    color: #f7f7f8;
  }

  .mitushi-product-cart-btn {
    background-color: #cc132a;
    padding: 10px 16px;
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.3em;
    color: #f7f7f8;
    border: none;
    cursor: pointer;
    transition: all 0.3s;
  }

  .mitushi-product-cart-btn:hover {
    background-color: #ff1a3a;
  }

  .mitushi-product-info {
    margin-top: 16px;
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 16px;
  }

  .mitushi-product-details {
    flex: 1;
  }

  .mitushi-product-name {
    font-size: 14px;
    font-weight: 500;
    color: #f7f7f8;
    margin: 0;
  }

  .mitushi-product-tag {
    margin-top: 6px;
    font-size: 12px;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: rgba(255, 255, 255, 0.5);
    margin-bottom: 0;
  }

  .mitushi-product-info-price {
    font-family: var(--font-display);
    letter-spacing: 0.02em;
    font-size: 18px;
    font-weight: 700;
    color: #f7f7f8;
  }
</style>

<div class="mitushi-product-carousel-wrapper" data-ui-component="Product Recommendation Section">
  <sht-prd-recom class="product-recommendations" data-url="{{ routes.product_recommendations_url }}?section_id={{ section.id }}&product_id={{ product.id }}&limit={{ section.settings.items_to_show }}">
    {%- if recommendations.performed and recommendations.products_count > 0 -%}
      <section class="mitushi-product-carousel">
        <div class="mitushi-carousel-container">
          <div class="mitushi-carousel-header">
            <div class="mitushi-carousel-title-group">
              <div>/ 03 — Recommendations</div>
              <h2>{{ section.settings.heading }}</h2>
            </div>
            <div class="mitushi-carousel-controls">
              <button class="mitushi-carousel-btn" aria-label="Previous" onclick="scrollRecCarousel(-1)">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16">
                  <path d="M15 19l-7-7 7-7"></path>
                </svg>
              </button>
              <button class="mitushi-carousel-btn" aria-label="Next" onclick="scrollRecCarousel(1)">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16">
                  <path d="M9 5l7 7-7 7"></path>
                </svg>
              </button>
            </div>
          </div>
          <div class="mitushi-carousel-track" id="recCarouselTrack">
            {% for recommendation in recommendations.products limit: section.settings.items_to_show %}
              {%- liquid
                assign index_mod = forloop.index
                assign prod_obj = recommendation
                assign prod_name = prod_obj.title
                assign prod_tag = prod_obj.collections.first.title | default: prod_obj.vendor
                assign prod_price = prod_obj.price | money_without_trailing_zeros
                assign prod_url = prod_obj.url
                assign variant_id = prod_obj.selected_or_first_available_variant.id

                if prod_obj.featured_image != blank
                  assign front_img = prod_obj.featured_image | img_url: '360x450'
                else
                  if index_mod == 1 or index_mod == 5
                    assign front_img = 'product-shirt-1.jpg' | asset_url
                  elsif index_mod == 2
                    assign front_img = 'product-shirt-2.jpg' | asset_url
                  elsif index_mod == 3
                    assign front_img = 'product-tank-1.jpg' | asset_url
                  else
                    assign front_img = 'product-shorts-1.jpg' | asset_url
                  endif
                endif

                if prod_obj.images[1] != blank
                  assign back_img = prod_obj.images[1] | img_url: '360x450'
                elsif prod_obj.featured_image != blank
                  assign back_img = prod_obj.featured_image | img_url: '360x450'
                else
                  if index_mod == 1 or index_mod == 5
                    assign back_img = 'product-shirt-1-back.jpg' | asset_url
                  elsif index_mod == 2
                    assign back_img = 'product-shirt-2-back.jpg' | asset_url
                  elsif index_mod == 3
                    assign back_img = 'product-tank-1-back.jpg' | asset_url
                  else
                    assign back_img = 'product-shorts-1-back.jpg' | asset_url
                  endif
                endif

                assign prod_badge = ''
                if prod_obj.compare_at_price > prod_obj.price
                  assign prod_badge = 'SALE'
                else
                  for tag in prod_obj.tags
                    assign tag_down = tag | downcase
                    if tag_down contains 'new'
                      assign prod_badge = 'NEW'
                      break
                    elsif tag_down contains 'hot'
                      assign prod_badge = 'HOT'
                      break
                    elsif tag_down contains 'drop'
                      assign prod_badge = tag | uppercase
                      break
                    endif
                  endfor
                endif
              -%}

              <article class="mitushi-product-card">
                <div class="mitushi-product-image-wrapper">
                  <a href="{{ prod_url }}">
                    <img
                      src="{{ front_img }}"
                      alt="{{ prod_name | escape }}"
                      loading="lazy"
                      class="mitushi-product-front"
                    />
                    <img
                      src="{{ back_img }}"
                      alt="{{ prod_name | escape }} (back)"
                      loading="lazy"
                      class="mitushi-product-back"
                    />
                  </a>
                  {% comment %}
                  {% if prod_badge != blank %}
                    <span class="mitushi-product-badge">{{ prod_badge }}</span>
                  {% endif %}
                  {% endcomment %}
                  
                  <button class="mitushi-product-add-btn" aria-label="Add to cart" {% if variant_id != blank %}onclick="addProductToCart('{{ variant_id }}')"{% endif %}>
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16">
                      <line x1="12" y1="5" x2="12" y2="19"></line>
                      <line x1="5" y1="12" x2="19" y2="12"></line>
                    </svg>
                  </button>

                  <div class="mitushi-product-cta">
                    <div class="mitushi-product-cta-content">
                      <div class="mitushi-product-cta-info">
                        <div class="mitushi-product-cta-label">Quick add</div>
                        <div class="mitushi-product-price">{{ prod_price }}</div>
                      </div>
                      <button class="mitushi-product-cart-btn" {% if variant_id != blank %}onclick="addProductToCart('{{ variant_id }}')"{% endif %}>Add to cart</button>
                    </div>
                  </div>
                </div>

                <div class="mitushi-product-info">
                  <div class="mitushi-product-details">
                    <h3 class="mitushi-product-name">
                      <a href="{{ prod_url }}" style="color: inherit; text-decoration: none;">{{ prod_name }}</a>
                    </h3>
                    <p class="mitushi-product-tag">{{ prod_tag }}</p>
                  </div>
                  <div class="mitushi-product-info-price">{{ prod_price }}</div>
                </div>
              </article>
            {% endfor %}
          </div>
        </div>
      </section>

      <script>
        function scrollRecCarousel(direction) {
          const track = document.getElementById('recCarouselTrack');
          if (track) {
            track.scrollBy({ left: direction * 380, behavior: 'smooth' });
          }
        }

        if (typeof window.addProductToCart !== 'function') {
          window.addProductToCart = function(variantId) {
            if (!variantId) return;
            const formData = {
              'items': [{
                'id': variantId,
                'quantity': 1
              }]
            };
            fetch((window.Shopify && window.Shopify.routes && window.Shopify.routes.root) ? window.Shopify.routes.root + 'cart/add.js' : '/cart/add.js', {
              method: 'POST',
              headers: {
                'Content-Type': 'application/json'
              },
              body: JSON.stringify(formData)
            })
            .then(response => response.json())
            .then(data => {
              console.log('Product added successfully', data);
              fetch(((window.Shopify && window.Shopify.routes && window.Shopify.routes.root) ? window.Shopify.routes.root + 'cart.js' : '/cart.js'))
              .then(res => res.json())
              .then(cart => {
                const badges = document.querySelectorAll('.mitushi-cart-badge, .header__cart-count');
                badges.forEach(badge => {
                  badge.textContent = cart.item_count;
                });
                document.dispatchEvent(new CustomEvent('cart:updated', {
                  detail: { cart: cart }
                }));
              });
            })
            .catch((error) => {
              console.error('Error adding to cart:', error);
            });
          }
        }
      </script>
    {%- endif -%}
  </sht-prd-recom>
</div>

{% schema %}
{
  "name": "t:general.product_recommendation",
  "settings": [
    {
      "type": "paragraph",
      "content": "t:general.related_products_info"
    },
    {
      "type": "paragraph",
      "content": "t:general.related_products_select_info"
    },
    {
      "type": "header",
      "content": "t:general.general"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:general.color_scheme",
      "default": "accent-1"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "t:general.heading",
      "default": "You might also like"
    },
    {
      "type": "header",
      "content": "t:general.layout"
    },
    {
      "type": "select",
      "id": "style_card",
      "label": "t:general.style",
      "default": "standard",
      "info": "t:general.mask_overlay",
      "options": [
        {
          "value": "standard",
          "label": "t:general.standard"
        },
        {
          "value": "card",
          "label": "t:general.card"
        }
      ]
    },
    {
      "type": "select",
      "id": "items_per_row_on_desktop",
      "label": "t:general.items_per_row_on_desktop",
      "default": "4",
      "options": [
        {
          "value": "3",
          "label": "3"
        },
        {
          "value": "4",
          "label": "4"
        },
        {
          "value": "5",
          "label": "5"
        },
        {
          "value": "6",
          "label": "6"
        }
      ]
    },
    {
      "type": "select",
      "id": "items_per_row_on_mobile",
      "label": "t:general.items_per_row_on_mobile",
      "default": "1",
      "options": [
        {
          "value": "1",
          "label": "1"
        },
        {
          "value": "2",
          "label": "2"
        }
      ]
    },
    {
      "type": "select",
      "id": "content_alignment",
      "label": "t:general.content_alignment",
      "default": "ta-left",
      "options": [
        {
          "value": "ta-left",
          "label": "t:general.left"
        },
        {
          "value": "ta-center",
          "label": "t:general.center"
        }
      ]
    },
    {
      "type": "range",
      "id": "items_to_show",
      "label": "t:general.items_to_show",
      "min": 1,
      "max": 10,
      "step": 1,
      "default": 4
    },
    {
      "type": "checkbox",
      "id": "enable_carousel",
      "label": "t:general.enable_carousel_on_mobile",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_navigation",
      "label": "t:general.show_navigation_on_mobile",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "remove_padding_top",
      "label": "t:general.remove_padding_top",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "remove_padding_bottom",
      "label": "t:general.remove_padding_bottom",
      "default": false
    }
  ]
}
{% endschema %}
